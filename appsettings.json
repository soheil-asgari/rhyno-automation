{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=OfficeAutoDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Tenancy": {
    "DefaultTenantId": "default",
    "Tenants": [
      {
        "TenantId": "default",
        "Name": "Default Tenant",
        "IsolationMode": "DatabasePerTenant",
        "ConnectionString": "Server=(localdb)\\mssqllocaldb;Database=OfficeAutoDb;Trusted_Connection=True;MultipleActiveResultSets=true",
        "DatabaseSchema": "dbo",
        "QueueNamespace": "default",
        "CachePrefix": "default",
        "StorageRoot": "tenants/default",
        "LogPrefix": "default",
        "LogRoot": "logs/default",
        "SettingsNamespace": "default:settings",
        "JobNamespace": "default:jobs",
        "RedisDatabase": 0,
        "EnableOutboxPublisher": true,
        "EnableWorkflowJobs": true
      }
    ]
  },
  "Workflow": {
    "SeedSampleData": true
  },
  "Outbox": {
    "BatchSize": 20,
    "PollIntervalSeconds": 10,
    "LockTimeoutSeconds": 60,
    "MaxRetryCount": 15
  },
  "BackgroundWorkers": {
    "RunInWebHost": false
  },
  "AuditRetention": {
    "Enabled": false,
    "RetainDays": 180,
    "BatchSize": 500,
    "ArchivePath": "logs/audit-archive"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "officeautomation.workflow",
    "UseSsl": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
