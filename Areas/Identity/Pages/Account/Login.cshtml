@page
@model LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ورود به سیستم راینو</title>
    <link rel="stylesheet" href="https://lib.arvancloud.ir/bootstrap/5.3.0-alpha1/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://lib.arvancloud.ir/bootstrap-icons/1.9.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/Login.css" />
 
</head>
<body>

    <div class="glass-card">
        <div class="brand-logo">
            <i class="bi bi-box-seam-fill"></i>
        </div>

        <h4 class="text-white fw-bold mb-1 text-center">پنل مدیریت راینو</h4>
        <p class="text-white-50 small mb-4 text-center">ورود به دنیای مدیریت هوشمند</p>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger mb-3 small text-center"></div>

            <div class="input-group-glass">
                <i class="bi bi-person"></i>
                <input asp-for="Input.Email" class="form-control" placeholder="نام کاربری" />
            </div>

            <div class="input-group-glass">
                <i class="bi bi-lock"></i>
                <input asp-for="Input.Password" class="form-control" type="password" placeholder="رمز عبور" />
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4 px-1">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" style="background-color: transparent; border-color: rgba(255,255,255,0.2);">
                    <label class="text-white-50 small" style="cursor:pointer">مرا به خاطر بسپار</label>
                </div>
                <a href="#" class="text-accent small text-decoration-none" style="color: var(--accent);">فراموشی رمز؟</a>
            </div>

            <button type="submit" class="btn btn-login">
                <span>ورود به حساب</span>
                <i class="bi bi-arrow-left-short fs-4"></i>
            </button>
        </form>

        <div class="login-footer text-center">
            &copy; 2026 طراحی شده برای پورتال سازمانی راینو
        </div>
    </div>

</body>
</html>