@page
@model LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ورود به سیستم راینو</title>
    <link rel="stylesheet" href="https://lib.arvancloud.ir/bootstrap/5.3.0-alpha1/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://lib.arvancloud.ir/bootstrap-icons/1.9.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/Login.css" />
 
</head>
<body>
    <main class="login-shell">
        <section class="login-hero" aria-label="معرفی سامانه">
            <div class="hero-badge">
                <i class="bi bi-stars"></i>
                <span>نسخه سازمانی 2026</span>
            </div>
            <div class="hero-copy">
                <div class="brand-lockup">
                    <div class="brand-logo">
                        <i class="bi bi-box-seam-fill"></i>
                    </div>
                    <div>
                        <span class="brand-kicker">Rhyno Automation</span>
                        <h1>پنل مدیریت راینو</h1>
                    </div>
                </div>
                <p>ورود امن به مرکز مدیریت عملیات، مکاتبات، منابع انسانی، مالی و انبار در یک فضای یکپارچه.</p>
            </div>
            <div class="hero-metrics" aria-label="قابلیت‌های کلیدی">
                <div class="metric-pill">
                    <i class="bi bi-shield-check"></i>
                    <span>ورود امن</span>
                </div>
                <div class="metric-pill">
                    <i class="bi bi-lightning-charge"></i>
                    <span>دسترسی سریع</span>
                </div>
                <div class="metric-pill">
                    <i class="bi bi-grid-1x2"></i>
                    <span>هاب سازمانی</span>
                </div>
            </div>
        </section>

        <section class="glass-card" aria-label="فرم ورود">
            <div class="form-head">
                <span class="form-eyebrow">خوش آمدید</span>
                <h2>ورود به حساب کاربری</h2>
                <p>برای ادامه، نام کاربری و رمز عبور خود را وارد کنید.</p>
            </div>

            <form method="post" class="login-form">
                <div asp-validation-summary="All" class="validation-message"></div>

                <label class="field-label" asp-for="Input.Email">نام کاربری</label>
                <div class="input-group-glass">
                    <i class="bi bi-person"></i>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="مثلا: admin یا نام کاربری شما" />
                </div>

                <label class="field-label" asp-for="Input.Password">رمز عبور</label>
                <div class="input-group-glass">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="رمز عبور" />
                </div>

                <div class="login-options">
                    <div class="form-check remember-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label">مرا به خاطر بسپار</label>
                    </div>
                    <a href="#" class="forgot-link">فراموشی رمز؟</a>
                </div>

                <button type="submit" class="btn btn-login">
                    <span>ورود به سامانه</span>
                    <i class="bi bi-arrow-left-short"></i>
                </button>
            </form>

            <div class="login-footer">
                <span>&copy; 2026 پورتال سازمانی راینو</span>
                <span class="footer-dot"></span>
                <span>Secure Workspace</span>
            </div>
        </section>
    </main>

    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>
    <div class="ambient ambient-three"></div>
</body>
</html>
