@model OfficeAutomation.Models.Letter

@{
    ViewData["Title"] = "حذف نامه";
    var sender = Model.Sender?.FullName ?? Model.Sender?.UserName ?? "نامشخص";
    var receiver = Model.Receiver?.FullName ?? Model.Receiver?.UserName ?? "نامشخص";
}

<div class="page-shell letters-page">
    <div class="section-header">
        <div>
            <h1 class="section-title">حذف نامه</h1>
            <p class="section-subtitle">این عملیات برگشت‌پذیر نیست. قبل از حذف، اطلاعات اصلی نامه را مرور کنید.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">بازگشت</a>
    </div>

    <div class="form-card">
        <div class="alert alert-warning mb-4">آیا مطمئن هستید که می‌خواهید این نامه را حذف کنید؟</div>

        <dl class="row g-3 mb-0">
            <dt class="col-sm-3 text-muted">موضوع</dt>
            <dd class="col-sm-9">@Model.Title</dd>

            <dt class="col-sm-3 text-muted">فرستنده</dt>
            <dd class="col-sm-9">@sender</dd>

            <dt class="col-sm-3 text-muted">گیرنده</dt>
            <dd class="col-sm-9">@receiver</dd>

            <dt class="col-sm-3 text-muted">تاریخ ارسال</dt>
            <dd class="col-sm-9">@Model.SentDate.ToString("yyyy/MM/dd HH:mm")</dd>

            <dt class="col-sm-3 text-muted">وضعیت</dt>
            <dd class="col-sm-9">@WorkflowStatus.Label(Model.WorkflowStatus)</dd>
        </dl>

        <div class="action-bar mt-4">
            <form asp-action="Delete" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">حذف نهایی</button>
            </form>
            <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
        </div>
    </div>
</div>
