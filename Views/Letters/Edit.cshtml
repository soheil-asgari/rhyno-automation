@model OfficeAutomation.Models.Letter
@{
    ViewData["Title"] = "ویرایش نامه";
}

<div class="page-shell letters-page">
    <div class="section-header">
        <div>
            <h1 class="section-title">ویرایش نامه</h1>
            <p class="section-subtitle">اطلاعات اصلی نامه را اصلاح و ذخیره کنید.</p>
        </div>
        <div class="action-bar">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-right"></i>
                بازگشت
            </a>
        </div>
    </div>

    <div class="form-card">
        <form asp-action="Edit" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="col-12 col-lg-6">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="col-12 col-lg-6">
                <label asp-for="SentDate" class="form-label"></label>
                <input asp-for="SentDate" class="form-control" />
                <span asp-validation-for="SentDate" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Body" class="form-label"></label>
                <textarea asp-for="Body" class="form-control" rows="8"></textarea>
                <span asp-validation-for="Body" class="text-danger small"></span>
            </div>

            <div class="col-12 col-lg-6">
                <label asp-for="SenderId" class="form-label"></label>
                <select asp-for="SenderId" class="form-select" asp-items="ViewBag.SenderId"></select>
                <span asp-validation-for="SenderId" class="text-danger small"></span>
            </div>

            <div class="col-12 col-lg-6">
                <label asp-for="ReceiverId" class="form-label"></label>
                <select asp-for="ReceiverId" class="form-select" asp-items="ViewBag.ReceiverId"></select>
                <span asp-validation-for="ReceiverId" class="text-danger small"></span>
            </div>

            <div class="col-12 col-lg-6">
                <label asp-for="ReadDate" class="form-label"></label>
                <input asp-for="ReadDate" class="form-control" />
                <span asp-validation-for="ReadDate" class="text-danger small"></span>
            </div>

            <div class="col-12 col-lg-6 d-flex align-items-end">
                <div class="form-check mb-0">
                    <input class="form-check-input" asp-for="IsRead" />
                    <label class="form-check-label" asp-for="IsRead"></label>
                </div>
            </div>

            <div class="col-12 d-flex justify-content-between align-items-center pt-2">
                <a asp-action="Index" class="btn btn-light">انصراف</a>
                <button type="submit" class="btn btn-primary">ذخیره تغییرات</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
