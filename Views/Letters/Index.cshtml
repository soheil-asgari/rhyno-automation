@model IEnumerable<OfficeAutomation.Models.Letter>
@{
    ViewData["Title"] = "کارتابل نامه‌ها";
    var pc = new System.Globalization.PersianCalendar();
    var list = Model?.ToList() ?? new List<OfficeAutomation.Models.Letter>();
    var currentUserId = User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var unreadCount = list.Count(item => !item.IsRead && (item.ReceiverId == currentUserId || item.FinalReceiverId == currentUserId));
    var sentCount = list.Count(item => item.SenderId == currentUserId);
    var inboxCount = list.Count(item => (item.ReceiverId == currentUserId || item.FinalReceiverId == currentUserId));
}

<div class="container-fluid py-4 letters-page">
    @Html.AntiForgeryToken()

    <div class="header-section mb-5">
        <div class="d-flex align-items-center gap-3">
            <div class="brand-icon-box">
                <i class="bi bi-stack"></i>
            </div>
            <div>
                <h2 class="page-title">کارتابل نامه‌ها</h2>
                <p class="page-subtitle">مدیریت و پیگیری هوشمند مکاتبات اداری</p>
            </div>
        </div>

        <div class="header-actions">
            <div class="search-box-modern">
                <i class="bi bi-search"></i>
                <input id="lettersSearch" type="text" placeholder="جستجوی شماره، عنوان یا فرستنده...">
            </div>
            <a asp-action="Create" class="btn-new-letter">
                <i class="bi bi-plus-circle-fill"></i>
                <span>ایجاد نامه جدید</span>
            </a>
        </div>
    </div>

    <div class="letter-filter-bar mb-4">
        <button type="button" class="letter-filter-btn active" data-letter-filter="all">
            <i class="bi bi-folder2-open"></i> همه (@list.Count)
        </button>
        <button type="button" class="letter-filter-btn" data-letter-filter="unread">
            <i class="bi bi-envelope-open"></i> خوانده‌نشده (@unreadCount)
        </button>
        <button type="button" class="letter-filter-btn" data-letter-filter="sent">
            <i class="bi bi-send"></i> ارسالی (@sentCount)
        </button>
        <button type="button" class="letter-filter-btn" data-letter-filter="received">
            <i class="bi bi-inbox"></i> دریافتی (@inboxCount)
        </button>
    </div>

    <div class="letters-ai-summary mb-4">
        <div class="letters-ai-summary-head">
            <div>
                <h5><i class="bi bi-stars"></i> خلاصه هوشمند نامه‌ها</h5>
                <p>خلاصه نامه‌های دریافتی، خوانده‌نشده، ارسالی یا گردش یک نامه مشخص را با هوش مصنوعی ببینید.</p>
            </div>
        </div>
        <div class="letters-ai-summary-controls">
            <select id="letterSummaryMode" class="form-select">
                <option value="week">خلاصه نامه‌های دریافتی هفته اخیر</option>
                <option value="unread">خلاصه نامه‌های خوانده‌نشده</option>
                <option value="sent">خلاصه نامه‌های ارسالی من</option>
                <option value="selected">خلاصه و گردش نامه انتخاب‌شده</option>
            </select>
            <select id="letterSummaryId" class="form-select">
                <option value="">انتخاب موضوع نامه...</option>
                @foreach (var item in list.OrderByDescending(item => item.SentDate))
                {
                    <option value="@item.Id">@item.Title</option>
                }
            </select>
            <button id="btnSummarizeLetters" type="button" class="btn btn-primary">
                <i class="bi bi-card-text"></i>
                نمایش خلاصه
            </button>
        </div>
        <div id="letterSummaryResult" class="letters-ai-summary-result">
            یک گزینه را انتخاب کنید و دکمه نمایش خلاصه را بزنید.
        </div>
    </div>

    <div class="letters-container">
        @foreach (var item in list)
        {
            var shamsiDate = $"{pc.GetYear(item.SentDate)}/{pc.GetMonth(item.SentDate):D2}/{pc.GetDayOfMonth(item.SentDate):D2}";
            var isUnread = !item.IsRead && (item.ReceiverId == currentUserId || item.FinalReceiverId == currentUserId);
            var isSentByCurrentUser = item.SenderId == currentUserId;
            var isReceivedByCurrentUser = item.ReceiverId == currentUserId || item.FinalReceiverId == currentUserId;

            <div class="letter-row-card" data-unread="@(isUnread ? "1" : "0")" data-sent="@(isSentByCurrentUser ? "1" : "0")" data-received="@(isReceivedByCurrentUser ? "1" : "0")">
                <div class="row align-items-center">
                    <div class="col-lg-5 col-md-4 mb-3 mb-md-0">
                        <div class="d-flex align-items-center gap-3">
                            <div class="document-icon">
                                <i class="bi bi-file-earmark-text-fill"></i>
                            </div>
                            <div class="content-info">
                                <a href="@Url.Action("Details", new { id = item.Id })" class="letter-title">@item.Title</a>
                                <div class="flow-info">
                                    <span class="badge-person sender">@item.Sender.FullName</span>
                                    <i class="bi bi-chevron-left"></i>
                                    <span class="badge-person receiver">@item.Receiver.FullName</span>
                                    @if (isUnread)
                                    {
                                        <span class="badge-person unread-pill ms-2">خوانده‌نشده</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-3 text-center mb-3 mb-md-0">
                        <div class="date-wrapper">
                            <i class="bi bi-calendar-event"></i>
                            <span>@shamsiDate</span>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-2 text-center mb-3 mb-md-0">
                        <div class="status-indicator @(item.IsWorkflowCompleted ? "approved" : "pending")">
                            <span class="dot"></span>
                            @(item.IsWorkflowCompleted ? "تایید نهایی" : $"در گردش - مرحله {item.CurrentWorkflowStep}")
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-3 text-start">
                        <div class="action-flex">
                            <a href="@Url.Action("Details", new { id = item.Id })" class="btn-action-minimal view" title="مشاهده">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (!item.IsWorkflowCompleted && item.ReceiverId == currentUserId)
                            {
                                <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action-minimal view" title="تایید و ارجاع مرحله بعد">
                                        <i class="bi bi-check2-circle"></i>
                                    </button>
                                </form>
                            }
                            <button type="button" class="btn-action-minimal print" title="چاپ">
                                <i class="bi bi-printer"></i>
                            </button>
                            <a href="@Url.Action("Create", new { replyToId = item.Id })" class="btn-action-minimal reply" title="پاسخ">
                                <i class="bi bi-reply-fill"></i>
                            </a>
                            <button type="button" class="btn-action-minimal more" title="بیشتر">
                                <i class="bi bi-three-dots"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/letters-index.css" />
    <style>
        html.theme-dark .letters-page .header-section,
        html.theme-dark .letters-page .letter-row-card {
            background: rgba(30, 41, 59, 0.8) !important;
            border-color: #334155 !important;
            color: #e2e8f0 !important;
        }
        html.theme-dark .letters-page .page-title,
        html.theme-dark .letters-page .letter-title,
        html.theme-dark .letters-page .date-wrapper,
        html.theme-dark .letters-page .flow-info,
        html.theme-dark .letters-page .status-indicator {
            color: #e2e8f0 !important;
        }
        html.theme-dark .letters-page .search-box-modern input {
            background: #1e293b !important;
            border-color: #334155 !important;
            color: #f8fafc !important;
        }
        html.theme-dark .letters-page .btn-action-minimal {
            background: #0f172a !important;
            border-color: #334155 !important;
        }
        .letters-ai-summary {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            padding: 14px;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.05);
        }
        .letters-ai-summary h5 {
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 0 0 4px;
            font-weight: 800;
            color: #1e293b;
        }
        .letters-ai-summary p {
            margin: 0 0 12px;
            color: #64748b;
            font-size: 0.84rem;
        }
        .letters-ai-summary-controls {
            display: grid;
            grid-template-columns: minmax(180px, 1fr) minmax(180px, 1fr) auto;
            gap: 10px;
        }
        .letters-ai-summary select,
        .letters-ai-summary button,
        .letters-ai-summary-result {
            border-radius: 6px !important;
        }
        .letters-ai-summary-result {
            margin-top: 12px;
            min-height: 70px;
            padding: 12px;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            color: #334155;
            line-height: 1.9;
            white-space: pre-wrap;
        }
        .letter-filter-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        .letter-filter-btn {
            border: 1px solid #e2e8f0;
            background: white;
            color: #334155;
            border-radius: 10px;
            padding: 8px 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s ease;
        }
        .letter-filter-btn.active,
        .letter-filter-btn:hover {
            background: #4361ee;
            border-color: #4361ee;
            color: white;
        }
        .unread-pill {
            color: #f97316;
            font-size: 0.75rem;
            background: #fff7ed;
            border: 1px solid #fed7aa;
            border-radius: 999px;
            padding: 2px 10px;
        }
        html.theme-dark .letters-ai-summary {
            background: rgba(30, 41, 59, 0.8) !important;
            border-color: #334155 !important;
        }
        html.theme-dark .letters-ai-summary h5,
        html.theme-dark .letters-ai-summary p,
        html.theme-dark .letters-ai-summary-result {
            color: #f1f5f9 !important;
        }
        html.theme-dark .letters-ai-summary-result {
            background: #111827 !important;
            border-color: #334155 !important;
        }
        html.theme-dark .letter-filter-btn {
            background: #0f172a !important;
            border-color: #334155 !important;
            color: #f8fafc !important;
        }
        html.theme-dark .letter-filter-btn.active,
        html.theme-dark .letter-filter-btn:hover {
            background: #1d4ed8 !important;
            border-color: #1d4ed8 !important;
            color: #fff !important;
        }
        html.theme-dark .unread-pill {
            color: #fdba74 !important;
            background: #451a03 !important;
            border-color: #7c2d12 !important;
        }
        @@media (max-width: 768px) {
            .letters-ai-summary-controls {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@section Scripts {
    <script src="~/js/letters-index.js"></script>
    <script src="~/js/letters-ai.js"></script>
}
