@model IEnumerable<OfficeAutomation.Models.Letter>

@{
    ViewData["Title"] = "کارتابل نامه‌ها";
    var pc = new System.Globalization.PersianCalendar();
    var list = Model?.ToList() ?? new List<OfficeAutomation.Models.Letter>();
}

<div class="container-fluid mt-4 letters-page" style="direction: rtl; text-align: right;">

    <!-- Header / Toolbar -->
    <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
        <div class="d-flex align-items-center gap-2">
            <div class="letters-title-icon">
                <i class="bi bi-envelope-paper"></i>
            </div>
            <div>
                <h4 class="mb-1">کارتابل نامه‌ها</h4>
                <div class="text-muted small">
                    <span>تعداد:</span>
                    <span class="badge bg-light text-dark border" id="lettersCount">@list.Count</span>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-center">
            <!-- Search -->
            <div class="letters-search">
                <i class="bi bi-search"></i>
                <input id="lettersSearch" type="text" class="form-control" placeholder="جستجو در عنوان، فرستنده، گیرنده..." autocomplete="off" />
                <button type="button" class="btn btn-sm btn-light border letters-search-clear d-none" id="lettersSearchClear" aria-label="پاک کردن">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-lg ms-1"></i>
                ایجاد نامه جدید
            </a>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 letters-table" id="lettersTable">
                    <thead>
                        <tr>
                            <th style="min-width: 280px;">عنوان</th>
                            <th style="width: 140px;">تاریخ ارسال</th>
                            <th style="width: 180px;">فرستنده</th>
                            <th style="width: 180px;">گیرنده</th>
                            <th style="width: 160px;" class="text-center">عملیات</th>
                        </tr>
                    </thead>
                    <tbody id="lettersTbody">
                        @if (!list.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center p-5">
                                    <div class="text-muted">
                                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                                        نامه‌ای برای نمایش وجود ندارد.
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in list)
                            {
                                var title = item.Title ?? "";
                                var sender = item.Sender?.FullName ?? "—";
                                var receiver = item.Receiver?.FullName ?? "—";

                                string shamsiDate = $"{pc.GetYear(item.SentDate)}/{pc.GetMonth(item.SentDate):D2}/{pc.GetDayOfMonth(item.SentDate):D2}";
                                var greg = item.SentDate.ToString("yyyy-MM-dd");

                                <tr class="letter-row"
                                    data-title="@title"
                                    data-sender="@sender"
                                    data-receiver="@receiver"
                                    data-date="@greg">
                                    <td>
                                        <div class="d-flex align-items-start gap-2">
                                            <span class="letter-dot"></span>
                                            <div class="min-w-0">
                                                <div class="letter-title text-truncate">@title</div>
                                                <div class="letter-sub text-muted small">
                                                    <i class="bi bi-person-up me-1"></i>
                                                    <span>@sender</span>
                                                    <span class="mx-2">•</span>
                                                    <i class="bi bi-person-down me-1"></i>
                                                    <span>@receiver</span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- لینک مخفی برای کلیک راحت‌تر روی عنوان (اختیاری) -->
                                        <a asp-action="Details" asp-route-id="@item.Id" class="stretched-link" aria-label="نمایش نامه"></a>
                                    </td>

                                    <td>
                                        <span class="badge bg-light text-dark border letter-date">@shamsiDate</span>
                                    </td>

                                    <td>
                                        <span class="badge bg-light text-dark border letter-person">@sender</span>
                                    </td>

                                    <td>
                                        <span class="badge bg-light text-dark border letter-person">@receiver</span>
                                    </td>

                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye ms-1"></i>
                                            نمایش و چاپ
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- Empty state for search -->
            <div class="letters-empty-search d-none" id="lettersEmptySearch">
                <div class="text-muted text-center p-5">
                    <i class="bi bi-search fs-3 d-block mb-2"></i>
                    موردی با این عبارت پیدا نشد.
                </div>
            </div>
        </div>
    </div>

</div>

@section Styles {
    <link rel="stylesheet" href="~/css/letters-index.css" />
}

@section Scripts {
    <script src="~/js/letters-index.js"></script>
}