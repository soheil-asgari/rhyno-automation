@model IEnumerable<OfficeAutomation.Models.Letter>
@{
    ViewData["Title"] = "کارتابل نامه‌ها";
    var pc = new System.Globalization.PersianCalendar();
    var list = Model?.ToList() ?? new List<OfficeAutomation.Models.Letter>();
}

<div class="container-fluid py-4 letters-page">
    <div class="header-section mb-5">
        <div class="d-flex align-items-center gap-3">
            <div class="brand-icon-box">
                <i class="bi bi-stack"></i>
            </div>
            <div>
                <h2 class="page-title">کارتابل نامه‌ها</h2>
                <p class="page-subtitle">مدیریت و پیگیری هوشمند مکاتبات اداری</p>
            </div>
        </div>

        <div class="header-actions">
            <div class="search-box-modern">
                <i class="bi bi-search"></i>
                <input id="lettersSearch" type="text" placeholder="جستجوی شماره، عنوان یا فرستنده...">
            </div>
            <a asp-action="Create" class="btn-new-letter">
                <i class="bi bi-plus-circle-fill"></i>
                <span>ایجاد نامه جدید</span>
            </a>
        </div>
    </div>

    <div class="letters-container">
        @foreach (var item in list)
        {
            var shamsiDate = $"{pc.GetYear(item.SentDate)}/{pc.GetMonth(item.SentDate):D2}/{pc.GetDayOfMonth(item.SentDate):D2}";

            <div class="letter-row-card">
                <div class="row align-items-center">
                    <div class="col-lg-5 col-md-4 mb-3 mb-md-0">
                        <div class="d-flex align-items-center gap-3">
                            <div class="document-icon">
                                <i class="bi bi-file-earmark-text-fill"></i>
                            </div>
                            <div class="content-info">
                                <a href="#" class="letter-title">@item.Title</a>
                                <div class="flow-info">
                                    <span class="badge-person sender">@item.Sender.FullName</span>
                                    <i class="bi bi-chevron-left"></i>
                                    <span class="badge-person receiver">@item.Receiver.FullName</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-3 text-center mb-3 mb-md-0">
                        <div class="date-wrapper">
                            <i class="bi bi-calendar-event"></i>
                            <span>@shamsiDate</span>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-2 text-center mb-3 mb-md-0">
                        <div class="status-indicator @(item.IsWorkflowCompleted ? "approved" : "pending")">
                            <span class="dot"></span>
                            @(item.IsWorkflowCompleted ? "تایید نهایی" : $"در گردش - مرحله {item.CurrentWorkflowStep}")
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-3 text-start">
                        <div class="action-flex">
                            <a href="@Url.Action("Details", new { id = item.Id })" class="btn-action-minimal view" title="مشاهده">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (!item.IsWorkflowCompleted && item.ReceiverId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                            {
                                <form asp-action="Approve" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action-minimal view" title="تایید و ارجاع مرحله بعد">
                                        <i class="bi bi-check2-circle"></i>
                                    </button>
                                </form>
                            }
                            <button type="button" class="btn-action-minimal print" title="چاپ">
                                <i class="bi bi-printer"></i>

                            </button>
                            <button type="button" class="btn-action-minimal more" title="بیشتر">
                                <i class="bi bi-three-dots"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/letters-index.css" />
    <style>
        html.theme-dark .letters-page .header-section,
        html.theme-dark .letters-page .letter-row-card {
            background: rgba(30, 41, 59, 0.8) !important;
            border-color: #334155 !important;
            color: #e2e8f0 !important;
        }
        html.theme-dark .letters-page .page-title,
        html.theme-dark .letters-page .letter-title,
        html.theme-dark .letters-page .date-wrapper,
        html.theme-dark .letters-page .flow-info,
        html.theme-dark .letters-page .status-indicator {
            color: #e2e8f0 !important;
        }
        html.theme-dark .letters-page .search-box-modern input {
            background: #1e293b !important;
            border-color: #334155 !important;
            color: #f8fafc !important;
        }
        html.theme-dark .letters-page .btn-action-minimal {
            background: #0f172a !important;
            border-color: #334155 !important;
        }
    </style>
}

@section Scripts {
    <script src="~/js/letters-index.js"></script>
}
