@model OfficeAutomation.Models.Letter

@{
    Layout = "_Layout";
    ViewData["Title"] = "ارسال نامه جدید";

    var pc = new System.Globalization.PersianCalendar();
    var now = DateTime.Now;
    string persianDate = $"{pc.GetYear(now)}/{pc.GetMonth(now):D2}/{pc.GetDayOfMonth(now):D2}";
}

<link rel="stylesheet" href="/css/letter.css">

<script src="https://lib.arvancloud.ir/ckeditor5/36.0.1/ckeditor.js"></script>

<div class="word-processor-container">

    <!-- Toolbar -->
    <div class="top-toolbar">
        <div class="toolbar-row">

            <div class="left-tools">
                <div class="input-group receiver-box">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <select id="receiverSelect" class="form-select" asp-items="ViewBag.ReceiverId">
                        <option value="">انتخاب گیرنده یا واحد...</option>
                    </select>
                </div>

                <input type="text" id="subjectInput" class="form-control subject-input" placeholder="موضوع نامه...">
            </div>

            <button class="btn btn-primary fw-bold send-btn" id="btnSendLetter">
                <i class="bi bi-send"></i> ارسال نهایی
            </button>
        </div>
    </div>

    <!-- Paper -->
    <div class="paper-wrapper">
        <div id="paper" class="paper">

            <!-- Header -->
            <div class="header-row">
                <div class="header-info">
                    <div>تاریخ: @persianDate</div>
                    <div>شماره: RH-@now.Ticks.ToString().Substring(12)</div>
                    <div>پیوست: ندارد</div>
                </div>

                <div class="header-center">
                    <h5 class="fw-bold">بسمه تعالی</h5>
                    <div class="fw-bold mt-2">شرکت فنی مهندسی راینو</div>
                </div>

                <img src="/images/logo.png" class="letter-logo" alt="لوگو" onerror="this.style.display='none'">
            </div>

            <!-- Receiver / Subject -->
            <div class="receiver-block">
                <div class="fw-bold receiver-line">
                    <span id="gender-prefix">جناب آقای / سرکار خانم</span>
                    <span id="display-receiver" class="receiver-name">....................</span>
                </div>
                <div class="fw-bold">
                    موضوع: <span id="display-subject" class="subject-display">....................</span>
                </div>
            </div>

            <!-- Editor -->
            <div id="editor-container">
                <div id="editor">
                    <p>با سلام و احترام،</p>
                    <p>به استحضار می‌رساند...</p>
                </div>
            </div>

            <!-- Signature -->
            <div class="signature-wrapper">
                <div class="signature-box">
                    <p class="fw-bold mb-1">با تقدیم احترام</p>
                    <p class="fw-bold">@ViewBag.SenderFullName</p>
                    <p class="small text-muted">@ViewBag.SenderRole</p>

                    @if (ViewBag.UserSignature != null)
                    {
                        <img src="@ViewBag.UserSignature" class="signature-img" alt="امضا">
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Hidden Form -->
<form id="finalForm" asp-action="Create" method="post" class="d-none">
    <input type="hidden" id="hTitle" name="Title">
    <input type="hidden" id="hContent" name="Body">
    <input type="hidden" id="hReceiver" name="ReceiverId">
    @Html.AntiForgeryToken()
</form>
<script>
    window.usersList = @Html.Raw(ViewBag.UsersData ?? "[]");
</script>
<script src="/js/letter.js"></script>
