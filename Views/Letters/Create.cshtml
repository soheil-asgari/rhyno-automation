@model OfficeAutomation.Models.Letter

@{
    Layout = "_Layout";
    ViewData["Title"] = "ارسال نامه جدید";

    var pc = new System.Globalization.PersianCalendar();
    var now = DateTime.Now;
    string persianDate = $"{pc.GetYear(now)}/{pc.GetMonth(now):D2}/{pc.GetDayOfMonth(now):D2}";
    bool isReplyMode = ViewBag.IsReplyMode == true;
    string replySubject = (ViewBag.ReplyToSubject as string) ?? string.Empty;
    string replyReceiverId = (ViewBag.ReplyToReceiverId as string) ?? string.Empty;
}

<link rel="stylesheet" href="/css/letter.css">
<script src="https://lib.arvancloud.ir/ckeditor5/36.0.1/ckeditor.js"></script>

<div class="word-processor-container">
    <div class="top-toolbar">
        <div class="toolbar-row">
            <div class="left-tools">
                <div class="input-group receiver-box">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <select id="receiverSelect" class="form-select" asp-items="ViewBag.ReceiverId">
                        <option value="">انتخاب گیرنده یا واحد...</option>
                    </select>
                </div>
                <input type="text" id="subjectInput" class="form-control subject-input" value="@replySubject" placeholder="موضوع نامه...">
            </div>
            <div class="d-flex align-items-center gap-2">
                <span id="draftStatus" class="draft-status">پیش‌نویس ذخیره نشده</span>
                <button class="btn btn-outline-secondary fw-bold" id="btnPreviewLetter" type="button">
                    <i class="bi bi-eye"></i> پیش‌نمایش
                </button>
                <button class="btn btn-primary fw-bold send-btn" id="btnSendLetter" type="button">
                    <i class="bi bi-send"></i> ارسال نهایی
                </button>
            </div>
        </div>

        <div class="reply-mode-title @(isReplyMode ? "" : "d-none")">
            <i class="bi bi-reply-fill"></i> حالت پاسخ نامه
        </div>

        <div class="ai-letter-panel">
            <div class="ai-letter-title">
                <i class="bi bi-stars"></i>
                <span>نگارش نامه با دستیار هوش مصنوعی</span>
            </div>
            <div class="ai-letter-controls">
                <input id="aiLetterInstruction" type="text" class="form-control" placeholder="مثلاً: یک نامه رسمی برای درخواست تأیید خرید تجهیزات بنویس...">
                <button id="btnDraftWithAi" type="button" class="btn btn-outline-primary">
                    <i class="bi bi-magic"></i>
                    تولید متن
                </button>
            </div>
            <div id="aiLetterStatus" class="ai-letter-status"></div>
        </div>
    </div>

    <div class="paper-wrapper">
        <div id="paper" class="paper">
            <div class="header-row">
                <div class="header-info">
                    <div>تاریخ: @persianDate</div>
                    <div>شماره: RH-@now.Ticks.ToString().Substring(12)</div>
                    <div>پیوست: ندارد</div>
                </div>
                <div class="header-center">
                    <h5 class="fw-bold">بسمه تعالی</h5>
                    <div class="fw-bold mt-2">شرکت فنی مهندسی راینو</div>
                </div>
                <img src="/images/logo.png" class="letter-logo" alt="لوگو" onerror="this.style.display='none'">
            </div>

            <div class="letter-summary-grid">
                <div class="summary-chip">
                    <span class="summary-label">گیرنده</span>
                    <strong id="previewReceiver">انتخاب نشده</strong>
                </div>
                <div class="summary-chip">
                    <span class="summary-label">موضوع</span>
                    <strong id="previewSubject">-</strong>
                </div>
                <div class="summary-chip">
                    <span class="summary-label">وضعیت</span>
                    <strong id="previewStatus">پیش‌نویس</strong>
                </div>
            </div>

            <div class="receiver-block">
                <div class="fw-bold receiver-line">
                    <span id="gender-prefix">جناب آقای / سرکار خانم</span>
                    <span id="display-receiver" class="receiver-name">....................</span>
                </div>
                <div class="fw-bold">
                    موضوع: <span id="display-subject" class="subject-display">....................</span>
                </div>
            </div>

            <div id="editor-container">
                <div id="editor">
                    <p>با سلام و احترام،</p>
                    <p>به استحضار می‌رساند...</p>
                </div>
            </div>

            <div class="signature-wrapper">
                <div class="signature-box">
                    <p class="fw-bold mb-1">با تقدیم احترام</p>
                    <p class="fw-bold">@ViewBag.SenderFullName</p>
                    <p class="small text-muted">@ViewBag.SenderRole</p>
                    @if (ViewBag.UserSignature != null)
                    {
                        <img src="@ViewBag.UserSignature" class="signature-img" alt="امضا">
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div id="letterPreviewModal" class="letter-preview-modal d-none" aria-hidden="true">
    <div class="letter-preview-dialog">
        <div class="letter-preview-head">
            <div>
                <h5>پیش‌نمایش قبل از ارسال</h5>
                <p>این نسخه همان چیزی است که کاربر قبل از ارسال می‌بیند.</p>
            </div>
            <button type="button" id="btnClosePreview" class="btn btn-sm btn-outline-secondary">بستن</button>
        </div>
        <div id="letterPreviewBody" class="letter-preview-body"></div>
    </div>
</div>

<form id="finalForm" asp-action="Create" method="post" class="d-none">
    <input type="hidden" id="hTitle" name="Title">
    <input type="hidden" id="hContent" name="Body">
    <input type="hidden" id="hReceiver" name="ReceiverId">
    <input type="hidden" id="hReplyToLetterId" name="ReplyToLetterId" value="@(ViewBag.ReplyToLetterId)">
    @Html.AntiForgeryToken()
</form>

<script>
    window.usersList = @Html.Raw(ViewBag.UsersData ?? "[]");
    window.letterReplyConfig = {
        isReplyMode: @((isReplyMode).ToString().ToLowerInvariant()),
        replyToLetterId: @Html.Raw((ViewBag.ReplyToLetterId == null ? "null" : ViewBag.ReplyToLetterId.ToString())),
        defaultSubject: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(replySubject ?? string.Empty)),
        defaultReceiverId: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(replyReceiverId ?? string.Empty))
    };
</script>
<script src="/js/letter.js"></script>
<script src="/js/letters-ai.js"></script>

@section Styles {
    <style>
        .draft-status {
            color: #64748b;
            font-size: 0.78rem;
            font-weight: 700;
        }
        .letter-summary-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            margin-bottom: 18px;
        }
        .summary-chip {
            border: 1px solid #dbe4f0;
            border-radius: 14px;
            padding: 12px 14px;
            background: rgba(255,255,255,.72);
        }
        .summary-label {
            display: block;
            color: #64748b;
            font-size: .75rem;
            margin-bottom: 4px;
        }
        .letter-preview-modal {
            position: fixed;
            inset: 0;
            background: rgba(2, 6, 23, .72);
            z-index: 2000;
            padding: 24px;
            overflow: auto;
        }
        .letter-preview-dialog {
            max-width: 1100px;
            margin: 0 auto;
            background: #fff;
            border-radius: 20px;
            padding: 18px;
        }
        .letter-preview-head {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: center;
            margin-bottom: 14px;
        }
        .letter-preview-head p { margin: 0; color: #64748b; }
        .letter-preview-body {
            max-height: calc(100vh - 140px);
            overflow: auto;
            border: 1px solid #e2e8f0;
            border-radius: 18px;
            padding: 16px;
            background: #f8fafc;
        }
        html.theme-dark .summary-chip,
        html[data-theme="dark"] .summary-chip,
        body[data-theme="dark"] .summary-chip { background: rgba(15,23,42,.92); border-color: rgba(148,163,184,.18); color: #edf4ff; }
        html.theme-dark .letter-preview-dialog,
        html[data-theme="dark"] .letter-preview-dialog,
        body[data-theme="dark"] .letter-preview-dialog { background: #0f172a; color: #edf4ff; }
        html.theme-dark .letter-preview-body,
        html[data-theme="dark"] .letter-preview-body,
        body[data-theme="dark"] .letter-preview-body { background: rgba(15,23,42,.9); border-color: rgba(148,163,184,.18); }
        @@media (max-width: 992px) {
            .letter-summary-grid { grid-template-columns: 1fr; }
            .toolbar-row { flex-direction: column; align-items: stretch; gap: 12px; }
            .left-tools { flex-direction: column; }
            .receiver-box, .subject-input { width: 100%; }
        }
    </style>
}
