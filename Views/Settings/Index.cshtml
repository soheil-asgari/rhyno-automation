@model OfficeAutomation.Models.SettingsIndexViewModel
@{
    ViewData["Title"] = "تنظیمات";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Settings.css" asp-append-version="true" />
}

<div class="settings-page" dir="rtl">
    @if (TempData["SettingsSuccess"] is string message)
    {
        <div class="alert alert-success settings-alert" role="alert">
            <i class="bi bi-check2-circle"></i>
            <span>@message</span>
        </div>
    }

    <div asp-validation-summary="ModelOnly" class="alert alert-danger settings-alert"></div>

    <header class="settings-header-card">
        <div>
            <h1 class="settings-title">تنظیمات سامانه</h1>
            <p class="settings-subtitle">مدیریت هویت سامانه، امنیت کاربر و تنظیمات عملیاتی</p>
        </div>
        <span class="settings-badge">Settings Hub</span>
    </header>

    <div class="settings-shell">
        <aside class="settings-side-nav nav nav-pills" id="settings-tab" role="tablist" aria-orientation="vertical">
            <button class="nav-link active" id="general-tab" data-bs-toggle="pill" data-bs-target="#general-pane" type="button" role="tab" aria-controls="general-pane" aria-selected="true">
                <i class="bi bi-sliders"></i>
                <span>تنظیمات عمومی</span>
            </button>
            <button class="nav-link" id="security-tab" data-bs-toggle="pill" data-bs-target="#security-pane" type="button" role="tab" aria-controls="security-pane" aria-selected="false">
                <i class="bi bi-shield-lock"></i>
                <span>پروفایل و امنیت</span>
            </button>
            <button class="nav-link" id="system-tab" data-bs-toggle="pill" data-bs-target="#system-pane" type="button" role="tab" aria-controls="system-pane" aria-selected="false">
                <i class="bi bi-hdd-network"></i>
                <span>اتصال دیتابیس و شبکه</span>
            </button>
            <button class="nav-link" id="ui-tab" data-bs-toggle="pill" data-bs-target="#ui-pane" type="button" role="tab" aria-controls="ui-pane" aria-selected="false">
                <i class="bi bi-palette2"></i>
                <span>تنظیمات ظاهری</span>
            </button>
            @if (Model.CanManageSecurity)
            {
                <button class="nav-link" id="signature-admin-tab" data-bs-toggle="pill" data-bs-target="#signature-admin-pane" type="button" role="tab" aria-controls="signature-admin-pane" aria-selected="false">
                    <i class="bi bi-pen"></i>
                    <span>مدیریت امضای کاربر</span>
                </button>
                <button class="nav-link" id="add-user-admin-tab" data-bs-toggle="pill" data-bs-target="#add-user-admin-pane" type="button" role="tab" aria-controls="add-user-admin-pane" aria-selected="false">
                    <i class="bi bi-person-plus"></i>
                    <span>افزودن کاربر</span>
                </button>
            }
        </aside>

        <section class="settings-content tab-content">
            <div class="tab-pane fade show active" id="general-pane" role="tabpanel" aria-labelledby="general-tab" tabindex="0">
                @await Html.PartialAsync("_GeneralSettings", Model)
            </div>
            <div class="tab-pane fade" id="security-pane" role="tabpanel" aria-labelledby="security-tab" tabindex="0">
                @await Html.PartialAsync("_ProfileSecuritySettings", Model)
            </div>
            <div class="tab-pane fade" id="system-pane" role="tabpanel" aria-labelledby="system-tab" tabindex="0">
                @await Html.PartialAsync("_SystemConnectivitySettings", Model)
            </div>
            <div class="tab-pane fade" id="ui-pane" role="tabpanel" aria-labelledby="ui-tab" tabindex="0">
                @await Html.PartialAsync("_UiPreferencesSettings", Model)
            </div>
            @if (Model.CanManageSecurity)
            {
                <div class="tab-pane fade" id="signature-admin-pane" role="tabpanel" aria-labelledby="signature-admin-tab" tabindex="0">
                    <div class="settings-panel">
                        <div class="section-head">
                            <h2>مدیریت امضای کاربر</h2>
                            <p>بارگذاری یا رسم امضای دیجیتال برای استفاده در اسناد سامانه</p>
                        </div>

                        <div class="signature-admin-grid">
                            <div class="signature-draw-card">
                                <div class="signature-canvas-wrap">
                                    <canvas id="signature-canvas" class="signature-canvas" aria-label="Signature Canvas"></canvas>
                                </div>
                                <div class="signature-actions">
                                    <button type="button" class="btn settings-btn-primary" id="signature-save-btn">
                                        <i class="bi bi-check2-circle"></i>
                                        <span>ذخیره امضا</span>
                                    </button>
                                    <button type="button" class="btn settings-btn-danger" id="signature-clear-btn">
                                        <i class="bi bi-eraser"></i>
                                        <span>پاک‌سازی</span>
                                    </button>
                                    <label class="btn btn-outline-primary signature-upload-btn mb-0">
                                        <i class="bi bi-upload"></i>
                                        <span>آپلود فایل</span>
                                        <input type="file" id="signature-upload-input" accept="image/*" hidden />
                                    </label>
                                </div>
                            </div>

                            <div class="signature-preview-card">
                                <h3 class="signature-preview-title">پیش‌نمایش امضای فعلی</h3>
                                @if (!string.IsNullOrWhiteSpace(Model.CurrentUserSignaturePath))
                                {
                                    <img src="@Model.CurrentUserSignaturePath" alt="Current Signature" class="signature-preview-image" id="signature-current-preview" />
                                }
                                else
                                {
                                    <div class="signature-preview-empty" id="signature-current-preview-empty">
                                        <i class="bi bi-pen"></i>
                                        <span>هنوز امضایی ثبت نشده است.</span>
                                    </div>
                                }
                                <div class="role-hint mb-0">
                                    <i class="bi bi-shield-check"></i>
                                    <span>این ابزار مخصوص مدیر سیستم است.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="add-user-admin-pane" role="tabpanel" aria-labelledby="add-user-admin-tab" tabindex="0">
                    <div class="settings-panel">
                        <div class="section-head">
                            <h2>افزودن کاربر جدید</h2>
                            <p>ایجاد حساب کاربری جدید با دسترسی مدیریتی یا کاربری</p>
                        </div>
                        <div class="role-hint mb-3">
                            <i class="bi bi-shield-check"></i>
                            <span>برای ثبت کاربر جدید از فرم مدیریتی کاربران استفاده کنید.</span>
                        </div>
                        <div class="actions-row justify-content-start">
                            <a asp-controller="Settings" asp-action="AddNewUser" class="btn settings-btn-primary">
                                <i class="bi bi-person-plus-fill"></i>
                                <span>انتقال به فرم افزودن کاربر</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
    <script src="~/js/settings-hub.js" asp-append-version="true"></script>
}
