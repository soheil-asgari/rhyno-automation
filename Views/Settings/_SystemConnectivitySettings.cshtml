@model OfficeAutomation.Models.SettingsIndexViewModel

<div class="settings-panel">
    <div class="section-head">
        <h2>اتصال دیتابیس و شبکه</h2>
        <p>نمایش وضعیت زیرساخت و کنترل حالت نگهداری سامانه</p>
    </div>

    <div class="status-cards-grid">
        <div class="status-card">
            <div class="status-card-title">وضعیت دیتابیس</div>
            <div class="status-pill @(Model.System.IsDatabaseConnected ? "ok" : "fail")">
                <i class="bi @(Model.System.IsDatabaseConnected ? "bi-check-circle" : "bi-x-circle")"></i>
                <span>@(Model.System.IsDatabaseConnected ? "متصل" : "قطع")</span>
            </div>
        </div>

        <div class="status-card">
            <div class="status-card-title">محیط فعال</div>
            <div class="status-pill neutral">
                <i class="bi bi-layers"></i>
                <span>@Model.System.ActiveEnvironment</span>
            </div>
        </div>

        <div class="status-card">
            <div class="status-card-title">آخرین بروزرسانی</div>
            <div class="status-pill neutral">
                <i class="bi bi-clock-history"></i>
                <span>@(Model.System.LastUpdatedUtc?.ToLocalTime().ToString("yyyy/MM/dd HH:mm") ?? "-" )</span>
            </div>
        </div>
    </div>

    <form asp-action="UpdateSystem" asp-controller="Settings" method="post" class="settings-form">
        @Html.AntiForgeryToken()

        <div class="switch-card">
            <div>
                <h3 class="switch-title">حالت نگهداری سامانه</h3>
                <p class="switch-text">در زمان نگهداری، امکان کنترل دسترسی کاربران محدود می‌شود.</p>
            </div>
            <div class="form-check form-switch form-switch-lg">
                <input asp-for="System.MaintenanceMode" class="form-check-input" type="checkbox" role="switch" />
                <label asp-for="System.MaintenanceMode" class="form-check-label"></label>
            </div>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="actions-row">
                <button type="submit" class="btn settings-btn-primary">
                    <i class="bi bi-hdd-network"></i>
                    <span>ثبت تنظیمات اتصال</span>
                </button>
            </div>
        }
        else
        {
            <div class="role-hint">
                <i class="bi bi-info-circle"></i>
                <span>مدیریت اتصال و نگهداری فقط در دسترس مدیر است.</span>
            </div>
        }
    </form>
</div>
