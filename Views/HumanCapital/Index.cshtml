@model HumanCapitalIndexVM
@{
    ViewData["Title"] = "مدیریت سرمایه انسانی";
    ViewData["SectionTitle"] = "مدیریت سرمایه انسانی";
    ViewData["SectionSubtitle"] = "ثبت، جستجو، وضعیت‌های شغلی و تاریخچه حقوق در یک نمای عملیاتی";
    ViewData["SectionActionUrl"] = Url.Action("Create", "HumanCapital");
    ViewData["SectionActionText"] = "استخدام جدید";
}

@section Styles {
    <link rel="stylesheet" href="~/css/human-capital.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/human-capital-index.css" asp-append-version="true" />
}

<div class="page-shell hc-page">
    <partial name="_SectionHeader" />

    <div class="hc-stats-grid">
        <a asp-action="Index" asp-route-workflowView="all" asp-route-searchTerm="@Model.SearchTerm" asp-route-status="@Model.Status" asp-route-departmentId="@Model.DepartmentId" class="hc-stat-link">
            <div class="hc-stat-card @(string.IsNullOrWhiteSpace(Model.WorkflowView) || Model.WorkflowView == "all" ? "active" : "")">
                <span class="hc-stat-label">کل پرسنل</span>
                <span class="hc-stat-value">@Model.TotalCount</span>
            </div>
        </a>
        <a asp-action="Index" asp-route-workflowView="active" asp-route-searchTerm="@Model.SearchTerm" asp-route-status="@Model.Status" asp-route-departmentId="@Model.DepartmentId" class="hc-stat-link">
            <div class="hc-stat-card @(Model.WorkflowView == "active" ? "active" : "")">
                <span class="hc-stat-label">پرسنل فعال</span>
                <span class="hc-stat-value text-success">@Model.ActiveCount</span>
            </div>
        </a>
        <a asp-action="Index" asp-route-workflowView="separated" asp-route-searchTerm="@Model.SearchTerm" asp-route-status="@Model.Status" asp-route-departmentId="@Model.DepartmentId" class="hc-stat-link">
            <div class="hc-stat-card @(Model.WorkflowView == "separated" ? "active" : "")">
                <span class="hc-stat-label">خارج‌شده</span>
                <span class="hc-stat-value text-danger">@Model.SeparatedCount</span>
            </div>
        </a>
        <a asp-action="Index" asp-route-workflowView="@Model.WorkflowView" asp-route-searchTerm="@Model.SearchTerm" asp-route-status="@Model.Status" asp-route-departmentId="@Model.DepartmentId" class="hc-stat-link">
            <div class="hc-stat-card">
                <span class="hc-stat-label">نتیجه فیلتر</span>
                <span class="hc-stat-value text-primary">@Model.FilteredCount</span>
            </div>
        </a>
    </div>

    @{ ViewData["SavedFiltersTitle"] = "فیلترهای ذخیره‌شده"; ViewData["SavedFiltersSubtitle"] = "فیلترهای اخیر و ذخیره‌شده برای دسترسی سریع‌تر"; ViewData["SavedFiltersSaveButtonId"] = "hc-save-filter"; ViewData["SavedFiltersClearButtonId"] = "hc-clear-filters"; ViewData["SavedFiltersContainerId"] = "hc-saved-filters"; }

    <div class="hc-content-grid">
        <div class="hc-stack">
            <div class="form-card">
                <div class="hc-card-head">
                    <div>
                        <h2 class="hc-card-title">فیلتر و جستجو</h2>
                        <p class="hc-card-subtitle">لیست پرسنل را بر اساس نام، وضعیت و دپارتمان محدود کنید.</p>
                    </div>
                </div>
                <partial name="_SavedFiltersPanel" />
                <form method="get" asp-action="Index" class="row g-2 g-md-3 align-items-end" id="hc-filter-form">
                    <input type="hidden" asp-for="WorkflowView" />
                    <div class="col-12 col-md-4">
                        <label asp-for="SearchTerm" class="form-label"></label>
                        <input asp-for="SearchTerm" class="form-control" placeholder="نام، کد پرسنلی، کد ملی یا عنوان شغلی" />
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="">همه وضعیت‌ها</option>
                            @foreach (var status in Model.StatusOptions)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="DepartmentId" class="form-label"></label>
                        <select asp-for="DepartmentId" class="form-select" asp-items="Model.DepartmentOptions">
                            <option value="">همه دپارتمان‌ها</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-2 d-grid">
                        <button type="submit" class="btn btn-primary">اعمال فیلتر</button>
                    </div>
                </form>
            </div>

            <div class="form-card hc-list-card">
                <div class="hc-list-toolbar">
                    <div>
                        <h2 class="hc-card-title">لیست کارمندان</h2>
                        <p class="hc-card-subtitle">نمای عملیاتی پرسنل با دسترسی سریع به جزئیات و ویرایش.</p>
                    </div>
                    <div class="hc-list-count">@Model.FilteredCount رکورد نمایش داده می‌شود</div>
                </div>

                <div class="table-responsive">
                    <table class="table smart-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>پرسنل</th>
                                <th>سمت / دپارتمان</th>
                                <th>استخدام</th>
                                <th>حقوق فعلی</th>
                                <th>وضعیت</th>
                                <th>سوابق</th>
                                <th class="text-center">عملیات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Items.Any())
                            {
                                foreach (var employee in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@employee.FullName</div>
                                            <div class="small text-muted">کد پرسنلی: @employee.PersonnelCode</div>
                                        </td>
                                        <td>
                                            <div>@employee.PositionTitle</div>
                                            <div class="small text-muted">@(employee.DepartmentName ?? "-")</div>
                                        </td>
                                        <td>@employee.HireDate.ToString("yyyy/MM/dd")</td>
                                        <td>@employee.CurrentSalary.ToString("N0")</td>
                                        <td>
                                            <span class="badge @(employee.CurrentStatus == "فعال" ? "text-bg-success" : "text-bg-secondary")">@employee.CurrentStatus</span>
                                        </td>
                                        <td>
                                            <div class="small text-muted">افزایش حقوق: @employee.SalaryChangeCount</div>
                                            <div class="small text-muted">آخرین رخداد: @(employee.LatestStatusDate?.ToString("yyyy/MM/dd") ?? "-")</div>
                                        </td>
                                        <td class="text-center">
                                            <div class="action-bar justify-content-center">
                                                <a asp-action="Details" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-primary hc-track-visit" data-id="@employee.Id" data-name="@employee.FullName" data-url="@Url.Action("Details", "HumanCapital", new { id = employee.Id })">جزئیات</a>
                                                <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-sm btn-outline-secondary">ویرایش</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7">
                                        <div class="empty-state">
                                            <i class="bi bi-people"></i>
                                            <div>موردی برای نمایش وجود ندارد.</div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="hc-stack">
            <div class="form-card">
                <div class="hc-card-head">
                    <div>
                        <h2 class="hc-card-title">آخرین بازدیدها</h2>
                        <p class="hc-card-subtitle">افرادی که اخیراً باز کرده‌اید اینجا ذخیره می‌شوند.</p>
                    </div>
                </div>
                <div id="hc-recent-items" class="recent-items-list"></div>
            </div>
        </div>
    </div>
</div>

<script>
    (() => {
        const storageKey = "rhyno.humanCapital.filters";
        const recentKey = "rhyno.humanCapital.recent";
        const preferenceEndpoint = "/table-preferences/human-capital.filters";
        const form = document.getElementById("hc-filter-form");
        const savedContainer = document.getElementById("hc-saved-filters");
        const recentContainer = document.getElementById("hc-recent-items");
        const saveButton = document.getElementById("hc-save-filter");
        const clearButton = document.getElementById("hc-clear-filters");

        const readJson = (key, fallback) => {
            try {
                return JSON.parse(localStorage.getItem(key) || "null") || fallback;
            } catch {
                return fallback;
            }
        };

        const writeJson = (key, value) => localStorage.setItem(key, JSON.stringify(value));

        const loadSavedFilters = async () => {
            try {
                const response = await fetch(preferenceEndpoint, { credentials: "same-origin" });
                if (!response.ok) {
                    return readJson(storageKey, []);
                }

                const items = await response.json();
                const normalized = Array.isArray(items) ? items : [];
                if (normalized.length) {
                    writeJson(storageKey, normalized);
                }

                return normalized.length ? normalized : readJson(storageKey, []);
            } catch {
                return readJson(storageKey, []);
            }
        };

        const saveFilters = async (items) => {
            writeJson(storageKey, items);
            try {
                await fetch(preferenceEndpoint, {
                    method: "POST",
                    credentials: "same-origin",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(items)
                });
            } catch {
            }
        };

        const currentFilter = () => ({
            searchTerm: form.querySelector('[name="SearchTerm"]')?.value?.trim() || "",
            status: form.querySelector('[name="Status"]')?.value || "",
            departmentId: form.querySelector('[name="DepartmentId"]')?.value || "",
            workflowView: form.querySelector('[name="WorkflowView"]')?.value || "all"
        });

        const filterLabel = (item) => {
            const parts = [];
            if (item.searchTerm) parts.push(`جستجو: ${item.searchTerm}`);
            if (item.status) parts.push(`وضعیت: ${item.status}`);
            if (item.departmentId) parts.push(`دپارتمان: ${item.departmentId}`);
            if (item.workflowView && item.workflowView !== "all") parts.push(`نما: ${item.workflowView}`);
            return parts.length ? parts.join(" | ") : "فیلتر بدون شرط";
        };

        const renderSaved = () => {
            const items = readJson(storageKey, []);
            savedContainer.innerHTML = "";
            if (!items.length) {
                savedContainer.innerHTML = '<span class="text-muted small">هنوز فیلتری ذخیره نشده است.</span>';
                return;
            }

            items.slice(0, 6).forEach((item, index) => {
                const chip = document.createElement("button");
                chip.type = "button";
                chip.className = "btn btn-sm btn-outline-secondary rounded-pill";
                chip.textContent = item.name;
                chip.title = filterLabel(item);
                chip.addEventListener("click", () => {
                    form.querySelector('[name="SearchTerm"]').value = item.searchTerm || "";
                    form.querySelector('[name="Status"]').value = item.status || "";
                    form.querySelector('[name="DepartmentId"]').value = item.departmentId || "";
                    form.querySelector('[name="WorkflowView"]').value = item.workflowView || "all";
                    form.submit();
                });
                chip.dataset.index = index;
                savedContainer.appendChild(chip);
            });
        };

        const renderRecent = () => {
            const items = readJson(recentKey, []);
            recentContainer.innerHTML = "";
            if (!items.length) {
                recentContainer.innerHTML = '<div class="text-muted small">هنوز موردی باز نشده است.</div>';
                return;
            }

            items.slice(0, 6).forEach(item => {
                const row = document.createElement("div");
                row.className = "recent-item";
                row.innerHTML = `
                    <div>
                        <div class="fw-semibold">${item.name}</div>
                        <div class="small text-muted">${item.when}</div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="${item.url}">باز کردن</a>
                `;
                recentContainer.appendChild(row);
            });
        };

        saveButton?.addEventListener("click", () => {
            const next = currentFilter();
            const name = prompt("نام این فیلتر را وارد کنید:", "فیلتر ذخیره‌شده");
            if (!name) return;
            const items = readJson(storageKey, []);
            items.unshift({ name, ...next });
            saveFilters(items.slice(0, 8)).finally(renderSaved);
        });

        clearButton?.addEventListener("click", () => {
            form.querySelector('[name="SearchTerm"]').value = "";
            form.querySelector('[name="Status"]').value = "";
            form.querySelector('[name="DepartmentId"]').value = "";
            form.querySelector('[name="WorkflowView"]').value = "all";
            form.submit();
        });

        document.querySelectorAll(".hc-track-visit").forEach(link => {
            link.addEventListener("click", () => {
                const items = readJson(recentKey, []).filter(x => x.id !== link.dataset.id);
                items.unshift({
                    id: link.dataset.id,
                    name: link.dataset.name,
                    url: link.dataset.url,
                    when: new Date().toLocaleString("fa-IR")
                });
                writeJson(recentKey, items.slice(0, 8));
            });
        });

        loadSavedFilters().finally(renderSaved);
        renderRecent();
    })();
</script>
