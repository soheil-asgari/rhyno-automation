@{
    ViewData["Title"] = "سرمایه انسانی";
}

<div class="container-fluid py-3">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h4 mb-0">سرمایه انسانی</h1>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h6">خلاصه</h2>
                    <p class="text-muted mb-0">
                        این صفحه نقطه شروع ماژول منابع انسانی است (پرسنل، احکام، قراردادها، مرخصی، حضور و غیاب و ...).
                    </p>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h6">میانبرها</h2>
                    <ul class="mb-0">
                        <li>لیست پرسنل</li>
                        <li>درخواست‌های مرخصی</li>
                        <li>گزارش حضور و غیاب</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>