@model IEnumerable<InsuranceList>
@{
    ViewData["Title"] = "لیست بیمه";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Bimeh.css" asp-append-version="true" />
}

<div class="container-fluid py-4" style="direction: rtl; text-align: right; max-width: 1200px;">


    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold mb-1 text-dark">مدیریت لیست بیمه</h5>
            <p class="text-muted small mb-0">لیست و وضعیت درخواست‌های ثبت شده در سیستم</p>
        </div>
        <a class="btn btn-primary px-4 shadow-sm" style="border-radius: 10px; background-color: var(--primary-main);" asp-action="Create">
            <i class="bi bi-plus-lg ms-1"></i> لیست جدید
        </a>
        
    </div>
</div>
    <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>پروژه</th>
                    <th>مدیر</th>
                    <th>ماه</th>
                    <th>تعداد پرسنل</th>
                    <th>وضعیت</th>
                </tr>
            </thead>
            <tbody>

                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProjectName</td>
                        <td>@item.ManagerName</td>
                        <td>@item.Month / @item.Year</td>
                        <td>@item.EmployeeCount</td>
                        <td>@item.Status</td>
                    </tr>
                }

            </table>
        </div>
    </div>
           