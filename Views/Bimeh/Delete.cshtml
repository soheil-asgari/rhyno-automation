@model InsuranceList
@{
    ViewData["Title"] = "حذف لیست بیمه";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Bimeh.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bimeh-page">
    <div class="card border-0 shadow-sm bimeh-card">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex align-items-start gap-3 mb-4">
                <div class="bimeh-danger-icon">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div>
                    <h5 class="fw-bold text-danger mb-1">حذف لیست بیمه</h5>
                    <p class="text-muted small mb-0">
                        آیا از حذف این لیست و تمام کارکنان مرتبط با آن اطمینان دارید؟
                    </p>
                </div>
            </div>

            <div class="row g-3 bimeh-delete-summary mb-4">
                <div class="col-12 col-md-6 col-lg-3">
                    <small class="text-muted d-block">پروژه</small>
                    <span class="fw-semibold">@Model.ProjectName</span>
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <small class="text-muted d-block">مدیر پروژه</small>
                    <span class="fw-semibold">@Model.ManagerName</span>
                </div>
                <div class="col-6 col-lg-2">
                    <small class="text-muted d-block">ماه / سال</small>
                    <span class="fw-semibold">@Model.Month / @Model.Year</span>
                </div>
                <div class="col-6 col-lg-2">
                    <small class="text-muted d-block">وضعیت</small>
                    <span class="badge bimeh-status-badge">@Model.Status</span>
                </div>
                <div class="col-6 col-lg-2">
                    <small class="text-muted d-block">تعداد کارکنان</small>
                    <span class="badge bimeh-count-badge">@Model.EmployeeCount نفر</span>
                </div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">انصراف</a>
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash3 ms-1"></i>
                        تایید حذف
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
