@using System.Globalization
@model InsuranceList
@{
    ViewData["Title"] = "جزئیات لیست بیمه";
    string ToSolar(DateTime date)
    {
        var pc = new PersianCalendar();
        return $"{pc.GetYear(date):0000}/{pc.GetMonth(date):00}/{pc.GetDayOfMonth(date):00}";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/Bimeh.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bimeh-page">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h5 class="fw-bold mb-1 text-dark">جزئیات لیست بیمه</h5>
            <p class="text-muted small mb-0">نمای کلی اطلاعات لیست و کارکنان ثبت‌شده</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">ویرایش</a>
            <a asp-action="Index" class="btn btn-outline-primary">بازگشت</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm bimeh-card mb-3">
        <div class="card-body p-3 p-md-4">
            <div class="row g-3">
                <div class="col-12 col-md-6 col-lg-3">
                    <small class="text-muted d-block">پروژه</small>
                    <span class="fw-semibold">@Model.ProjectName</span>
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <small class="text-muted d-block">مدیر پروژه</small>
                    <span class="fw-semibold">@Model.ManagerName</span>
                </div>
                <div class="col-6 col-lg-2">
                    <small class="text-muted d-block">ماه / سال</small>
                    <span class="fw-semibold">@Model.Month / @Model.Year</span>
                </div>
                <div class="col-6 col-lg-2">
                    <small class="text-muted d-block">وضعیت</small>
                    <span class="badge bimeh-status-badge">@Model.Status</span>
                </div>
                <div class="col-6 col-lg-2">
                    <small class="text-muted d-block">تعداد پرسنل</small>
                    <span class="badge bimeh-count-badge">@Model.EmployeeCount نفر</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm bimeh-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 bimeh-table">
                <thead>
                    <tr>
                        <th>نام</th>
                        <th>شغل</th>
                        <th>شروع کار</th>
                        <th>ترک کار</th>
                        <th>روز کارکرد</th>
                        <th>حقوق</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Employees.Any())
                    {
                        @foreach (var employee in Model.Employees)
                        {
                            <tr>
                                <td class="fw-semibold">@employee.FullName</td>
                                <td>@employee.JobTitle</td>
                                <td>@ToSolar(employee.StartWork)</td>
                                <td>@(employee.EndWork.HasValue ? ToSolar(employee.EndWork.Value) : "-")</td>
                                <td>@employee.WorkDays</td>
                                <td>@employee.Salary.ToString("N0")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">برای این لیست، پرسنلی ثبت نشده است.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
