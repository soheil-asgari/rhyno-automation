@model InsuranceEditVM
@{
    ViewData["Title"] = "ویرایش لیست بیمه";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Bimeh.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bimeh-page">
    <div class="card border-0 shadow-sm bimeh-card">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                <div>
                    <h5 class="fw-bold mb-1 text-dark">ویرایش لیست بیمه</h5>
                    <p class="text-muted small mb-0">اطلاعات لیست و کارکنان را به‌روزرسانی کنید.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">بازگشت</a>
            </div>

            <form asp-action="Edit" method="post" id="bimehEditForm">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row g-3 mb-4">
                    <div class="col-md-6 col-lg-3">
                        <label asp-for="ProjectName" class="form-label">پروژه</label>
                        <input asp-for="ProjectName" class="form-control" maxlength="150" />
                        <span asp-validation-for="ProjectName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <label asp-for="ManagerName" class="form-label">مدیر پروژه</label>
                        <input asp-for="ManagerName" class="form-control" maxlength="100" />
                        <span asp-validation-for="ManagerName" class="text-danger small"></span>
                    </div>

                    <div class="col-6 col-lg-2">
                        <label asp-for="Month" class="form-label">ماه</label>
                        <input asp-for="Month" class="form-control" type="number" min="1" max="12" />
                        <span asp-validation-for="Month" class="text-danger small"></span>
                    </div>

                    <div class="col-6 col-lg-2">
                        <label asp-for="Year" class="form-label">سال</label>
                        <input asp-for="Year" class="form-control" type="number" min="1300" max="1600" />
                        <span asp-validation-for="Year" class="text-danger small"></span>
                    </div>

                    <div class="col-12 col-lg-2">
                        <label asp-for="Status" class="form-label">وضعیت</label>
                        <select asp-for="Status" class="form-select">
                            @foreach (var status in Model.AvailableStatuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <h6 class="mb-0 fw-bold">کارکنان</h6>
                    <button type="button" id="addRow" class="btn btn-secondary btn-sm">
                        <i class="bi bi-plus-lg ms-1"></i>
                        افزودن کارمند
                    </button>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle bimeh-table" id="employeeTable">
                        <thead>
                            <tr>
                                <th>نام</th>
                                <th>شغل</th>
                                <th>شروع کار</th>
                                <th>ترک کار</th>
                                <th>روز کارکرد</th>
                                <th>حقوق</th>
                                <th class="text-center">حذف</th>
                            </tr>
                        </thead>
                        <tbody id="employeeRows">
                            @if (Model.Employees.Any())
                            {
                                @for (var index = 0; index < Model.Employees.Count; index++)
                                {
                                    <tr>
                                        <td><input asp-for="Employees[index].FullName" class="form-control" maxlength="100" required data-field="FullName" /></td>
                                        <td><input asp-for="Employees[index].JobTitle" class="form-control" maxlength="100" required data-field="JobTitle" /></td>
                                        <td><input asp-for="Employees[index].StartWork" type="date" class="form-control" required data-field="StartWork" /></td>
                                        <td><input asp-for="Employees[index].EndWork" type="date" class="form-control" data-field="EndWork" /></td>
                                        <td><input asp-for="Employees[index].WorkDays" type="number" class="form-control" min="0" max="31" required data-field="WorkDays" /></td>
                                        <td><input asp-for="Employees[index].Salary" type="number" class="form-control" min="0" step="0.01" required data-field="Salary" /></td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-outline-danger btn-sm removeRow">حذف</button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
                    <small id="employeeCountLabel" class="text-muted">تعداد کارکنان: 0</small>
                    <button class="btn btn-success px-4">ذخیره تغییرات</button>
                </div>
            </form>
        </div>
    </div>
</div>

<template id="employeeRowTemplate">
    <tr>
        <td><input data-field="FullName" class="form-control" maxlength="100" required /></td>
        <td><input data-field="JobTitle" class="form-control" maxlength="100" required /></td>
        <td><input type="date" data-field="StartWork" class="form-control" required /></td>
        <td><input type="date" data-field="EndWork" class="form-control" /></td>
        <td><input type="number" data-field="WorkDays" class="form-control" min="0" max="31" required /></td>
        <td><input type="number" data-field="Salary" class="form-control" min="0" step="0.01" required /></td>
        <td class="text-center">
            <button type="button" class="btn btn-outline-danger btn-sm removeRow">حذف</button>
        </td>
    </tr>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const rowsContainer = document.getElementById('employeeRows');
            const rowTemplate = document.getElementById('employeeRowTemplate');
            const addRowButton = document.getElementById('addRow');
            const employeeCountLabel = document.getElementById('employeeCountLabel');

            const updateRowIndexes = () => {
                const rows = rowsContainer.querySelectorAll('tr');
                rows.forEach((row, index) => {
                    row.querySelectorAll('[data-field]').forEach((input) => {
                        const fieldName = input.dataset.field;
                        input.name = `Employees[${index}].${fieldName}`;
                    });
                });
                employeeCountLabel.textContent = `تعداد کارکنان: ${rows.length}`;
            };

            const addRow = () => {
                const clone = rowTemplate.content.firstElementChild.cloneNode(true);
                rowsContainer.appendChild(clone);
                updateRowIndexes();
            };

            addRowButton.addEventListener('click', addRow);

            rowsContainer.addEventListener('click', (event) => {
                const removeButton = event.target.closest('.removeRow');
                if (!removeButton) return;

                const row = removeButton.closest('tr');
                row?.remove();

                if (rowsContainer.children.length === 0) {
                    addRow();
                } else {
                    updateRowIndexes();
                }
            });

            if (rowsContainer.children.length === 0) {
                addRow();
            } else {
                updateRowIndexes();
            }
        })();
    </script>
}
