@model OfficeAutomation.Models.UserViewModel

<div class="row justify-content-center users-create">
    <div class="col-md-6">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0">تعریف همکار جدید</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small"></div>

                    <div class="mb-3">
                        <label class="form-label">نام و نام خانوادگی</label>
                        <input asp-for="FullName" class="form-control" required readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">نام کاربری (کد پرسنلی یا نام)</label>
                        <input asp-for="Email" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">اتصال به کارمند</label>
                        <select asp-for="EmployeeId" class="form-select" required>
                            <option value="">انتخاب کارمند</option>
                            @foreach (var employee in (IEnumerable<dynamic>)(ViewBag.EmployeeOptions ?? new List<dynamic>()))
                            {
                                <option value="@employee.Id">@employee.FullName (@employee.PersonnelCode)</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">مدیر مستقیم</label>
                        <select asp-for="ParentManagerUserId" class="form-select">
                            <option value="">بدون مدیر</option>
                            @foreach (var manager in (IEnumerable<dynamic>)(ViewBag.ManagerOptions ?? new List<dynamic>()))
                            {
                                <option value="@manager.Id">@manager.FullName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">نقش</label>
                        <select asp-for="Role" class="form-select" required>
                            <option value="">انتخاب نقش</option>
                            @foreach (var role in (IEnumerable<string>)(ViewBag.RoleOptions ?? new List<string>()))
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">رمز عبور پیش‌فرض</label>
                        <input asp-for="Password" type="password" class="form-control" required />
                        <small class="text-muted">حداقل ۶ کاراکتر، شامل عدد و حروف بزرگ</small>
                    </div>

                    <div class="mb-3">
                        <small class="text-muted">دسترسی‌ها به‌صورت پویا از ماتریس نقش تعیین می‌شود.</small>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">ذخیره و ایجاد اکانت</button>
                        <a asp-action="Index" class="btn btn-light">انصراف</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .users-create .dropdown-menu {
            z-index: 10001 !important;
        }
    </style>
}

@section Scripts {
    <script>
        (() => {
            const employeeSelect = document.getElementById('EmployeeId');
            const fullNameInput = document.getElementById('FullName');
            if (!employeeSelect || !fullNameInput) return;

            employeeSelect.addEventListener('change', () => {
                const selectedOption = employeeSelect.options[employeeSelect.selectedIndex];
                if (!selectedOption || !selectedOption.value) {
                    fullNameInput.value = '';
                    return;
                }
                const optionText = selectedOption.textContent || '';
                const namePart = optionText.split('(')[0]?.trim() || '';
                fullNameInput.value = namePart;
            });
        })();
    </script>
}
