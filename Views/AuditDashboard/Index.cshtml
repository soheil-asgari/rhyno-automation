@model OfficeAutomation.Controllers.AuditDashboardViewModel
@{
    ViewData["Title"] = "داشبورد لاگ";
    ViewData["SectionTitle"] = "داشبورد لاگ و رویدادهای حساس";
    ViewData["SectionSubtitle"] = "نمای سریع و قابل‌فیلتر از رخدادهای امنیتی، حذف‌ها و تغییرات حساس";
}

@section Styles {
    <style>
        .audit-dashboard-page .section-header {
            display: flex;
            justify-content: space-between;
            align-items: end;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .audit-dashboard-page .section-subtitle {
            margin: 0.35rem 0 0;
            color: #64748b;
            font-size: 0.95rem;
        }

        .audit-stats-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .audit-stat-card {
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            border: 1px solid #dbe7f3;
            border-radius: 18px;
            padding: 1.1rem 1.2rem;
            box-shadow: 0 12px 30px -22px rgba(15, 23, 42, 0.28);
        }

        .audit-stat-card.is-active {
            background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
            border-color: #1d4ed8;
            color: #fff;
        }

        .audit-stat-label {
            display: block;
            font-size: 0.86rem;
            color: #64748b;
            margin-bottom: 0.45rem;
        }

        .audit-stat-card.is-active .audit-stat-label {
            color: rgba(255, 255, 255, 0.82);
        }

        .audit-stat-value {
            display: block;
            font-size: 2rem;
            line-height: 1;
            font-weight: 800;
            color: #0f172a;
        }

        .audit-stat-card.is-active .audit-stat-value {
            color: #fff;
        }

        .audit-json {
            direction: ltr;
            text-align: left;
            background: #0f172a;
            color: #e2e8f0;
            border-radius: 14px;
            padding: 1rem;
            min-height: 140px;
            overflow: auto;
            font-size: 0.82rem;
        }

        .audit-inline-detail .audit-json {
            min-height: auto;
            max-height: 220px;
            padding: 0.75rem;
            border-radius: 12px;
        }

        @@media (max-width: 992px) {
            .audit-stats-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 576px) {
            .audit-dashboard-page .section-header {
                align-items: start;
            }

            .audit-stats-grid {
                grid-template-columns: 1fr;
            }

            .audit-stat-value {
                font-size: 1.6rem;
            }
        }
    </style>
}

<div class="page-shell audit-dashboard-page">
    <partial name="_SectionHeader" />

    <div class="audit-stats-grid">
        <div class="audit-stat-card is-active">
            <span class="audit-stat-label">کل رویدادها</span>
            <span class="audit-stat-value">@Model.TotalEvents</span>
        </div>
        <div class="audit-stat-card">
            <span class="audit-stat-label">رویدادهای هفته</span>
            <span class="audit-stat-value text-primary">@Model.WeekEvents</span>
        </div>
        <div class="audit-stat-card">
            <span class="audit-stat-label">رویداد حساس امروز</span>
            <span class="audit-stat-value text-warning">@Model.SensitiveEventsToday</span>
        </div>
        <div class="audit-stat-card">
            <span class="audit-stat-label">حذف امروز</span>
            <span class="audit-stat-value text-danger">@Model.DeletesToday</span>
        </div>
    </div>

    <div class="form-card mb-3">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-6">
                <label class="form-label">جستجوی متنی</label>
                <input type="search" class="form-control" id="audit-search" placeholder="کاربر، جدول، ستون، ماژول یا عملیات..." />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">ماژول</label>
                <select class="form-select" id="audit-module">
                    <option value="">همه ماژول‌ها</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">عملیات</label>
                <select class="form-select" id="audit-action">
                    <option value="">همه عملیات</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">جدول</label>
                <select class="form-select" id="audit-table">
                    <option value="">همه جدول‌ها</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">کاربر</label>
                <select class="form-select" id="audit-user">
                    <option value="">همه کاربران</option>
                </select>
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">از تاریخ</label>
                <input type="date" class="form-control" id="audit-from" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">تا تاریخ</label>
                <input type="date" class="form-control" id="audit-to" />
            </div>
            <div class="col-12 col-md-3">
                <label class="form-label">فقط حساس</label>
                <select class="form-select" id="audit-sensitive">
                    <option value="">همه</option>
                    <option value="true">بله</option>
                    <option value="false">خیر</option>
                </select>
            </div>
            <div class="col-12 col-md-3 d-grid gap-2">
                <button class="btn btn-primary" id="audit-refresh">اعمال فیلتر</button>
                <a class="btn btn-outline-secondary" id="audit-export" href="/api/admin/audit-logs/export" target="_blank">خروجی CSV</a>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2 mt-3">
            <button type="button" class="btn btn-sm btn-outline-primary" id="audit-expand-all">باز کردن همه</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="audit-collapse-all">بستن همه</button>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="audit-copy-json">کپی JSON ردیف انتخاب‌شده</button>
        </div>
    </div>

    <div class="form-card">
        <div class="table-responsive">
            <table class="table smart-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>زمان</th>
                        <th>کاربر</th>
                        <th>عملیات</th>
                        <th>ماژول</th>
                        <th>جدول</th>
                        <th>حساس</th>
                        <th>جزئیات</th>
                    </tr>
                </thead>
                <tbody id="audit-table-body">
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-hourglass-split"></i>
                                <div>در حال بارگذاری ...</div>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="small text-muted" id="audit-summary"></div>
            <div class="btn-group">
                <button class="btn btn-outline-secondary btn-sm" id="audit-prev">قبلی</button>
                <button class="btn btn-outline-secondary btn-sm" id="audit-next">بعدی</button>
            </div>
        </div>
    </div>

    <div class="form-card mt-3" id="audit-detail-panel" style="display:none;">
        <div class="section-title h5 mb-3">جزئیات ردیف انتخاب‌شده</div>
        <div class="row g-3">
            <div class="col-12 col-md-6">
                <div class="small text-muted mb-1">مقادیر قبلی</div>
                <pre class="mb-0 audit-json" id="audit-old-values"></pre>
            </div>
            <div class="col-12 col-md-6">
                <div class="small text-muted mb-1">مقادیر جدید</div>
                <pre class="mb-0 audit-json" id="audit-new-values"></pre>
            </div>
        </div>
        <div class="small text-muted mt-3" id="audit-detail-meta"></div>
    </div>
</div>

<script>
    (() => {
        const body = document.getElementById("audit-table-body");
        const summary = document.getElementById("audit-summary");
        const detailPanel = document.getElementById("audit-detail-panel");
        const oldValues = document.getElementById("audit-old-values");
        const newValues = document.getElementById("audit-new-values");
        const detailMeta = document.getElementById("audit-detail-meta");
        const moduleSelect = document.getElementById("audit-module");
        const actionSelect = document.getElementById("audit-action");
        const tableSelect = document.getElementById("audit-table");
        const searchInput = document.getElementById("audit-search");
        const userSelect = document.getElementById("audit-user");
        const fromInput = document.getElementById("audit-from");
        const toInput = document.getElementById("audit-to");
        const sensitiveSelect = document.getElementById("audit-sensitive");
        const exportLink = document.getElementById("audit-export");
        const expandAllButton = document.getElementById("audit-expand-all");
        const collapseAllButton = document.getElementById("audit-collapse-all");
        const copyJsonButton = document.getElementById("audit-copy-json");
        const pageSize = 20;
        let page = 1;
        let totalPages = 1;
        let lastRows = [];
        let allRows = [];
        let selectedRowIndex = null;

        const escape = (value) => String(value ?? "")
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll("\"", "&quot;");

        const params = () => {
            const query = new URLSearchParams();
            if (moduleSelect.value) query.set("Module", moduleSelect.value);
            if (actionSelect.value) query.set("Action", actionSelect.value);
            if (tableSelect.value) query.set("TableName", tableSelect.value);
            if (userSelect.value) query.set("UserId", userSelect.value);
            if (fromInput.value) query.set("From", `${fromInput.value}T00:00:00+03:30`);
            if (toInput.value) query.set("To", `${toInput.value}T23:59:59+03:30`);
            if (sensitiveSelect.value) query.set("SensitiveOnly", sensitiveSelect.value);
            query.set("Page", page.toString());
            query.set("PageSize", pageSize.toString());
            return query;
        };

        const applyExportHref = () => {
            const query = new URLSearchParams();
            if (moduleSelect.value) query.set("Module", moduleSelect.value);
            if (actionSelect.value) query.set("Action", actionSelect.value);
            if (tableSelect.value) query.set("TableName", tableSelect.value);
            if (userSelect.value) query.set("UserId", userSelect.value);
            if (fromInput.value) query.set("From", `${fromInput.value}T00:00:00+03:30`);
            if (toInput.value) query.set("To", `${toInput.value}T23:59:59+03:30`);
            if (sensitiveSelect.value) query.set("SensitiveOnly", sensitiveSelect.value);
            exportLink.href = `/api/admin/audit-logs/export?${query.toString()}`;
        };

        const showDetails = (item) => {
            if (!item) return;
            detailPanel.style.display = "block";
            oldValues.textContent = formatJson(item.oldValues);
            newValues.textContent = formatJson(item.newValues);
            detailMeta.textContent = `${item.tableName} | ${item.module} | ${item.userDisplayName || item.userId || "-"} | ${new Date(item.dateTime).toLocaleString("fa-IR")}`;
        };

        const formatJson = (value) => {
            if (!value) return "ندارد";
            try {
                const parsed = JSON.parse(value);
                return JSON.stringify(parsed, null, 2);
            } catch {
                return value;
            }
        };

        const applyClientSearch = () => {
            const term = (searchInput.value || "").trim().toLowerCase();
            if (!term) {
                renderRows(allRows);
                return;
            }

            const filtered = allRows.filter(item => {
                const haystack = [
                    item.userDisplayName,
                    item.userId,
                    item.action,
                    item.tableName,
                    item.module,
                    item.affectedColumns,
                    item.oldValues,
                    item.newValues,
                    item.userIP
                ].filter(Boolean).join(" ").toLowerCase();
                return haystack.includes(term);
            });

            renderRows(filtered);
            summary.textContent = `${filtered.length} رکورد مطابق جستجو`;
        };

        const renderRows = (items) => {
            lastRows = items || [];
            if (!items.length) {
                body.innerHTML = `<tr><td colspan="7"><div class="empty-state"><i class="bi bi-inbox"></i><div>رکوردی پیدا نشد.</div></div></td></tr>`;
                return;
            }

            body.innerHTML = items.map((item, index) => `
                <tr class="audit-row" data-index="${index}">
                    <td>${new Date(item.dateTime).toLocaleString("fa-IR")}</td>
                    <td>${escape(item.userDisplayName || item.userId || "-")}</td>
                    <td><span class="badge text-bg-${item.action === "Delete" ? "danger" : item.action === "Update" ? "warning" : "success"}">${escape(item.action)}</span></td>
                    <td>${escape(item.module)}</td>
                    <td>${escape(item.tableName)}</td>
                    <td>${item.isSensitive ? '<span class="badge text-bg-danger">بله</span>' : '<span class="badge text-bg-secondary">خیر</span>'}</td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-primary audit-toggle mb-2">نمایش جزئیات</button>
                        <div class="small text-muted">${escape(item.affectedColumns || "-")}</div>
                        <div class="small">${item.newValues ? "دارای داده جدید" : "بدون داده جدید"}</div>
                        <div class="audit-inline-detail mt-2" style="display:none;">
                            <div class="small text-muted mb-1">مقادیر قبلی</div>
                            <pre class="mb-2 audit-json">${escape(formatJson(item.oldValues))}</pre>
                            <div class="small text-muted mb-1">مقادیر جدید</div>
                            <pre class="mb-0 audit-json">${escape(formatJson(item.newValues))}</pre>
                        </div>
                    </td>
                </tr>
            `).join("");

            body.querySelectorAll(".audit-row").forEach(row => {
                const detail = row.querySelector(".audit-inline-detail");
                const toggle = row.querySelector(".audit-toggle");
                toggle?.addEventListener("click", (e) => {
                    e.stopPropagation();
                    const open = detail.style.display !== "none";
                    detail.style.display = open ? "none" : "block";
                });
                row.addEventListener("click", () => {
                    selectedRowIndex = Number(row.dataset.index);
                    showDetails(lastRows[selectedRowIndex]);
                });
            });
        };

        const loadOptions = async () => {
            const response = await fetch("/api/admin/audit-logs/filter-options", { credentials: "same-origin" });
            if (!response.ok) return;
            const data = await response.json();
            const fill = (select, values, valueKey = "value", labelKey = "label") => {
                values.forEach(v => {
                    const option = document.createElement("option");
                    option.value = v[valueKey] ?? v;
                    option.textContent = v[labelKey] ?? v;
                    select.appendChild(option);
                });
            };
            fill(moduleSelect, data.modules || []);
            fill(actionSelect, data.actions || []);
            fill(tableSelect, data.tableNames || []);
            fill(userSelect, data.users || []);
        };

        const loadData = async () => {
            body.innerHTML = `<tr><td colspan="7"><div class="empty-state"><i class="bi bi-hourglass-split"></i><div>در حال بارگذاری ...</div></div></td></tr>`;
            const response = await fetch(`/api/admin/audit-logs?${params().toString()}`, { credentials: "same-origin" });
            if (!response.ok) {
                body.innerHTML = `<tr><td colspan="7"><div class="empty-state"><i class="bi bi-exclamation-triangle"></i><div>خطا در دریافت داده‌ها</div></div></td></tr>`;
                return;
            }

            const data = await response.json();
            totalPages = data.totalPages || 1;
            allRows = data.items || [];
            renderRows(allRows);
            summary.textContent = `صفحه ${data.page} از ${data.totalPages} | ${data.totalCount} رکورد`;
            document.getElementById("audit-prev").disabled = page <= 1;
            document.getElementById("audit-next").disabled = page >= totalPages;
            applyExportHref();
        };

        document.getElementById("audit-refresh").addEventListener("click", (e) => {
            e.preventDefault();
            page = 1;
            loadData();
        });

        document.getElementById("audit-prev").addEventListener("click", () => {
            if (page > 1) {
                page--;
                loadData();
            }
        });

        document.getElementById("audit-next").addEventListener("click", () => {
            if (page < totalPages) {
                page++;
                loadData();
            }
        });

        expandAllButton.addEventListener("click", () => {
            document.querySelectorAll(".audit-inline-detail").forEach(detail => detail.style.display = "block");
        });

        collapseAllButton.addEventListener("click", () => {
            document.querySelectorAll(".audit-inline-detail").forEach(detail => detail.style.display = "none");
        });

        copyJsonButton.addEventListener("click", async () => {
            const item = selectedRowIndex != null ? lastRows[selectedRowIndex] : null;
            if (!item) return;
            const payload = {
                oldValues: item.oldValues ? (() => { try { return JSON.parse(item.oldValues); } catch { return item.oldValues; } })() : null,
                newValues: item.newValues ? (() => { try { return JSON.parse(item.newValues); } catch { return item.newValues; } })() : null,
                affectedColumns: item.affectedColumns,
                tableName: item.tableName,
                action: item.action
            };
            await navigator.clipboard.writeText(JSON.stringify(payload, null, 2));
            window.AppUI?.toast("کپی شد", "JSON ردیف انتخاب‌شده در کلیپ‌بورد قرار گرفت.", "success");
        });

        [moduleSelect, actionSelect, tableSelect, userSelect, fromInput, toInput, sensitiveSelect].forEach(el => {
            el.addEventListener("change", () => {
                page = 1;
                loadData();
            });
        });

        searchInput.addEventListener("input", applyClientSearch);

        Promise.all([loadOptions()]).then(() => loadData());
    })();
</script>
