@model GlobalSearchViewModel
@{
    ViewData["Title"] = "جستجوی سراسری";
    var groups = Model.Results.GroupBy(item => item.Module).OrderBy(item => item.Key).ToList();
}

<div class="container-fluid py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">جستجوی سراسری</h5>
            <p class="text-muted small mb-0">نامه‌ها، اشخاص، فاکتورها، کالاها، تامین‌کنندگان، بارنامه‌ها و کاربران</p>
        </div>
        <a asp-controller="Reports" asp-action="Index" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-file-earmark-bar-graph"></i> گزارش‌ساز
        </a>
    </div>

    <form method="get" class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
            <div class="input-group input-group-sm">
                <button class="btn btn-primary px-3" type="submit"><i class="bi bi-search"></i></button>
                <input name="q" value="@Model.Query" class="form-control" autofocus placeholder="جستجو در کل سیستم..." />
            </div>
        </div>
    </form>

    @if (string.IsNullOrWhiteSpace(Model.Query))
    {
        <div class="alert alert-light border small">برای شروع، عبارت مورد نظر را وارد کنید.</div>
    }
    else if (!Model.Results.Any())
    {
        <div class="alert alert-warning small">نتیجه‌ای برای «@Model.Query» پیدا نشد.</div>
    }
    else
    {
        <div class="small text-muted mb-2">@Model.TotalCount نتیجه پیدا شد.</div>
        <div class="row g-3">
            @foreach (var group in groups)
            {
                <div class="col-12 col-xl-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white d-flex align-items-center justify-content-between py-2">
                            <strong class="small">@group.Key</strong>
                            <span class="badge text-bg-light">@group.Count()</span>
                        </div>
                        <div class="list-group list-group-flush">
                            @foreach (var item in group)
                            {
                                <a href="@item.Url" class="list-group-item list-group-item-action d-flex align-items-start gap-2 py-2">
                                    <i class="bi @item.Icon text-@item.Tone mt-1"></i>
                                    <span class="min-w-0">
                                        <span class="d-block fw-semibold small text-truncate">@item.Title</span>
                                        <small class="text-muted">@item.Subtitle</small>
                                    </span>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
