@model ErrorViewModel
@{
    ViewData["Title"] = "خطا";
}

<h1 class="text-danger">خطا</h1>
<h2 class="text-danger">در پردازش درخواست شما خطایی رخ داد.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>شناسه درخواست:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>حالت توسعه</h3>
<p>
    اگر برنامه در محیط <strong>توسعه</strong> اجرا شود، جزئیات بیشتری از خطای رخ‌داده نمایش داده می‌شود.
</p>
<p>
    <strong>فعال بودن محیط توسعه در سامانه عملیاتی توصیه نمی‌شود.</strong>
    این حالت ممکن است اطلاعات حساس مربوط به خطاها را به کاربران نهایی نمایش دهد.
    برای اشکال‌زدایی محلی، مقدار متغیر محیطی <strong>ASPNETCORE_ENVIRONMENT</strong> را روی <strong>Development</strong> قرار دهید
    و برنامه را دوباره اجرا کنید.
</p>
