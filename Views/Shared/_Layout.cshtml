                <div class="logo-wrapper">
                    <div class="logo-icon">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div class="logo-text">
                        <span class="brand-name">پنل راینو</span>
                        <span class="brand-status">نسخه سازمانی 2026</span>
                    </div>
                </div>
            </div>

            <div class="sidebar-content" id="sidebarScrollContainer">
                <div class="sidebar-fixed-top">
                    <div class="sidebar-quick-search">
