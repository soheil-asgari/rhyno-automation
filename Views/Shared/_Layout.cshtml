                                        <a class="nav-link sidebar-link @(currentController == "Financial" && (currentAction == "Dashboard" || currentAction == "ReportingHub") ? "sidebar-active" : "")" data-nav-id="financial-dashboard" asp-controller="Financial" asp-action="Dashboard"><i class="bi bi-speedometer2 text-info"></i> <span class="link-text">داشبورد مالی</span></a>
