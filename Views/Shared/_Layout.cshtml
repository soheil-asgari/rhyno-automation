@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using OfficeAutomation.Data
@using OfficeAutomation.Models
@using OfficeAutomation.Services.Security
@inject ApplicationDbContext DbContext
@inject IAuthorizationFacade AuthorizationFacade
@{
    var displayName = User?.FindFirst("name")?.Value
                      ?? User?.FindFirst(ClaimTypes.Name)?.Value
                      ?? User?.Identity?.Name;
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = "کاربر";
    }

    var userHasSecurityAccess = await AuthorizationFacade.IsSecurityAdminAsync();
    var userRoleLabel = "کاربر سیستم";
    if (User?.Identity?.IsAuthenticated == true)
    {
        if (userHasSecurityAccess)
        {
            userRoleLabel = "مدیر سیستم";
        }
        else
        {
            var roleClaim = User.FindFirst(ClaimTypes.Role)?.Value
                            ?? User.FindFirst("role")?.Value;

            if (!string.IsNullOrWhiteSpace(roleClaim))
            {
                userRoleLabel = roleClaim;
            }
        }
    }

    var themePreference = "System";
    if (User?.Identity?.IsAuthenticated == true)
    {
        var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(currentUserId))
        {
            var savedTheme = await DbContext.UserPreferences
                .AsNoTracking()
                .Where(preference => preference.UserId == currentUserId)
                .Select(preference => preference.ThemePreference)
                .FirstOrDefaultAsync();

            if (string.Equals(savedTheme, "Light", StringComparison.OrdinalIgnoreCase))
            {
                themePreference = "Light";
            }
            else if (string.Equals(savedTheme, "Dark", StringComparison.OrdinalIgnoreCase))
            {
                themePreference = "Dark";
            }
        }
    }

    var rootThemeClass = string.Equals(themePreference, "Dark", StringComparison.OrdinalIgnoreCase)
        ? "theme-dark"
        : "theme-light";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var userCanAccessFinance = userHasSecurityAccess;
    var userCanAccessWarehouse = userHasSecurityAccess;
    var userCanAccessHumanCapital = userHasSecurityAccess;
    var userCanAccessSystemSettings = userHasSecurityAccess;
    if (User?.Identity?.IsAuthenticated == true && !userHasSecurityAccess)
    {
        var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(currentUserId))
        {
            var permission = await DbContext.Users
                .AsNoTracking()
                .Where(item => item.Id == currentUserId)
                .Select(item => new
                {
                    item.CanAccessFinance,
                    item.CanAccessWarehouse,
                    item.CanAccessHumanCapital,
                    item.CanAccessSystemSettings
                })
                .FirstOrDefaultAsync();

            if (permission != null)
            {
                userCanAccessFinance = permission.CanAccessFinance;
                userCanAccessWarehouse = permission.CanAccessWarehouse;
                userCanAccessHumanCapital = permission.CanAccessHumanCapital;
                userCanAccessSystemSettings = permission.CanAccessSystemSettings;
            }
        }
    }

    var headerNotifications = new List<(string Title, string Description, string Url, string Icon, string Tone)>();
    if (User?.Identity?.IsAuthenticated == true)
    {
        var notificationUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        var todayStart = new DateTimeOffset(DateTime.UtcNow.Date, TimeSpan.Zero);

        if (!string.IsNullOrWhiteSpace(notificationUserId))
        {
            var unreadLetters = await DbContext.Letters
                .AsNoTracking()
                .CountAsync(item => !item.IsRead && (item.ReceiverId == notificationUserId || item.FinalReceiverId == notificationUserId));
            if (unreadLetters > 0)
            {
                headerNotifications.Add(("نامه جدید", $"{unreadLetters:N0} نامه خوانده نشده دارید.", "/Letters", "bi-envelope", "primary"));
            }

            var approvedLeaves = await DbContext.Leaves
                .AsNoTracking()
                .CountAsync(item => item.UserId == notificationUserId && item.Status == WorkflowStatus.Approved);
            if (approvedLeaves > 0)
            {
                headerNotifications.Add(("تایید مرخصی", $"{approvedLeaves:N0} درخواست مرخصی تایید شده دارید.", "/Leaves", "bi-calendar-check", "success"));
            }
        }

        if (userHasSecurityAccess)
        {
            var pendingLeavesForApproval = await DbContext.Leaves
                .AsNoTracking()
                .CountAsync(item => item.Status == WorkflowStatus.PendingApproval || item.Status == "در انتظار تایید" || item.Status == "در انتظار تأیید");
            if (pendingLeavesForApproval > 0)
            {
                headerNotifications.Add(("مرخصی در انتظار", $"{pendingLeavesForApproval:N0} درخواست مرخصی نیاز به بررسی دارد.", "/Leaves", "bi-hourglass-split", "warning"));
            }
        }

        var lowStock = await DbContext.InventoryStocks
            .AsNoTracking()
            .CountAsync(item => item.Product.MinimumStock > 0 && item.CurrentQuantity <= item.Product.MinimumStock);
        if (lowStock > 0)
        {
            headerNotifications.Add(("کاهش موجودی", $"{lowStock:N0} قلم کالا به حداقل موجودی رسیده است.", "/Warehouse/Stock", "bi-box-seam", "danger"));
        }

        var dueInvoices = await DbContext.Invoices
            .AsNoTracking()
            .CountAsync(item =>
                item.InvoiceType == "Purchase" &&
                item.DeadlineDateShamsi != null &&
                item.WorkflowStatus != WorkflowStatus.Approved &&
                item.WorkflowStatus != WorkflowStatus.Archived);
        if (dueInvoices > 0)
        {
            headerNotifications.Add(("سررسید مالی/پرداخت", $"{dueInvoices:N0} فاکتور خرید نیاز به پیگیری موعد دارد.", "/Financial/Purchases", "bi-calendar2-week", "warning"));
        }

        var securityChanges = await DbContext.AuditLogs
            .AsNoTracking()
            .CountAsync(item =>
                item.DateTime >= todayStart &&
                (item.Action == "Delete" || item.TableName.Contains("Role") || item.TableName.Contains("Permission")));
        if (securityChanges > 0)
        {
            headerNotifications.Add(("تغییر امنیتی", $"{securityChanges:N0} رخداد حساس امروز ثبت شده است.", "/admin/audit-dashboard", "bi-shield-check", "info"));
        }
    }

    var headerNotificationCount = headerNotifications.Count;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl" data-theme="@themePreference.ToLowerInvariant()" class="@rootThemeClass">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل مدیریت راینو</title>

    <script src="https://lib.arvancloud.ir/sweetalert2/9.17.4/sweetalert2.all.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <link rel="stylesheet" href="https://lib.arvancloud.ir/bootstrap/5.3.0-alpha1/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://lib.arvancloud.ir/bootstrap-icons/1.9.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.9.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true">

    <style>
        :root {
            --app-sidebar-width: 232px;
            --app-content-gutter: 14px;
            --layout-shell-bg: var(--app-shell-bg);
            --layout-surface: var(--app-surface-strong);
            --layout-surface-soft: var(--app-surface-soft);
            --layout-border: var(--app-border-strong);
            --layout-text: var(--text-main);
            --layout-text-muted: var(--text-muted);
            --layout-shadow: var(--app-shadow);
        }

        /* فیکس کردن ارتفاع بدنه و اسکرول سایدبار */
        body {
            background-color: var(--layout-shell-bg);
            color: var(--layout-text);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            overflow-y: auto;
        }

        .app-shell {
            display: block;
            height: auto;
            min-height: 100vh;
            overflow-x: hidden;
            overflow-y: visible;
            width: 100%;
        }

        /* استایل سایدبار راست با اسکرول فعال مستقل */
        .sidebar-right,
        #appSidebar.sidebar-right {
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: fixed;
            top: 0;
            right: 0;
            width: var(--app-sidebar-width) !important;
            min-width: var(--app-sidebar-width) !important;
            max-width: var(--app-sidebar-width) !important;
            background-color: var(--layout-surface);
            border-left: 1px solid var(--layout-border);
            z-index: 1030;
        }

        #appSidebar i,
        #appSidebar .bi,
        .custom-topbar i,
        .custom-topbar .bi {
            background-image: none !important;
            border-radius: 6px !important;
            line-height: 1;
        }

        .logo-icon,
        .user-avatar-box {
            border: 1px solid var(--layout-border);
            color: var(--primary);
        }

        .sidebar-content {
            flex: 1;
            min-height: 0;
            overflow-y: auto;
            padding: 8px;
            overscroll-behavior: contain;
        }

            .sidebar-content::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-content::-webkit-scrollbar-thumb {
                background-color: #cbd5e1;
                border-radius: 6px !important;
            }

        /* نوار بالای صفحه همرنگ بدنه (بدون حاشیه اضافی) */
        .custom-topbar {
            background-color: var(--layout-shell-bg);
            padding: 10px 18px;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            gap: 12px;
            min-height: 56px;
            overflow: visible;
        }

        .topbar-cluster,
        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 8px;
            min-width: 0;
            white-space: nowrap;
        }

        .topbar-right-info {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.72rem;
            color: var(--layout-text-muted);
        }

        .status-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 6px !important;
            margin-left: 4px;
        }

        .topbar-clock-box {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.76rem;
            font-weight: 600;
            color: var(--layout-text);
            background: var(--layout-surface);
            padding: 5px 10px;
            border-radius: 6px !important;
            border: 1px solid var(--layout-border);
            box-shadow: var(--layout-shadow);
            flex: 0 0 auto;
            white-space: nowrap;
        }

        .notification-center {
            position: relative;
        }

        .notification-toggle {
            position: relative;
            width: 32px;
            height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--layout-border);
            background: var(--layout-surface);
            color: var(--layout-text);
            padding: 0;
        }

        .notification-count {
            position: absolute;
            top: -6px;
            left: -6px;
            min-width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #ef4444;
            color: #fff;
            border: 2px solid var(--layout-surface);
            font-size: .62rem;
            font-weight: 900;
            line-height: 1;
        }

        .notification-menu {
            width: min(360px, 88vw);
            padding: 0;
            border: 1px solid var(--layout-border);
            box-shadow: var(--layout-shadow);
            background: var(--layout-surface);
            overflow: hidden;
        }

        .notification-menu-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 10px 12px;
            border-bottom: 1px solid var(--layout-border);
            background: var(--layout-surface-soft);
        }

        .notification-menu-head strong {
            font-size: .78rem;
        }

        .notification-menu-head span {
            font-size: .66rem;
            color: var(--layout-text-muted);
            font-weight: 800;
        }

        .notification-item {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            padding: 9px 12px;
            color: inherit;
            text-decoration: none;
            border-bottom: 1px solid var(--layout-border);
        }

        .notification-item:last-child {
            border-bottom: 0;
        }

        .notification-item:hover {
            background: var(--layout-surface-soft);
        }

        .notification-item i {
            width: 26px;
            height: 26px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--layout-border);
            color: var(--primary);
            flex: 0 0 auto;
        }

        .notification-item strong {
            display: block;
            font-size: .74rem;
            margin-bottom: 2px;
        }

        .notification-item small {
            display: block;
            color: var(--layout-text-muted);
            font-size: .66rem;
            line-height: 1.6;
        }

        .notification-empty {
            padding: 16px 12px;
            text-align: center;
            color: var(--layout-text-muted);
            font-size: .72rem;
        }

        .topbar-search {
            position: relative;
            width: min(220px, 24vw);
            min-width: 160px;
            flex: 0 1 220px;
        }

        .sidebar-quick-search {
            position: sticky;
            top: 0;
            z-index: 2;
            background: var(--layout-surface);
            padding-bottom: 7px;
            margin-bottom: 6px;
        }

        .sidebar-quick-search .search-box {
            position: relative;
        }

        .sidebar-quick-search .form-control {
            height: 32px;
            border: 1px solid var(--layout-border);
            background: var(--layout-surface-soft);
            color: var(--layout-text);
            font-size: .72rem;
            font-weight: 700;
            padding-right: 28px;
        }

        .sidebar-quick-search .form-control:focus {
            border-color: #6366f1;
            background: var(--layout-surface);
            box-shadow: 0 0 0 .18rem rgba(99, 102, 241, .14);
        }

        .sidebar-quick-search .bi-search {
            position: absolute;
            right: 9px;
            top: 8px;
            color: var(--layout-text-muted);
            font-size: .76rem;
            pointer-events: none;
        }

        .sidebar-search-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            margin-top: 5px;
            color: var(--layout-text-muted);
            font-size: .66rem;
            font-weight: 800;
        }

        .sidebar-search-clear {
            border: 0;
            background: transparent;
            color: var(--primary);
            padding: 0;
            font-size: .66rem;
            font-weight: 850;
        }

        .sidebar-search-clear.d-none {
            display: none !important;
        }

        .sidebar-search-hidden {
            display: none !important;
        }

        .sidebar-search-no-results {
            display: none;
            border: 1px dashed var(--layout-border);
            background: var(--layout-surface-soft);
            color: var(--layout-text-muted);
            border-radius: 6px !important;
            padding: 8px;
            font-size: .7rem;
            font-weight: 750;
            line-height: 1.7;
        }

        .sidebar-search-no-results.is-visible {
            display: block;
        }

        .main-wrapper {
            width: calc(100% - var(--app-sidebar-width)) !important;
            max-width: calc(100% - var(--app-sidebar-width)) !important;
            margin-right: var(--app-sidebar-width) !important;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: visible;
            min-width: 0;
        }

        #main-content-wrapper {
            width: 100%;
            max-width: 100%;
            min-width: 0;
            overflow-x: hidden;
            box-sizing: border-box;
        }

        #main-content-wrapper > * {
            max-width: 100%;
        }

        #main-content-wrapper .container,
        #main-content-wrapper .container-fluid {
            max-width: 100%;
        }

        #main-content-wrapper .table-responsive {
            overflow-x: auto;
        }

        .sidebar-accordion .accordion-item {
            border: 0;
            border-radius: 6px !important;
            overflow: visible;
            background: transparent;
            margin-bottom: 4px;
        }

        .sidebar-accordion .accordion-button {
            background: var(--layout-surface-soft);
            color: var(--layout-text);
            font-size: 0.72rem;
            font-weight: 700;
            padding: 6px 8px;
            box-shadow: none;
            border-radius: 6px !important;
        }

            .sidebar-accordion .accordion-button:not(.collapsed) {
                background: rgba(99, 102, 241, 0.16);
                color: var(--primary);
            }

            .sidebar-accordion .accordion-button::after {
                width: 0.68rem;
                height: 0.68rem;
                background-size: 0.68rem;
            }

        .sidebar-group-nav {
            padding: 4px 0 1px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 5px;
            border-radius: 6px !important;
            font-size: 0.7rem;
            color: var(--layout-text);
            padding: 5px 8px;
        }

            .sidebar-link:hover {
                background: var(--layout-surface-soft);
                color: var(--layout-text);
            }

            .sidebar-link.sidebar-active {
                background: rgba(99, 102, 241, 0.14);
                color: var(--primary);
                font-weight: 700;
            }

        .user-profile-link .user-profile-pill {
            transition: background-color 0.2s ease;
        }

        .sidebar-footer {
            flex: 0 0 auto;
            margin-top: auto;
            padding: 0;
            border-top: 1px solid var(--layout-border);
            background: var(--layout-surface);
        }

        .user-profile-link {
            display: block;
            text-decoration: none;
            color: inherit;
            cursor: pointer;
        }

        .user-profile-pill {
            padding: 8px 10px;
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--layout-surface);
            border-radius: 6px !important;
            border: 1px solid var(--layout-border);
        }

        .user-avatar-box {
            width: 28px;
            height: 28px;
            background: transparent;
            border-radius: 6px !important;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .online-status {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 7px;
            height: 7px;
            background: #10b981;
            border: 2px solid var(--layout-surface);
            border-radius: 6px !important;
        }

        #appSidebar,
        #appSidebar *,
        .main-wrapper,
        .custom-topbar,
        .topbar-clock-box,
        .topbar-search .form-control,
        .topbar-actions .btn,
        #main-content-wrapper,
        #main-content-wrapper .card,
        #main-content-wrapper .btn,
        #main-content-wrapper .form-control,
        #main-content-wrapper .form-select,
        #main-content-wrapper textarea,
        #main-content-wrapper select,
        #main-content-wrapper input,
        button,
        .btn,
        .card,
        input,
        select,
        textarea,
        #main-content-wrapper .badge,
        #main-content-wrapper .modal-content {
            border-radius: 6px !important;
        }

        .user-profile-link:hover .user-profile-pill,
        .user-profile-link:focus-visible .user-profile-pill {
            background-color: var(--layout-surface-soft);
        }

        #main-content-wrapper,
        #main-content-wrapper table,
        #main-content-wrapper .table,
        #main-content-wrapper .table th,
        #main-content-wrapper .table td,
        #main-content-wrapper .table th *,
        #main-content-wrapper .table td *,
        #main-content-wrapper .grid,
        #main-content-wrapper .matrix {
            color: var(--text-dark) !important;
        }
    </style>
    <style>
        html.theme-dark body,
        html.dark-mode body,
        html[data-theme="dark"] body {
            background-color: var(--layout-shell-bg) !important;
            color: var(--layout-text) !important;
        }

        html.theme-dark .app-shell,
        html.theme-dark .main-wrapper,
        html.theme-dark .main-content,
        html.dark-mode .app-shell,
        html.dark-mode .main-wrapper,
        html.dark-mode .main-content,
        html[data-theme="dark"] .app-shell,
        html[data-theme="dark"] .main-wrapper,
        html[data-theme="dark"] .main-content {
            background-color: var(--layout-shell-bg) !important;
            color: var(--layout-text) !important;
        }

        html.theme-dark .custom-topbar,
        html.theme-dark .topbar-clock-box,
        html.theme-dark .sidebar-right,
        html.theme-dark .user-profile-pill,
        html.theme-dark .notification-menu,
        html.theme-dark .notification-toggle,
        html.theme-dark .sidebar-quick-search,
        html.dark-mode .custom-topbar,
        html.dark-mode .topbar-clock-box,
        html.dark-mode .sidebar-right,
        html.dark-mode .user-profile-pill,
        html.dark-mode .notification-menu,
        html.dark-mode .notification-toggle,
        html.dark-mode .sidebar-quick-search,
        html[data-theme="dark"] .custom-topbar,
        html[data-theme="dark"] .topbar-clock-box,
        html[data-theme="dark"] .sidebar-right,
        html[data-theme="dark"] .user-profile-pill,
        html[data-theme="dark"] .notification-menu,
        html[data-theme="dark"] .notification-toggle,
        html[data-theme="dark"] .sidebar-quick-search {
            background-color: var(--layout-surface) !important;
            background-image: linear-gradient(180deg, rgba(139, 92, 246, 0.06), rgba(34, 211, 238, 0.03)) !important;
            border-color: var(--layout-border) !important;
            color: var(--layout-text) !important;
        }

        html.theme-dark .sidebar-accordion .accordion-button,
        html.dark-mode .sidebar-accordion .accordion-button,
        html[data-theme="dark"] .sidebar-accordion .accordion-button {
            background: var(--layout-surface-soft) !important;
            color: var(--layout-text) !important;
        }

        html.theme-dark .sidebar-quick-search .form-control,
        html.dark-mode .sidebar-quick-search .form-control,
        html[data-theme="dark"] .sidebar-quick-search .form-control {
            background: var(--layout-surface-soft) !important;
            border-color: var(--layout-border) !important;
            color: var(--layout-text) !important;
        }

        html.theme-dark #main-content-wrapper [style*="background-color: #fff"],
        html.theme-dark #main-content-wrapper [style*="background: #fff"],
        html.theme-dark #main-content-wrapper [style*="background-color:#fff"],
        html.theme-dark #main-content-wrapper [style*="background:#fff"],
        html.theme-dark #main-content-wrapper [style*="background-color: #f8fafc"],
        html.theme-dark #main-content-wrapper [style*="background: #f8fafc"],
        html.theme-dark #main-content-wrapper [style*="background-color: #fff9f0"],
        html.theme-dark #main-content-wrapper [style*="color:#1e293b"],
        html.theme-dark #main-content-wrapper [style*="color: #1e293b"],
        html.theme-dark #main-content-wrapper [style*="color:#64748b"],
        html.theme-dark #main-content-wrapper [style*="color: #64748b"],
        html.theme-dark #appSidebar [style*="background-color: #fff"],
        html.theme-dark #appSidebar [style*="background: #fff"],
        html.theme-dark #appSidebar [style*="background-color:#fff"],
        html.theme-dark #appSidebar [style*="background:#fff"],
        html.theme-dark #appSidebar [style*="color:#1e293b"],
        html.theme-dark #appSidebar [style*="color: #1e293b"],
        html.theme-dark #appSidebar [style*="color:#64748b"],
