                            <input id="sidebarMenuSearch" type="search" class="form-control" autocomplete="off" placeholder="جستجوی سریع منو..." aria-label="جستجوی سریع منو">
                            <i class="bi bi-search"></i>
                        </div>
                        <div class="sidebar-search-meta">
                            <span id="sidebarSearchCount">همه بخش‌ها</span>
                            <button id="sidebarSearchClear" type="button" class="sidebar-search-clear d-none">پاک کردن</button>
                        </div>
                    </div>

                    <section class="sidebar-section sidebar-section-pinned">
                        <div class="sidebar-section-head">
