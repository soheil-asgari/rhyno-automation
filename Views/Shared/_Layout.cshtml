@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Antiforgery
@using OfficeAutomation.Models
@using OfficeAutomation.Services
@using OfficeAutomation.Services.Security
@inject OfficeAutomation.Modules.Identity.Infrastructure.Persistence.IdentityDbContext DbContext
@inject IAuthorizationFacade AuthorizationFacade
@inject IAntiforgery Antiforgery
@inject NotificationService NotificationService
@{
    var antiforgeryTokens = Antiforgery.GetAndStoreTokens(Context);
    var displayName = User?.FindFirst("name")?.Value
                      ?? User?.FindFirst(ClaimTypes.Name)?.Value
                      ?? User?.Identity?.Name;
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = "کاربر";
    }

    var userHasSecurityAccess = await AuthorizationFacade.IsSecurityAdminAsync();
    var userRoleLabel = "کاربر سیستم";
    if (User?.Identity?.IsAuthenticated == true)
    {
        if (userHasSecurityAccess)
        {
            userRoleLabel = "مدیر سیستم";
        }
        else
        {
            var roleClaim = User.FindFirst(ClaimTypes.Role)?.Value
                            ?? User.FindFirst("role")?.Value;

            if (!string.IsNullOrWhiteSpace(roleClaim))
            {
                userRoleLabel = roleClaim;
            }
        }
    }

    var themePreference = "System";
    if (User?.Identity?.IsAuthenticated == true)
    {
        var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(currentUserId))
        {
            var savedTheme = await DbContext.UserPreferences
                .AsNoTracking()
                .Where(preference => preference.UserId == currentUserId)
                .Select(preference => preference.ThemePreference)
                .FirstOrDefaultAsync();

            if (string.Equals(savedTheme, "Light", StringComparison.OrdinalIgnoreCase))
            {
                themePreference = "Light";
            }
            else if (string.Equals(savedTheme, "Dark", StringComparison.OrdinalIgnoreCase))
            {
                themePreference = "Dark";
            }
        }
    }

    var rootThemeClass = string.Equals(themePreference, "Dark", StringComparison.OrdinalIgnoreCase)
        ? "theme-dark"
        : "theme-light";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var userCanAccessFinance = userHasSecurityAccess;
    var userCanAccessWarehouse = userHasSecurityAccess;
    var userCanAccessHumanCapital = userHasSecurityAccess;
    var userCanAccessSystemSettings = userHasSecurityAccess;
    var userCanAccessProcessAnalytics = userHasSecurityAccess;
    if (User?.Identity?.IsAuthenticated == true && !userHasSecurityAccess)
    {
        var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(currentUserId))
        {
            var permission = await DbContext.Users
                .AsNoTracking()
                .Where(item => item.Id == currentUserId)
                .Select(item => new
                {
                    item.CanAccessFinance,
                    item.CanAccessWarehouse,
                    item.CanAccessHumanCapital,
                    item.CanAccessSystemSettings
                })
                .FirstOrDefaultAsync();

            if (permission != null)
            {
                userCanAccessFinance = permission.CanAccessFinance;
                userCanAccessWarehouse = permission.CanAccessWarehouse;
                userCanAccessHumanCapital = permission.CanAccessHumanCapital;
                userCanAccessSystemSettings = permission.CanAccessSystemSettings;
            }
        }

        userCanAccessProcessAnalytics = await AuthorizationFacade.HasPermissionAsync("تحلیل.مشاهده");
    }

    var headerNotifications = new List<HeaderNotificationVM>();
    if (User?.Identity?.IsAuthenticated == true)
    {
        var notificationUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (!string.IsNullOrWhiteSpace(notificationUserId))
        {
            headerNotifications = (await NotificationService.GetHeaderNotificationsAsync(notificationUserId)).ToList();
        }
    }

    var headerNotificationCount = headerNotifications.Count;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl" data-theme="@themePreference.ToLowerInvariant()" class="@rootThemeClass">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="request-verification-token" content="@antiforgeryTokens.RequestToken" />
    <title>@ViewData["Title"] - پنل مدیریت راینو</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" asp-append-version="true">
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/main-foundation.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/main-legacy.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/app-shell.css" asp-append-version="true">
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/visual-refresh-core.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/visual-refresh-legacy.css" asp-append-version="true">
</head>

<body data-theme="@themePreference.ToLowerInvariant()">
