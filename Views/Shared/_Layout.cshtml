            html.theme-dark .sidebar-accordion .accordion-button:not(.collapsed),
            html.dark-mode .sidebar-accordion .accordion-button:not(.collapsed),
            html[data-theme="dark"] .sidebar-accordion .accordion-button:not(.collapsed) {
                background: rgba(99, 102, 241, 0.16) !important;
                color: var(--primary) !important;
            }

        html.theme-dark .sidebar-link,
        html.dark-mode .sidebar-link,
        html[data-theme="dark"] .sidebar-link {
            color: var(--layout-text) !important;
        }

            html.theme-dark .sidebar-link:hover,
            html.theme-dark .sidebar-link.sidebar-active,
            html.dark-mode .sidebar-link:hover,
            html.dark-mode .sidebar-link.sidebar-active,
            html[data-theme="dark"] .sidebar-link:hover,
            html[data-theme="dark"] .sidebar-link.sidebar-active {
                background: rgba(99, 102, 241, 0.14) !important;
                color: var(--primary) !important;
            }

        html.theme-dark .main-content,
        html.dark-mode .main-content,
        html[data-theme="dark"] .main-content {
            background-color: var(--layout-shell-bg) !important;
        }

        html.theme-dark .logo-icon,
        html.theme-dark .user-avatar-box,
        html.dark-mode .logo-icon,
        html.dark-mode .user-avatar-box,
        html[data-theme="dark"] .logo-icon,
        html[data-theme="dark"] .user-avatar-box {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.18), rgba(56, 189, 248, 0.12)) !important;
            background-color: transparent !important;
            border-color: rgba(139, 92, 246, 0.34) !important;
            color: #dbeafe !important;
        }

        html.theme-dark .text-muted,
        html.theme-dark .text-secondary,
        html.theme-dark .text-dark,
        html.theme-dark .brand-status,
        html.theme-dark .u-role,
        html.dark-mode .text-muted,
        html.dark-mode .text-secondary,
        html.dark-mode .text-dark,
        html.dark-mode .brand-status,
        html.dark-mode .u-role,
        html[data-theme="dark"] .text-muted,
        html[data-theme="dark"] .text-secondary,
        html[data-theme="dark"] .text-dark,
        html[data-theme="dark"] .brand-status,
        html[data-theme="dark"] .u-role {
            color: var(--layout-text-muted) !important;
        }

        html.theme-dark .text-dark,
        html.dark-mode .text-dark,
        html[data-theme="dark"] .text-dark {
            color: var(--layout-text) !important;
        }

        html.theme-dark i,
        html.theme-dark .bi,
        html.dark-mode i,
        html.dark-mode .bi,
        html[data-theme="dark"] i,
        html[data-theme="dark"] .bi {
            color: currentColor !important;
        }

        html.theme-dark .notification-toggle,
        html.dark-mode .notification-toggle,
        html[data-theme="dark"] .notification-toggle {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.16), rgba(34, 211, 238, 0.12)) !important;
            color: #e0f2fe !important;
        }

        html.theme-dark .notification-menu-head,
        html.dark-mode .notification-menu-head,
        html[data-theme="dark"] .notification-menu-head {
            background: linear-gradient(135deg, rgba(34, 211, 238, 0.08), rgba(139, 92, 246, 0.08)) !important;
        }

        html.theme-dark .notification-item i,
        html.dark-mode .notification-item i,
        html[data-theme="dark"] .notification-item i {
            background: color-mix(in srgb, currentColor 14%, var(--layout-surface)) !important;
            border-color: color-mix(in srgb, currentColor 36%, var(--layout-border)) !important;
            color: currentColor !important;
        }

        html.theme-dark .topbar-clock-box i,
        html.dark-mode .topbar-clock-box i,
        html[data-theme="dark"] .topbar-clock-box i {
            color: var(--info) !important;
        }

        html.theme-dark .status-dot,
        html.dark-mode .status-dot,
        html[data-theme="dark"] .status-dot {
            box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.14);
        }

        @@media (max-width: 1199.98px) {
            :root {
                --app-sidebar-width: 224px;
            }
        }

        @@media (max-width: 991.98px) {
            .app-shell {
                display: block;
            }

            .sidebar-right,
            #appSidebar.sidebar-right {
                width: min(82vw, 260px) !important;
                min-width: min(82vw, 260px) !important;
                max-width: min(82vw, 260px) !important;
                transform: translateX(100%);
                transition: transform .2s ease;
            }

            .sidebar-right.is-open {
                transform: translateX(0);
            }

            .main-wrapper {
                width: 100% !important;
                margin-right: 0 !important;
            }

            .custom-topbar {
                padding: 8px 10px;
                grid-template-columns: minmax(0, 1fr);
            }

            .topbar-actions {
                justify-content: flex-start;
                overflow-x: auto;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/visual-refresh.css" asp-append-version="true">
</head>

<body data-theme="@themePreference.ToLowerInvariant()">
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <form id="rhGlobalAntiForgery" class="d-none">@Html.AntiForgeryToken()</form>

    <div class="app-shell">

        <aside class="sidebar-right" id="appSidebar">
            <div class="sidebar-header" style="padding: 20px 15px; border-bottom: 1px solid var(--layout-border);">
                <div class="logo-wrapper" style="display: flex; align-items: center; gap: 10px;">
                    <div class="logo-icon" style="background: var(--icon-tint); color:var(--primary); padding: 6px 9px; border-radius: 10px !important;">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div class="logo-text">
                        <span class="brand-name" style="display:block; font-weight:bold; font-size:0.95rem;">پنل راینو</span>
                        <span class="brand-status" style="font-size:0.75rem; color:var(--layout-text-muted);">نسخه سازمانی 2026</span>
                    </div>
                </div>
            </div>

            <div class="sidebar-content" id="sidebarScrollContainer">
                <div class="sidebar-quick-search">
                    <div class="search-box">
                        <input id="sidebarMenuSearch" type="search" class="form-control" autocomplete="off" placeholder="جستجوی سریع منو... (Ctrl+K)" aria-label="جستجوی سریع منو">
                        <i class="bi bi-search"></i>
                    </div>
                    <div class="sidebar-search-meta">
                        <span id="sidebarSearchCount">همه بخش‌ها</span>
                        <button id="sidebarSearchClear" type="button" class="sidebar-search-clear d-none">پاک کردن</button>
                    </div>
                </div>

                <div id="sidebarSearchNoResults" class="sidebar-search-no-results">
                    نتیجه‌ای در منو پیدا نشد.
                </div>

                <div class="mb-2">
                    <a class="nav-link sidebar-link @(currentController == "Home" ? "sidebar-active" : "")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid text-primary"></i> <span class="link-text">میز کار مرکزی</span>
                    </a>
                </div>

                <div class="accordion sidebar-accordion" id="sidebarAccordion">
                    @if (userCanAccessHumanCapital)
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingHumanCapital">
                                <button class="accordion-button @((currentController == "HumanCapital" || currentController == "Leaves" || currentController == "Letters") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseHumanCapital" aria-expanded="true" aria-controls="collapseHumanCapital">
                                    سرمایه انسانی
                                </button>
                            </h2>
                            <div id="collapseHumanCapital" class="accordion-collapse collapse @((currentController == "HumanCapital" || currentController == "Leaves" || currentController == "Letters") ? "show" : "")" aria-labelledby="headingHumanCapital" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body py-1 px-0">
                                    <nav class="nav flex-column sidebar-group-nav">
                                        <a class="nav-link sidebar-link @(currentController == "HumanCapital" ? "sidebar-active" : "")" asp-controller="HumanCapital" asp-action="Index"><i class="bi bi-people text-warning"></i> <span class="link-text">سرمایه انسانی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Leaves" ? "sidebar-active" : "")" asp-controller="Leaves" asp-action="Index"><i class="bi bi-calendar-check text-success"></i> <span class="link-text">درخواست مرخصی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Letters" ? "sidebar-active" : "")" asp-controller="Letters" asp-action="Index"><i class="bi bi-envelope-paper text-danger"></i> <span class="link-text">مدیریت نامه‌ها</span></a>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    }

                    @if (userCanAccessFinance)
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingFinancial">
                                <button class="accordion-button @((currentController == "Payroll" || currentController == "Bimeh" || currentController == "Financial") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFinancial" aria-expanded="false" aria-controls="collapseFinancial">
                                    مالی و حقوق و بیمه
                                </button>
                            </h2>
                            <div id="collapseFinancial" class="accordion-collapse collapse @((currentController == "Payroll" || currentController == "Bimeh" || currentController == "Financial") ? "show" : "")" aria-labelledby="headingFinancial" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body py-1 px-0">
                                    <nav class="nav flex-column sidebar-group-nav">
                                        <a class="nav-link sidebar-link @(currentController == "Financial" && currentAction == "Sales" ? "sidebar-active" : "")" asp-controller="Financial" asp-action="Sales"><i class="bi bi-graph-up text-success"></i> <span class="link-text">مدیریت فاکتورهای فروش (درآمد)</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Financial" && currentAction == "Purchases" ? "sidebar-active" : "")" asp-controller="Financial" asp-action="Purchases"><i class="bi bi-cart text-primary"></i> <span class="link-text">مدیریت فاکتورهای خرید (هزینه)</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Financial" && (currentAction == "Dashboard" || currentAction == "ReportingHub") ? "sidebar-active" : "")" asp-controller="Financial" asp-action="Dashboard"><i class="bi bi-speedometer2 text-info"></i> <span class="link-text">داشبورد مالی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Financial" && (currentAction == "VatDashboard" || currentAction == "Dashboard") ? "sidebar-active" : "")" asp-controller="Financial" asp-action="VatDashboard"><i class="bi bi-percent text-warning"></i> <span class="link-text">مالیات بر ارزش افزوده</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Financial" && (currentAction == "SeasonalTax" || currentAction == "SeasonalTaxReport") ? "sidebar-active" : "")" asp-controller="Financial" asp-action="SeasonalTax"><i class="bi bi-journal-text text-info"></i> <span class="link-text">معاملات فصلی (ماده ۱۶۹)</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Financial" && currentAction == "ReportingHub" ? "sidebar-active" : "")" asp-controller="Financial" asp-action="ReportingHub"><i class="bi bi-bar-chart text-secondary"></i> <span class="link-text">گزارشات و داشبورد مدیریتی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Payroll" ? "sidebar-active" : "")" asp-controller="Payroll" asp-action="Index"><i class="bi bi-cash-stack text-warning"></i> <span class="link-text">لیست حقوق</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Bimeh" ? "sidebar-active" : "")" asp-controller="Bimeh" asp-action="Index"><i class="bi bi-shield-lock text-info"></i> <span class="link-text">لیست بیمه</span></a>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    }

                    @if (userCanAccessWarehouse)
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingWarehouse">
                                <button class="accordion-button @((currentController == "Warehouse" || currentController == "Vendors" || currentController == "Employers") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseWarehouse" aria-expanded="false" aria-controls="collapseWarehouse">
                                    انبارداری
                                </button>
                            </h2>
                            <div id="collapseWarehouse" class="accordion-collapse collapse @((currentController == "Warehouse" || currentController == "Vendors" || currentController == "Employers") ? "show" : "")" aria-labelledby="headingWarehouse" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body py-1 px-0">
                                    <nav class="nav flex-column sidebar-group-nav">
                                        <a class="nav-link sidebar-link @(currentController == "Warehouse" && currentAction == "Index" ? "sidebar-active" : "")" asp-controller="Warehouse" asp-action="Index"><i class="bi bi-box-seam text-primary"></i> <span class="link-text">داشبورد انبار</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Warehouse" && (currentAction == "Products" || currentAction == "CreateProduct" || currentAction == "EditProduct") ? "sidebar-active" : "")" asp-controller="Warehouse" asp-action="Products"><i class="bi bi-box-seam text-info"></i> <span class="link-text">کالاها</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Warehouse" && (currentAction == "Warehouses" || currentAction == "CreateWarehouse" || currentAction == "EditWarehouse") ? "sidebar-active" : "")" asp-controller="Warehouse" asp-action="Warehouses"><i class="bi bi-building text-secondary"></i> <span class="link-text">انبارها</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Vendors" ? "sidebar-active" : "")" asp-controller="Vendors" asp-action="Index"><i class="bi bi-truck text-success"></i> <span class="link-text">تامین‌کنندگان</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Employers" ? "sidebar-active" : "")" asp-controller="Employers" asp-action="Index"><i class="bi bi-briefcase text-warning"></i> <span class="link-text">کارفرمایان</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Warehouse" && (currentAction == "Receipts" || currentAction == "CreateReceipt") ? "sidebar-active" : "")" asp-controller="Warehouse" asp-action="Receipts"><i class="bi bi-box-arrow-in-down text-success"></i> <span class="link-text">رسید انبار</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Warehouse" && (currentAction == "Issuances" || currentAction == "CreateIssuance") ? "sidebar-active" : "")" asp-controller="Warehouse" asp-action="Issuances"><i class="bi bi-box-arrow-up text-danger"></i> <span class="link-text">خروج انبار</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Warehouse" && currentAction == "Stock" ? "sidebar-active" : "")" asp-controller="Warehouse" asp-action="Stock"><i class="bi bi-clipboard-data text-info"></i> <span class="link-text">موجودی انبار</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Warehouse" && (currentAction == "TransferRequests" || currentAction == "CreateTransferRequest") ? "sidebar-active" : "")" asp-controller="Warehouse" asp-action="TransferRequests"><i class="bi bi-arrow-left-right text-primary"></i> <span class="link-text">انتقال بین انبارها</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Warehouse" && (currentAction == "Countings" || currentAction == "CreateCounting") ? "sidebar-active" : "")" asp-controller="Warehouse" asp-action="Countings"><i class="bi bi-check2-square text-secondary"></i> <span class="link-text">انبارگردانی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Warehouse" && currentAction == "Closing" ? "sidebar-active" : "")" asp-controller="Warehouse" asp-action="Closing"><i class="bi bi-lock text-danger"></i> <span class="link-text">بستن پایان سال</span></a>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    }

                    @if (userCanAccessSystemSettings)
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingSettings">
                                <button class="accordion-button @((currentController == "Settings" || currentController == "ManagementDashboard" || currentController == "AiAssistant" || currentController == "Waybill" || currentController == "Reports" || currentController == "Search") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSettings" aria-expanded="false" aria-controls="collapseSettings">
                                    تنظیمات
                                </button>
                            </h2>
                            <div id="collapseSettings" class="accordion-collapse collapse @((currentController == "Settings" || currentController == "ManagementDashboard" || currentController == "AiAssistant" || currentController == "Waybill" || currentController == "Reports" || currentController == "Search") ? "show" : "")" aria-labelledby="headingSettings" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body py-1 px-0">
                                    <nav class="nav flex-column sidebar-group-nav">
                                        @if (userHasSecurityAccess)
                                        {
                                            <a class="nav-link sidebar-link @((currentController == "AuditLogView" || currentController == "AuditLogs") ? "sidebar-active" : "")" href="/admin/audit-dashboard">
                                                <i class="bi bi-shield-check text-danger"></i> <span class="link-text">نظارت بر فعالیت‌ها</span>
                                            </a>
                                        }

                                        <a class="nav-link sidebar-link @(currentController == "ManagementDashboard" ? "sidebar-active" : "")" asp-controller="ManagementDashboard" asp-action="Index"><i class="bi bi-grid-1x2 text-primary"></i> <span class="link-text">داشبورد مدیریتی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Search" ? "sidebar-active" : "")" asp-controller="Search" asp-action="Index"><i class="bi bi-search text-primary"></i> <span class="link-text">جستجوی سراسری</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Reports" ? "sidebar-active" : "")" asp-controller="Reports" asp-action="Index"><i class="bi bi-file-earmark-bar-graph text-success"></i> <span class="link-text">گزارش‌ساز و خروجی‌ها</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "OrganizationCalendar" ? "sidebar-active" : "")" asp-controller="OrganizationCalendar" asp-action="Index"><i class="bi bi-calendar3 text-primary"></i> <span class="link-text">تقویم سازمانی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "DocumentArchive" ? "sidebar-active" : "")" asp-controller="DocumentArchive" asp-action="Index"><i class="bi bi-archive text-warning"></i> <span class="link-text">بایگانی اسناد</span></a>

                    @if (userHasSecurityAccess)
                                        {
                                            <a class="nav-link sidebar-link @(currentController == "Security" ? "sidebar-active" : "")" asp-controller="Security" asp-action="Index"><i class="bi bi-shield-check text-danger"></i> <span class="link-text">مرکز امنیت</span></a>
                                        }
                                        <a class="nav-link sidebar-link @(currentController == "AiAssistant" ? "sidebar-active" : "")" asp-controller="AiAssistant" asp-action="Index"><i class="bi bi-cpu text-info"></i> <span class="link-text">دستیار هوش مصنوعی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Waybill" ? "sidebar-active" : "")" asp-controller="Waybill" asp-action="Index"><i class="bi bi-truck text-warning"></i> <span class="link-text">ثبت بارنامه</span></a>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="sidebar-footer">
                <a asp-controller="Settings" asp-action="Index" class="user-profile-link">
                    <div class="user-profile-pill">
                            <div class="user-avatar" style="position: relative;">
                            <div class="user-avatar-box"><i class="bi bi-person-fill text-secondary"></i></div>
                            <span class="online-status"></span>
                            </div>
                            <div class="user-info" style="flex: 1;">
                                <span class="u-name" style="display: block; font-size: 0.85rem; font-weight: bold; color:var(--layout-text);">تنظیمات سامانه</span>
                                <span class="u-role" style="font-size: 0.7rem; color: var(--layout-text-muted);">@displayName - @userRoleLabel</span>
                            </div>
                        </div>
                    </a>
            </div>
        </aside>

        <div class="main-wrapper">

            <header class="custom-topbar">
                <div class="topbar-cluster">
                    <div class="topbar-clock-box">
                        <i class="bi bi-clock-history text-primary"></i>
                        <span id="topbarTime">--:--:--</span>
                        <span style="color: var(--layout-border);">|</span>
                        <span id="topbarDate">۱۴۰۵/۰۲/۲۷</span>
                    </div>

                    @* <form asp-controller="Search" asp-action="Index" method="get" class="topbar-search d-none d-md-flex" role="search">
                        <i class="bi bi-search"></i>
                        <input name="q" class="form-control form-control-sm" value="@(Context.Request.Query["q"].ToString())" autocomplete="off" placeholder="جستجوی کل سیستم..." />
                    </form> *@
                </div>

                <div class="topbar-actions">
                    <div class="dropdown notification-center">
                        <button class="notification-toggle" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" title="اعلان‌ها">
                            <i class="bi bi-bell"></i>
                            @if (headerNotificationCount > 0)
                            {
                                <span class="notification-count">@headerNotificationCount.ToString("N0")</span>
                            }
                        </button>
                        <div class="dropdown-menu dropdown-menu-start notification-menu">
                            <div class="notification-menu-head">
                                <strong>مرکز اعلان‌ها</strong>
                                <span>@headerNotificationCount.ToString("N0") اعلان</span>
                            </div>
                            @if (headerNotifications.Count == 0)
                            {
                                <div class="notification-empty">اعلان مهمی برای نمایش وجود ندارد.</div>
                            }
                            else
                            {
                                foreach (var notification in headerNotifications.Take(8))
                                {
                                    <a class="notification-item" href="@notification.Url">
                                        <i class="bi @notification.Icon text-@notification.Tone"></i>
                                        <span>
                                            <strong>@notification.Title</strong>
                                            <small>@notification.Description</small>
                                        </span>
                                    </a>
                                }
                            }
                        </div>
                    </div>
                    <div class="topbar-right-info d-none d-lg-flex">
                        <span><span class="status-dot" style="background-color: #22c55e;"></span> سرور: <span class="fw-bold text-success">فعال</span></span>
                        <span><span class="status-dot" style="background-color: #38bdf8;"></span> دیتابیس: <span class="fw-bold text-info">متصل</span></span>
                    </div>
                    <button class="btn btn-primary btn-sm px-3 py-1.5" style="background-color: var(--primary); border:none; font-size:0.8rem;">
                        <i class="bi bi-plus-lg me-1"></i> درخواست جدید
                    </button>
                </div>
            </header>

            <main id="main-content-wrapper" class="px-3 py-3" style="color: var(--layout-text); background: transparent;">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="https://lib.arvancloud.ir/jquery/3.6.3/jquery.min.js"></script>
    <script src="https://lib.arvancloud.ir/bootstrap/5.3.0-alpha1/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/layout.js" asp-append-version="true"></script>
    <script src="~/js/professional-table.js" asp-append-version="true"></script>
    <script>
        (() => {
            const html = document.documentElement;
            const storedPreference = localStorage.getItem('rhyno.theme.preference');
            const fallbackPreference = '@themePreference';
            const activePreference = storedPreference || fallbackPreference;
            const normalized = (activePreference || 'System').toLowerCase();

            html.classList.remove('theme-light', 'theme-dark');
            html.setAttribute('data-theme', normalized);
            document.body?.setAttribute('data-theme', normalized);

            if (normalized === 'light') {
                html.classList.add('theme-light');
                window.dispatchEvent(new Event('themechange'));
                return;
            }

            if (normalized === 'dark') {
                html.classList.add('theme-dark');
                window.dispatchEvent(new Event('themechange'));
                return;
            }

            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            html.classList.add(prefersDark ? 'theme-dark' : 'theme-light');
            window.dispatchEvent(new Event('themechange'));
        })();
    </script>
    <script>
        (() => {
            const sidebarContainer = document.getElementById('sidebarScrollContainer');
            if (!sidebarContainer) {
                return;
            }

            const storageKey = 'rhyno.sidebar.scrollTop';

            const savedRaw = localStorage.getItem(storageKey);
            const savedScrollTop = Number(savedRaw);
            if (Number.isFinite(savedScrollTop) && savedScrollTop >= 0) {
                sidebarContainer.scrollTop = savedScrollTop;
            }

            const persistScroll = () => {
                localStorage.setItem(storageKey, String(sidebarContainer.scrollTop));
            };

            sidebarContainer.addEventListener('scroll', persistScroll, { passive: true });

            sidebarContainer.addEventListener('click', () => {
                setTimeout(persistScroll, 0);
            });

            window.addEventListener('beforeunload', persistScroll);
        })();
    </script>

    <script>
        (() => {
            const timeElem = document.getElementById('topbarTime');
            const dateElem = document.getElementById('topbarDate');
            if (!timeElem || !dateElem) {
                return;
            }

            const toPersianDigits = (value) => String(value).replace(/\d/g, (digit) => '۰۱۲۳۴۵۶۷۸۹'[Number(digit)]);

            const updateClockAndDate = () => {
                const now = new Date();

                timeElem.textContent = now.toLocaleTimeString('fa-IR', {
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    hour12: false
                });

                const dateParts = new Intl.DateTimeFormat('fa-IR-u-ca-persian', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit'
                }).formatToParts(now);

                const year = dateParts.find((item) => item.type === 'year')?.value ?? '';
                const month = dateParts.find((item) => item.type === 'month')?.value ?? '';
                const day = dateParts.find((item) => item.type === 'day')?.value ?? '';

                dateElem.textContent = `${toPersianDigits(year)}/${toPersianDigits(month)}/${toPersianDigits(day)}`;
            };

            updateClockAndDate();
            setInterval(updateClockAndDate, 1000);
        })();
    </script>

    <script>
        (() => {
            const input = document.getElementById('sidebarMenuSearch');
            const clearButton = document.getElementById('sidebarSearchClear');
            const countLabel = document.getElementById('sidebarSearchCount');
            const noResults = document.getElementById('sidebarSearchNoResults');
            const sidebarContainer = document.getElementById('sidebarScrollContainer');
            const accordion = document.getElementById('sidebarAccordion');

            if (!input || !clearButton || !countLabel || !noResults || !sidebarContainer) {
                return;
            }

            const normalize = (value) => String(value || '')
                .replace(/[ي]/g, 'ی')
                .replace(/[ك]/g, 'ک')
                .replace(/\s+/g, ' ')
                .trim()
                .toLocaleLowerCase('fa-IR');

            const links = Array.from(sidebarContainer.querySelectorAll('a.sidebar-link'));
            const groups = Array.from(sidebarContainer.querySelectorAll('.sidebar-accordion .accordion-item'));

            groups.forEach((group) => {
                const collapse = group.querySelector('.accordion-collapse');
                if (collapse) {
                    collapse.dataset.initialShow = collapse.classList.contains('show') ? '1' : '0';
                }
            });

            const setCollapseVisible = (collapse, visible) => {
                if (!collapse) {
                    return;
                }

                collapse.classList.toggle('show', visible);
                const button = document.querySelector(`[data-bs-target="#${collapse.id}"]`);
                if (button) {
                    button.classList.toggle('collapsed', !visible);
                    button.setAttribute('aria-expanded', String(visible));
                }
            };

            const resetSearch = () => {
                links.forEach((link) => link.classList.remove('sidebar-search-hidden'));
                groups.forEach((group) => {
                    group.classList.remove('sidebar-search-hidden');
                    const collapse = group.querySelector('.accordion-collapse');
                    if (collapse) {
                        setCollapseVisible(collapse, collapse.dataset.initialShow === '1');
                    }
                });
                noResults.classList.remove('is-visible');
                clearButton.classList.add('d-none');
                countLabel.textContent = 'همه بخش‌ها';
            };

            const applySearch = () => {
                const query = normalize(input.value);
                if (!query) {
                    resetSearch();
                    return;
                }

                let matchCount = 0;

                links.forEach((link) => {
                    const text = normalize(link.textContent);
                    const matches = text.includes(query);
                    link.classList.toggle('sidebar-search-hidden', !matches);
                    if (matches) {
                        matchCount += 1;
                    }
                });

                groups.forEach((group) => {
                    const headerText = normalize(group.querySelector('.accordion-button')?.textContent);
                    const groupLinks = Array.from(group.querySelectorAll('a.sidebar-link'));
                    const headerMatches = headerText.includes(query);
                    const hasVisibleLink = groupLinks.some((link) => !link.classList.contains('sidebar-search-hidden'));

                    if (headerMatches) {
                        groupLinks.forEach((link) => link.classList.remove('sidebar-search-hidden'));
                        matchCount += groupLinks.filter((link) => !normalize(link.textContent).includes(query)).length;
                    }

                    const showGroup = headerMatches || hasVisibleLink;
                    group.classList.toggle('sidebar-search-hidden', !showGroup);
                    setCollapseVisible(group.querySelector('.accordion-collapse'), showGroup);
                });

                noResults.classList.toggle('is-visible', matchCount === 0);
                clearButton.classList.remove('d-none');
                countLabel.textContent = matchCount === 0
                    ? 'بدون نتیجه'
                    : `${matchCount.toLocaleString('fa-IR')} نتیجه`;
            };

            input.addEventListener('input', applySearch);

            clearButton.addEventListener('click', () => {
                input.value = '';
                input.focus();
                resetSearch();
            });

            document.addEventListener('keydown', (event) => {
                if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
                    event.preventDefault();
                    input.focus();
                    input.select();
                    sidebarContainer.scrollTop = 0;
                }

                if (event.key === 'Escape' && document.activeElement === input) {
                    input.value = '';
                    resetSearch();
                }
            });
        })();
    </script>

    <div class="modal fade" id="appConfirmDialog" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content app-confirm-dialog">
                <div class="modal-header">
                    <h5 class="modal-title">تایید عملیات</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="appConfirmMessage" class="mb-0">آیا مطمئن هستید؟</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">لغو</button>
                    <button type="button" class="btn btn-danger" id="appConfirmOk">تایید</button>
                </div>
            </div>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/app-ui.js" asp-append-version="true"></script>
</body>
</html>
