                                        <a class="nav-link sidebar-link @(currentController == "Bimeh" ? "sidebar-active" : "")" data-nav-id="bimeh-index" asp-controller="Bimeh" asp-action="Index"><i class="bi bi-shield-lock text-info"></i> <span class="link-text">لیست بیمه</span></a>
                                    </nav>
                                </div>
