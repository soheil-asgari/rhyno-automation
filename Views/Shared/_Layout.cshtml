    <script src="https://lib.arvancloud.ir/jquery/3.6.3/jquery.min.js"></script>
    <script src="https://lib.arvancloud.ir/bootstrap/5.3.0-alpha1/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/layout.js" asp-append-version="true"></script>
    <script>
        (() => {
            const html = document.documentElement;
            const storedPreference = localStorage.getItem('rhyno.theme.preference');
            const fallbackPreference = '@themePreference';
            const activePreference = storedPreference || fallbackPreference;
            const normalized = (activePreference || 'System').toLowerCase();

            html.classList.remove('theme-light', 'theme-dark');
            html.setAttribute('data-theme', normalized);
            document.body?.setAttribute('data-theme', normalized);

            if (normalized === 'light') {
                html.classList.add('theme-light');
                return;
            }

            if (normalized === 'dark') {
                html.classList.add('theme-dark');
                return;
            }

            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            html.classList.add(prefersDark ? 'theme-dark' : 'theme-light');
        })();
    </script>
    <script>
        (() => {
            const sidebarContainer = document.getElementById('sidebarScrollContainer');
            if (!sidebarContainer) {
                return;
            }

            const storageKey = 'rhyno.sidebar.scrollTop';

            const savedRaw = localStorage.getItem(storageKey);
            const savedScrollTop = Number(savedRaw);
            if (Number.isFinite(savedScrollTop) && savedScrollTop >= 0) {
                sidebarContainer.scrollTop = savedScrollTop;
            }

            const persistScroll = () => {
                localStorage.setItem(storageKey, String(sidebarContainer.scrollTop));
            };

            sidebarContainer.addEventListener('scroll', persistScroll, { passive: true });

            sidebarContainer.addEventListener('click', () => {
                setTimeout(persistScroll, 0);
            });

            window.addEventListener('beforeunload', persistScroll);
        })();
    </script>

    <script>
        (() => {
            const timeElem = document.getElementById('topbarTime');
            const dateElem = document.getElementById('topbarDate');
            if (!timeElem || !dateElem) {
                return;
            }

            const toPersianDigits = (value) => String(value).replace(/\d/g, (digit) => '۰۱۲۳۴۵۶۷۸۹'[Number(digit)]);

            const updateClockAndDate = () => {
                const now = new Date();

                timeElem.textContent = now.toLocaleTimeString('fa-IR', {
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    hour12: false
                });

                const dateParts = new Intl.DateTimeFormat('fa-IR-u-ca-persian', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit'
                }).formatToParts(now);

                const year = dateParts.find((item) => item.type === 'year')?.value ?? '';
                const month = dateParts.find((item) => item.type === 'month')?.value ?? '';
                const day = dateParts.find((item) => item.type === 'day')?.value ?? '';

                dateElem.textContent = `${toPersianDigits(year)}/${toPersianDigits(month)}/${toPersianDigits(day)}`;
            };

            updateClockAndDate();
            setInterval(updateClockAndDate, 1000);
        })();
    </script>

    <script>
        (() => {
            const input = document.getElementById('sidebarMenuSearch');
            const clearButton = document.getElementById('sidebarSearchClear');
            const countLabel = document.getElementById('sidebarSearchCount');
            const noResults = document.getElementById('sidebarSearchNoResults');
            const sidebarContainer = document.getElementById('sidebarScrollContainer');
            const accordion = document.getElementById('sidebarAccordion');

            if (!input || !clearButton || !countLabel || !noResults || !sidebarContainer) {
                return;
            }

            const normalize = (value) => String(value || '')
                .replace(/[ي]/g, 'ی')
                .replace(/[ك]/g, 'ک')
                .replace(/\s+/g, ' ')
                .trim()
                .toLocaleLowerCase('fa-IR');

            const links = Array.from(sidebarContainer.querySelectorAll('a.sidebar-link'));
            const groups = Array.from(sidebarContainer.querySelectorAll('.sidebar-accordion .accordion-item'));

            groups.forEach((group) => {
                const collapse = group.querySelector('.accordion-collapse');
                if (collapse) {
                    collapse.dataset.initialShow = collapse.classList.contains('show') ? '1' : '0';
                }
            });

            const setCollapseVisible = (collapse, visible) => {
                if (!collapse) {
                    return;
                }

                collapse.classList.toggle('show', visible);
                const button = document.querySelector(`[data-bs-target="#${collapse.id}"]`);
                if (button) {
                    button.classList.toggle('collapsed', !visible);
                    button.setAttribute('aria-expanded', String(visible));
                }
            };

            const resetSearch = () => {
                links.forEach((link) => link.classList.remove('sidebar-search-hidden'));
                groups.forEach((group) => {
                    group.classList.remove('sidebar-search-hidden');
                    const collapse = group.querySelector('.accordion-collapse');
                    if (collapse) {
                        setCollapseVisible(collapse, collapse.dataset.initialShow === '1');
                    }
                });
                noResults.classList.remove('is-visible');
                clearButton.classList.add('d-none');
                countLabel.textContent = 'همه بخش‌ها';
            };

            const applySearch = () => {
                const query = normalize(input.value);
                if (!query) {
                    resetSearch();
                    return;
                }

                let matchCount = 0;

                links.forEach((link) => {
                    const text = normalize(link.textContent);
                    const matches = text.includes(query);
                    link.classList.toggle('sidebar-search-hidden', !matches);
                    if (matches) {
                        matchCount += 1;
                    }
                });

                groups.forEach((group) => {
                    const headerText = normalize(group.querySelector('.accordion-button')?.textContent);
                    const groupLinks = Array.from(group.querySelectorAll('a.sidebar-link'));
                    const headerMatches = headerText.includes(query);
                    const hasVisibleLink = groupLinks.some((link) => !link.classList.contains('sidebar-search-hidden'));

                    if (headerMatches) {
                        groupLinks.forEach((link) => link.classList.remove('sidebar-search-hidden'));
                        matchCount += groupLinks.filter((link) => !normalize(link.textContent).includes(query)).length;
                    }

                    const showGroup = headerMatches || hasVisibleLink;
                    group.classList.toggle('sidebar-search-hidden', !showGroup);
                    setCollapseVisible(group.querySelector('.accordion-collapse'), showGroup);
                });

                noResults.classList.toggle('is-visible', matchCount === 0);
                clearButton.classList.remove('d-none');
                countLabel.textContent = matchCount === 0
                    ? 'بدون نتیجه'
                    : `${matchCount.toLocaleString('fa-IR')} نتیجه`;
            };

            input.addEventListener('input', applySearch);

            clearButton.addEventListener('click', () => {
                input.value = '';
                input.focus();
                resetSearch();
            });

            document.addEventListener('keydown', (event) => {
                if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
                    event.preventDefault();
                    input.focus();
                    input.select();
                    sidebarContainer.scrollTop = 0;
                }

                if (event.key === 'Escape' && document.activeElement === input) {
                    input.value = '';
                    resetSearch();
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
