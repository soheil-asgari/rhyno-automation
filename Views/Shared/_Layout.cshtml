@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using OfficeAutomation.Data
@inject ApplicationDbContext DbContext
@{
    var displayName = User?.FindFirst("name")?.Value
                      ?? User?.FindFirst(ClaimTypes.Name)?.Value
                      ?? User?.Identity?.Name;
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = "کاربر";
    }

    var userRoleLabel = "کاربر سیستم";
    if (User?.Identity?.IsAuthenticated == true)
    {
        if (User.IsInRole("Admin"))
        {
            userRoleLabel = "مدیر سیستم";
        }
        else
        {
            var roleClaim = User.FindFirst(ClaimTypes.Role)?.Value
                            ?? User.FindFirst("role")?.Value;

            if (!string.IsNullOrWhiteSpace(roleClaim))
            {
                userRoleLabel = roleClaim;
            }
        }
    }

    var themePreference = "System";
    if (User?.Identity?.IsAuthenticated == true)
    {
        var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(currentUserId))
        {
            var savedTheme = await DbContext.UserPreferences
                .AsNoTracking()
                .Where(preference => preference.UserId == currentUserId)
                .Select(preference => preference.ThemePreference)
                .FirstOrDefaultAsync();

            if (string.Equals(savedTheme, "Light", StringComparison.OrdinalIgnoreCase))
            {
                themePreference = "Light";
            }
            else if (string.Equals(savedTheme, "Dark", StringComparison.OrdinalIgnoreCase))
            {
                themePreference = "Dark";
            }
        }
    }

    var rootThemeClass = string.Equals(themePreference, "Dark", StringComparison.OrdinalIgnoreCase)
        ? "theme-dark"
        : "theme-light";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var userCanAccessFinance = true;
    var userCanAccessWarehouse = true;
    var userCanAccessHumanCapital = true;
    var userCanAccessSystemSettings = true;
    var userCanAccessWorkflowAdministration = true;
    if (User?.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
    {
        var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(currentUserId))
        {
            var permission = await DbContext.Users
                .AsNoTracking()
                .Where(item => item.Id == currentUserId)
                .Select(item => new
                {
                    item.CanAccessFinance,
                    item.CanAccessWarehouse,
                    item.CanAccessHumanCapital,
                    item.CanAccessSystemSettings
                })
                .FirstOrDefaultAsync();

            if (permission != null)
            {
                userCanAccessFinance = permission.CanAccessFinance;
                userCanAccessWarehouse = permission.CanAccessWarehouse;
                userCanAccessHumanCapital = permission.CanAccessHumanCapital;
                userCanAccessSystemSettings = permission.CanAccessSystemSettings;
                userCanAccessWorkflowAdministration = permission.CanAccessSystemSettings;
            }

            var roleIds = await DbContext.UserRoles
                .AsNoTracking()
                .Where(item => item.UserId == currentUserId)
                .Select(item => item.RoleId)
                .ToListAsync();

            if (roleIds.Count > 0)
            {
                var rolePermissions = await DbContext.RolePermissions
                    .AsNoTracking()
                    .Where(item => roleIds.Contains(item.RoleId))
                    .ToListAsync();

                bool? ResolvePermission(string key) => rolePermissions
                    .Where(item => item.PermissionKey == key)
                    .OrderByDescending(item => item.Id)
                    .Select(item => (bool?)item.IsAllowed)
                    .FirstOrDefault();

                userCanAccessFinance = ResolvePermission("Finance") ?? userCanAccessFinance;
                userCanAccessWarehouse = ResolvePermission("Warehouse") ?? userCanAccessWarehouse;
                userCanAccessHumanCapital = ResolvePermission("HumanCapital") ?? userCanAccessHumanCapital;
                userCanAccessSystemSettings = ResolvePermission("SystemSettings") ?? userCanAccessSystemSettings;
                userCanAccessWorkflowAdministration = ResolvePermission("WorkflowAdministration") ?? userCanAccessWorkflowAdministration;
            }
        }
    }
}
<!DOCTYPE html>
<html lang="fa" dir="rtl" data-theme="@themePreference.ToLowerInvariant()" class="@rootThemeClass">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل مدیریت راینو</title>

    <script src="https://lib.arvancloud.ir/sweetalert2/9.17.4/sweetalert2.all.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <link rel="stylesheet" href="https://lib.arvancloud.ir/bootstrap/5.3.0-alpha1/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://lib.arvancloud.ir/bootstrap-icons/1.9.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.9.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true">

    <style>
        /* فیکس کردن ارتفاع بدنه و اسکرول سایدبار */
        body {
            background-color: #f8fafc;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            overflow-y: auto;
        }

        .app-shell {
            display: flex;
            height: auto;
            min-height: 100vh;
            overflow: visible;
        }

        /* استایل سایدبار راست با اسکرول فعال مستقل */
        .sidebar-right {
            display: flex;
            flex-direction: column;
            height: 100vh;
            position: fixed;
            top: 0;
            right: 0;
            width: 260px;
            background-color: #fff;
            border-left: 1px solid #e2e8f0;
            z-index: 1030;
        }

        #appSidebar i,
        #appSidebar .bi,
        .custom-topbar i,
        .custom-topbar .bi {
            background: transparent !important;
            background-color: transparent !important;
            background-image: none !important;
            box-shadow: none !important;
            border-radius: 6px !important;
            line-height: 1;
        }

        .logo-icon,
        .user-avatar-box {
            background: transparent !important;
            background-color: transparent !important;
            background-image: none !important;
            box-shadow: none !important;
            border: 1px solid #e2e8f0;
            color: #4f46e5;
        }

        .sidebar-content {
            flex: 1;
            min-height: 0;
            overflow-y: auto;
            padding: 12px;
            overscroll-behavior: contain;
        }

            .sidebar-content::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-content::-webkit-scrollbar-thumb {
                background-color: #cbd5e1;
                border-radius: 6px !important;
            }

        /* نوار بالای صفحه همرنگ بدنه (بدون حاشیه اضافی) */
        .custom-topbar {
            background-color: #f8fafc;
            padding: 16px 24px;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            align-items: center;
            gap: 16px;
            min-height: 72px;
            overflow: visible;
        }

        .topbar-cluster,
        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
            white-space: nowrap;
        }

        .topbar-right-info {
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 0.8rem;
            color: #64748b;
        }

        .status-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 6px !important;
            margin-left: 4px;
        }

        .topbar-clock-box {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            font-weight: 600;
            color: #334155;
            background: #fff;
            padding: 6px 14px;
            border-radius: 6px !important;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            flex: 0 0 auto;
            white-space: nowrap;
        }

        .topbar-search {
            position: relative;
            width: min(260px, 28vw);
            min-width: 180px;
            flex: 0 1 260px;
        }

        .sidebar-quick-search {
            position: sticky;
            top: 0;
            z-index: 2;
            background: #fff;
            padding-bottom: 10px;
            margin-bottom: 8px;
        }

        .sidebar-quick-search .search-box {
            position: relative;
        }

        .sidebar-quick-search .form-control {
            height: 38px;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            color: #0f172a;
            font-size: .78rem;
            font-weight: 700;
            padding-right: 32px;
        }

        .sidebar-quick-search .form-control:focus {
            border-color: #6366f1;
            background: #fff;
            box-shadow: 0 0 0 .18rem rgba(99, 102, 241, .14);
        }

        .sidebar-quick-search .bi-search {
            position: absolute;
            right: 10px;
            top: 10px;
            color: #94a3b8;
            font-size: .82rem;
            pointer-events: none;
        }

        .sidebar-search-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            margin-top: 7px;
            color: #64748b;
            font-size: .7rem;
            font-weight: 800;
        }

        .sidebar-search-clear {
            border: 0;
            background: transparent;
            color: #4f46e5;
            padding: 0;
            font-size: .7rem;
            font-weight: 850;
        }

        .sidebar-search-clear.d-none {
            display: none !important;
        }

        .sidebar-search-hidden {
            display: none !important;
        }

        .sidebar-search-no-results {
            display: none;
            border: 1px dashed #cbd5e1;
            background: #f8fafc;
            color: #64748b;
            border-radius: 6px !important;
            padding: 10px;
            font-size: .76rem;
            font-weight: 750;
            line-height: 1.7;
        }

        .sidebar-search-no-results.is-visible {
            display: block;
        }

        .main-wrapper {
            margin-right: 260px;
            flex: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: visible;
        }

        .sidebar-accordion .accordion-item {
            border: 0;
            border-radius: 6px !important;
            overflow: visible;
            background: transparent;
            margin-bottom: 6px;
        }

        .sidebar-accordion .accordion-button {
            background: #f8fafc;
            color: #334155;
            font-size: 0.78rem;
            font-weight: 700;
            padding: 8px 10px;
            box-shadow: none;
            border-radius: 6px !important;
        }

            .sidebar-accordion .accordion-button:not(.collapsed) {
                background: #eef2ff;
                color: #312e81;
            }

            .sidebar-accordion .accordion-button::after {
                width: 0.8rem;
                height: 0.8rem;
                background-size: 0.8rem;
            }

        .sidebar-group-nav {
            padding: 6px 0 2px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 6px;
            border-radius: 6px !important;
            font-size: 0.76rem;
            color: #334155;
            padding: 7px 10px;
        }

            .sidebar-link:hover {
                background: #f1f5f9;
                color: #1e293b;
            }

            .sidebar-link.sidebar-active {
                background: var(--glass-bg);
                color: var(--primary);
                font-weight: 700;
            }

        .user-profile-link .user-profile-pill {
            transition: background-color 0.2s ease;
        }

        .sidebar-footer {
            flex: 0 0 auto;
            margin-top: auto;
            padding: 0;
            border-top: 1px solid #f1f5f9;
            background: #fff;
        }

        .user-profile-link {
            display: block;
            text-decoration: none;
            color: inherit;
            cursor: pointer;
        }

        .user-profile-pill {
            padding: 12px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            background: #fff;
            border-radius: 6px !important;
        }

        .user-avatar-box {
            width: 34px;
            height: 34px;
            background: transparent;
            border-radius: 6px !important;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .online-status {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 9px;
            height: 9px;
            background: #10b981;
            border: 2px solid #fff;
            border-radius: 6px !important;
        }

        #appSidebar,
        #appSidebar *,
        .main-wrapper,
        .custom-topbar,
        .topbar-clock-box,
        .topbar-search .form-control,
        .topbar-actions .btn,
        #main-content-wrapper,
        #main-content-wrapper .card,
        #main-content-wrapper .btn,
        #main-content-wrapper .form-control,
        #main-content-wrapper .form-select,
        #main-content-wrapper textarea,
        #main-content-wrapper select,
        #main-content-wrapper input,
        button,
        .btn,
        .card,
        input,
        select,
        textarea,
        #main-content-wrapper .badge,
        #main-content-wrapper .modal-content {
            border-radius: 6px !important;
        }

        .user-profile-link:hover .user-profile-pill,
        .user-profile-link:focus-visible .user-profile-pill {
            background-color: #f8fafc;
        }

        #main-content-wrapper,
        #main-content-wrapper table,
        #main-content-wrapper .table,
        #main-content-wrapper .table th,
        #main-content-wrapper .table td,
        #main-content-wrapper .table th *,
        #main-content-wrapper .table td *,
        #main-content-wrapper .grid,
        #main-content-wrapper .matrix {
            color: var(--text-dark) !important;
        }
    </style>
    <style>
        html.theme-dark body,
        html.dark-mode body,
        html[data-theme="dark"] body {
            background-color: #0f172a !important;
            color: #f8fafc !important;
        }

        html.theme-dark .app-shell,
        html.theme-dark .main-wrapper,
        html.theme-dark .main-content,
        html.dark-mode .app-shell,
        html.dark-mode .main-wrapper,
        html.dark-mode .main-content,
        html[data-theme="dark"] .app-shell,
        html[data-theme="dark"] .main-wrapper,
        html[data-theme="dark"] .main-content {
            background-color: #0f172a !important;
            color: #f8fafc !important;
        }

        html.theme-dark .custom-topbar,
        html.theme-dark .topbar-clock-box,
        html.theme-dark .sidebar-right,
        html.theme-dark .user-profile-pill,
        html.dark-mode .custom-topbar,
        html.dark-mode .topbar-clock-box,
        html.dark-mode .sidebar-right,
        html.dark-mode .user-profile-pill,
        html[data-theme="dark"] .custom-topbar,
        html[data-theme="dark"] .topbar-clock-box,
        html[data-theme="dark"] .sidebar-right,
        html[data-theme="dark"] .user-profile-pill {
            background-color: #111827 !important;
            border-color: #334155 !important;
            color: #f8fafc !important;
        }

        html.theme-dark .sidebar-accordion .accordion-button,
        html.dark-mode .sidebar-accordion .accordion-button,
        html[data-theme="dark"] .sidebar-accordion .accordion-button {
            background: #1f2937 !important;
            color: #f8fafc !important;
        }

        html.theme-dark .sidebar-quick-search,
        html.dark-mode .sidebar-quick-search,
        html[data-theme="dark"] .sidebar-quick-search {
            background: #111827 !important;
        }

        html.theme-dark .sidebar-quick-search .form-control,
        html.dark-mode .sidebar-quick-search .form-control,
        html[data-theme="dark"] .sidebar-quick-search .form-control {
            background: #0f172a !important;
            border-color: #334155 !important;
            color: #f8fafc !important;
        }

        html.theme-dark .sidebar-search-meta,
        html.theme-dark .sidebar-search-no-results,
        html.dark-mode .sidebar-search-meta,
        html.dark-mode .sidebar-search-no-results,
        html[data-theme="dark"] .sidebar-search-meta,
        html[data-theme="dark"] .sidebar-search-no-results {
            color: #cbd5e1 !important;
        }

        html.theme-dark .sidebar-search-no-results,
        html.dark-mode .sidebar-search-no-results,
        html[data-theme="dark"] .sidebar-search-no-results {
            background: #0f172a !important;
            border-color: #334155 !important;
        }

            html.theme-dark .sidebar-accordion .accordion-button:not(.collapsed),
            html.dark-mode .sidebar-accordion .accordion-button:not(.collapsed),
            html[data-theme="dark"] .sidebar-accordion .accordion-button:not(.collapsed) {
                background: #312e81 !important;
                color: #f8fafc !important;
            }

        html.theme-dark .sidebar-link,
        html.dark-mode .sidebar-link,
        html[data-theme="dark"] .sidebar-link {
            color: #f1f5f9 !important;
        }

            html.theme-dark .sidebar-link:hover,
            html.theme-dark .sidebar-link.sidebar-active,
            html.dark-mode .sidebar-link:hover,
            html.dark-mode .sidebar-link.sidebar-active,
            html[data-theme="dark"] .sidebar-link:hover,
            html[data-theme="dark"] .sidebar-link.sidebar-active {
                background: var(--glass-bg) !important;
                color: #f8fafc !important;
            }

        html.theme-dark .main-content,
        html.dark-mode .main-content,
        html[data-theme="dark"] .main-content {
            background-color: #0f172a !important;
        }

        html.theme-dark .logo-icon,
        html.theme-dark .user-avatar-box,
        html.dark-mode .logo-icon,
        html.dark-mode .user-avatar-box,
        html[data-theme="dark"] .logo-icon,
        html[data-theme="dark"] .user-avatar-box {
            background: transparent !important;
            background-color: transparent !important;
            border-color: #334155 !important;
            color: #f8fafc !important;
        }

        html.theme-dark,
        html.theme-dark body,
        html.theme-dark #main-content-wrapper,
        html.theme-dark #main-content-wrapper *,
        html.theme-dark .custom-topbar,
        html.theme-dark .custom-topbar *,
        html.theme-dark #appSidebar,
        html.theme-dark #appSidebar *,
        html.dark-mode,
        html.dark-mode body,
        html.dark-mode #main-content-wrapper,
        html.dark-mode #main-content-wrapper *,
        html.dark-mode .custom-topbar,
        html.dark-mode .custom-topbar *,
        html.dark-mode #appSidebar,
        html.dark-mode #appSidebar *,
        html[data-theme="dark"],
        html[data-theme="dark"] body,
        html[data-theme="dark"] #main-content-wrapper,
        html[data-theme="dark"] #main-content-wrapper *,
        html[data-theme="dark"] .custom-topbar,
        html[data-theme="dark"] .custom-topbar *,
        html[data-theme="dark"] #appSidebar,
        html[data-theme="dark"] #appSidebar * {
            color: #f8fafc !important;
        }

        html.theme-dark .text-muted,
        html.theme-dark .text-secondary,
        html.theme-dark .text-dark,
        html.theme-dark .brand-status,
        html.theme-dark .u-role,
        html.dark-mode .text-muted,
        html.dark-mode .text-secondary,
        html.dark-mode .text-dark,
        html.dark-mode .brand-status,
        html.dark-mode .u-role,
        html[data-theme="dark"] .text-muted,
        html[data-theme="dark"] .text-secondary,
        html[data-theme="dark"] .text-dark,
        html[data-theme="dark"] .brand-status,
        html[data-theme="dark"] .u-role {
            color: #f1f5f9 !important;
        }

        html.theme-dark i,
        html.theme-dark .bi,
        html.dark-mode i,
        html.dark-mode .bi,
        html[data-theme="dark"] i,
        html[data-theme="dark"] .bi {
            color: #f8fafc !important;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>

<body data-theme="@themePreference.ToLowerInvariant()">
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <form id="rhGlobalAntiForgery" class="d-none">@Html.AntiForgeryToken()</form>

    <div class="app-shell">

        <aside class="sidebar-right" id="appSidebar">
            <div class="sidebar-header" style="padding: 20px 15px; border-bottom: 1px solid #f1f5f9;">
                <div class="logo-wrapper" style="display: flex; align-items: center; gap: 10px;">
                    <div class="logo-icon" style="background: transparent; color:#4f46e5; padding: 6px 10px; border-radius: 6px !important;">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div class="logo-text">
                        <span class="brand-name" style="display:block; font-weight:bold; font-size:0.95rem;">پنل راینو</span>
                        <span class="brand-status" style="font-size:0.75rem; color:#64748b;">نسخه سازمانی 2026</span>
                    </div>
                </div>
            </div>

            <div class="sidebar-content" id="sidebarScrollContainer">
                <div class="sidebar-quick-search">
                    <div class="search-box">
                        <input id="sidebarMenuSearch" type="search" class="form-control" autocomplete="off" placeholder="جستجوی سریع منو... (Ctrl+K)" aria-label="جستجوی سریع منو">
                        <i class="bi bi-search"></i>
                    </div>
                    <div class="sidebar-search-meta">
                        <span id="sidebarSearchCount">همه بخش‌ها</span>
                        <button id="sidebarSearchClear" type="button" class="sidebar-search-clear d-none">پاک کردن</button>
                    </div>
                </div>

                <div id="sidebarSearchNoResults" class="sidebar-search-no-results">
                    نتیجه‌ای در منو پیدا نشد.
                </div>

                <div class="mb-2">
                    <a class="nav-link sidebar-link @(currentController == "Home" ? "sidebar-active" : "")" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid text-primary"></i> <span class="link-text">میز کار مرکزی</span>
                    </a>
                </div>

                <div class="accordion sidebar-accordion" id="sidebarAccordion">
                    @if (userCanAccessHumanCapital || User.IsInRole("Admin"))
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingHumanCapital">
                                <button class="accordion-button @((currentController == "HumanCapital" || currentController == "Leaves" || currentController == "Letters") ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#collapseHumanCapital" aria-expanded="true" aria-controls="collapseHumanCapital">
                                    سرمایه انسانی
                                </button>
                            </h2>
                            <div id="collapseHumanCapital" class="accordion-collapse collapse @((currentController == "HumanCapital" || currentController == "Leaves" || currentController == "Letters") ? "show" : "")" aria-labelledby="headingHumanCapital" data-bs-parent="#sidebarAccordion">
                                <div class="accordion-body py-1 px-0">
                                    <nav class="nav flex-column sidebar-group-nav">
                                        <a class="nav-link sidebar-link @(currentController == "HumanCapital" ? "sidebar-active" : "")" asp-controller="HumanCapital" asp-action="Index"><i class="bi bi-people text-warning"></i> <span class="link-text">سرمایه انسانی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Leaves" ? "sidebar-active" : "")" asp-controller="Leaves" asp-action="Index"><i class="bi bi-calendar-check text-success"></i> <span class="link-text">درخواست مرخصی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Letters" ? "sidebar-active" : "")" asp-controller="Letters" asp-action="Index"><i class="bi bi-envelope-paper text-danger"></i> <span class="link-text">مدیریت نامه‌ها</span></a>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    }

                    @if (userCanAccessFinance || User.IsInRole("Admin"))
                    {
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="headingFinancial">
