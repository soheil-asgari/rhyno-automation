                                        <a class="nav-link sidebar-link @(currentController == "DocumentArchive" ? "sidebar-active" : "")" asp-controller="DocumentArchive" asp-action="Index"><i class="bi bi-archive text-warning"></i> <span class="link-text">بایگانی اسناد</span></a>

                    @if (userHasSecurityAccess)
                                        {
                                            <a class="nav-link sidebar-link @(currentController == "Security" ? "sidebar-active" : "")" asp-controller="Security" asp-action="Index"><i class="bi bi-shield-check text-danger"></i> <span class="link-text">مرکز امنیت</span></a>
                                        }
                                        <a class="nav-link sidebar-link @(currentController == "AiAssistant" ? "sidebar-active" : "")" asp-controller="AiAssistant" asp-action="Index"><i class="bi bi-cpu text-info"></i> <span class="link-text">دستیار هوش مصنوعی</span></a>
                                        <a class="nav-link sidebar-link @(currentController == "Waybill" ? "sidebar-active" : "")" asp-controller="Waybill" asp-action="Index"><i class="bi bi-truck text-warning"></i> <span class="link-text">ثبت بارنامه</span></a>
                                    </nav>
                                </div>
                            </div>
                        </div>
                    }
                            </div>
                        </div>
                    </section>
                </div>

                <div class="sidebar-fixed-bottom">
                    <section class="sidebar-section">
                        <div class="sidebar-section-head">
                            <span>صفحات پرکاربرد</span>
                            <small>پرمراجعه</small>
                        </div>
                        <nav class="nav flex-column sidebar-dynamic-nav" id="frequentPagesNav">
                            <span class="sidebar-empty-state">هنوز داده‌ای ثبت نشده است.</span>
                        </nav>
                    </section>

                    <section class="sidebar-section">
                        <div class="sidebar-section-head">
                            <span>آخرین بازدیدها</span>
                            <small>دسترسی اخیر</small>
                        </div>
                        <nav class="nav flex-column sidebar-dynamic-nav" id="recentPagesNav">
                            <span class="sidebar-empty-state">هنوز صفحه‌ای ثبت نشده است.</span>
                        </nav>
                    </section>
                </div>
            </div>

            <div class="sidebar-footer">
                <a asp-controller="Settings" asp-action="Index" class="user-profile-link">
                    <div class="user-profile-pill">
                            <div class="user-avatar" >
                            <div class="user-avatar-box"><i class="bi bi-person-fill text-secondary"></i></div>
                            <span class="online-status"></span>
                            </div>
                            <div class="user-info" >
                                <span class="u-name" >تنظیمات سامانه</span>
                                <span class="u-role" >@displayName - @userRoleLabel</span>
                            </div>
                        </div>
                    </a>
            </div>
        </aside>

        <div class="main-wrapper">

            <header class="custom-topbar">
                <div class="topbar-cluster">
                    <div class="topbar-clock-box">
                        <i class="bi bi-clock-history text-primary"></i>
                        <span id="topbarTime">--:--:--</span>
                        <span class="topbar-divider">|</span>
                        <span id="topbarDate">۱۴۰۵/۰۲/۲۷</span>
                    </div>

                    @* <form asp-controller="Search" asp-action="Index" method="get" class="topbar-search d-none d-md-flex" role="search">
                        <i class="bi bi-search"></i>
                        <input name="q" class="form-control form-control-sm" value="@(Context.Request.Query["q"].ToString())" autocomplete="off" placeholder="جستجوی کل سیستم..." />
                    </form> *@
                </div>

                <div class="topbar-actions">
                    <div class="dropdown notification-center">
                        <button class="notification-toggle" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" title="اعلان‌ها">
                            <i class="bi bi-bell"></i>
                            @if (headerNotificationCount > 0)
                            {
                                <span class="notification-count">@headerNotificationCount.ToString("N0")</span>
                            }
                        </button>
                        <div class="dropdown-menu dropdown-menu-start notification-menu">
                            <div class="notification-menu-head">
                                <strong>مرکز اعلان‌ها</strong>
                                <span>@headerNotificationCount.ToString("N0") اعلان</span>
                            </div>
                            @if (headerNotifications.Count == 0)
                            {
                                <div class="notification-empty">اعلان مهمی برای نمایش وجود ندارد.</div>
                            }
                            else
                            {
                                foreach (var notification in headerNotifications.Take(8))
                                {
                                    <a class="notification-item" href="@notification.Url">
                                        <i class="bi @notification.Icon text-@notification.Tone"></i>
                                        <span>
                                            <strong>@notification.Title</strong>
                                            <small>@notification.Message</small>
                                        </span>
                                    </a>
                                }
                            }
                            <a class="notification-item" href="/Notifications">
                                <i class="bi bi-list-check text-secondary"></i>
                                <span>
                                    <strong>مشاهده همه اعلان‌ها</strong>
                                    <small>مرکز اعلان‌ها و وضعیت خوانده‌شدن</small>
                                </span>
                            </a>
                        </div>
                    </div>
                    <div class="topbar-right-info d-none d-lg-flex">
                        <span><span class="status-dot status-dot-success"></span> سرور: <span class="fw-bold text-success">فعال</span></span>
                        <span><span class="status-dot status-dot-info"></span> دیتابیس: <span class="fw-bold text-info">متصل</span></span>
                    </div>
                    <button class="btn btn-primary btn-sm topbar-new-request">
                        <i class="bi bi-plus-lg me-1"></i> درخواست جدید
                    </button>
                </div>
            </header>

            <main id="main-content-wrapper" class="px-3 py-3">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/layout.js" asp-append-version="true"></script>
    <script src="~/js/professional-table.js" asp-append-version="true"></script>
    <script>
        (() => {
            const html = document.documentElement;
            const storedPreference = localStorage.getItem('rhyno.theme.preference');
            const fallbackPreference = '@themePreference';
            const activePreference = storedPreference || fallbackPreference;
            const normalized = (activePreference || 'System').toLowerCase();

            html.classList.remove('theme-light', 'theme-dark');
            html.setAttribute('data-theme', normalized);
            document.body?.setAttribute('data-theme', normalized);

            if (normalized === 'light') {
                html.classList.add('theme-light');
                window.dispatchEvent(new Event('themechange'));
                return;
            }

            if (normalized === 'dark') {
                html.classList.add('theme-dark');
                window.dispatchEvent(new Event('themechange'));
                return;
            }

            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            html.classList.add(prefersDark ? 'theme-dark' : 'theme-light');
            window.dispatchEvent(new Event('themechange'));
        })();
    </script>
    <script>
        (() => {
            const sidebarContainer = document.getElementById('sidebarScrollContainer');
            if (!sidebarContainer) {
                return;
            }

            const storageKey = 'rhyno.sidebar.scrollTop';

            const savedRaw = localStorage.getItem(storageKey);
            const savedScrollTop = Number(savedRaw);
            if (Number.isFinite(savedScrollTop) && savedScrollTop >= 0) {
                sidebarContainer.scrollTop = savedScrollTop;
            }

            const persistScroll = () => {
                localStorage.setItem(storageKey, String(sidebarContainer.scrollTop));
            };

            sidebarContainer.addEventListener('scroll', persistScroll, { passive: true });

            sidebarContainer.addEventListener('click', () => {
                setTimeout(persistScroll, 0);
            });

            window.addEventListener('beforeunload', persistScroll);
        })();
    </script>

    <script>
        (() => {
            const timeElem = document.getElementById('topbarTime');
            const dateElem = document.getElementById('topbarDate');
            if (!timeElem || !dateElem) {
                return;
            }

            const toPersianDigits = (value) => String(value).replace(/\d/g, (digit) => '۰۱۲۳۴۵۶۷۸۹'[Number(digit)]);

            const updateClockAndDate = () => {
                const now = new Date();

                timeElem.textContent = now.toLocaleTimeString('fa-IR', {
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    hour12: false
                });

                const dateParts = new Intl.DateTimeFormat('fa-IR-u-ca-persian', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit'
                }).formatToParts(now);

                const year = dateParts.find((item) => item.type === 'year')?.value ?? '';
                const month = dateParts.find((item) => item.type === 'month')?.value ?? '';
                const day = dateParts.find((item) => item.type === 'day')?.value ?? '';

                dateElem.textContent = `${toPersianDigits(year)}/${toPersianDigits(month)}/${toPersianDigits(day)}`;
            };

            updateClockAndDate();
            setInterval(updateClockAndDate, 1000);
        })();
    </script>

    <script>
        (() => {
            const input = document.getElementById('sidebarMenuSearch');
            const clearButton = document.getElementById('sidebarSearchClear');
            const countLabel = document.getElementById('sidebarSearchCount');
            const noResults = document.getElementById('sidebarSearchNoResults');
            const sidebarContainer = document.getElementById('sidebarScrollContainer');
            const accordion = document.getElementById('sidebarAccordion');

            if (!input || !clearButton || !countLabel || !noResults || !sidebarContainer) {
                return;
            }

            const normalize = (value) => String(value || '')
                .replace(/[ي]/g, 'ی')
                .replace(/[ك]/g, 'ک')
                .replace(/\s+/g, ' ')
                .trim()
                .toLocaleLowerCase('fa-IR');

            const links = Array.from(sidebarContainer.querySelectorAll('a.sidebar-link'));
            const groups = Array.from(sidebarContainer.querySelectorAll('.sidebar-accordion .accordion-item'));

            groups.forEach((group) => {
                const collapse = group.querySelector('.accordion-collapse');
                if (collapse) {
                    collapse.dataset.initialShow = collapse.classList.contains('show') ? '1' : '0';
                }
            });

            const setCollapseVisible = (collapse, visible) => {
                if (!collapse) {
                    return;
                }

                collapse.classList.toggle('show', visible);
                const button = document.querySelector(`[data-bs-target="#${collapse.id}"]`);
                if (button) {
                    button.classList.toggle('collapsed', !visible);
                    button.setAttribute('aria-expanded', String(visible));
                }
            };

            const resetSearch = () => {
                links.forEach((link) => link.classList.remove('sidebar-search-hidden'));
                groups.forEach((group) => {
                    group.classList.remove('sidebar-search-hidden');
                    const collapse = group.querySelector('.accordion-collapse');
                    if (collapse) {
                        setCollapseVisible(collapse, collapse.dataset.initialShow === '1');
                    }
                });
                noResults.classList.remove('is-visible');
                clearButton.classList.add('d-none');
                countLabel.textContent = 'همه بخش‌ها';
            };

            const applySearch = () => {
                const query = normalize(input.value);
                if (!query) {
                    resetSearch();
                    return;
                }

                let matchCount = 0;

                links.forEach((link) => {
                    const text = normalize(link.textContent);
                    const matches = text.includes(query);
                    link.classList.toggle('sidebar-search-hidden', !matches);
                    if (matches) {
                        matchCount += 1;
                    }
                });

                groups.forEach((group) => {
                    const headerText = normalize(group.querySelector('.accordion-button')?.textContent);
                    const groupLinks = Array.from(group.querySelectorAll('a.sidebar-link'));
                    const headerMatches = headerText.includes(query);
                    const hasVisibleLink = groupLinks.some((link) => !link.classList.contains('sidebar-search-hidden'));

                    if (headerMatches) {
                        groupLinks.forEach((link) => link.classList.remove('sidebar-search-hidden'));
                        matchCount += groupLinks.filter((link) => !normalize(link.textContent).includes(query)).length;
                    }

                    const showGroup = headerMatches || hasVisibleLink;
                    group.classList.toggle('sidebar-search-hidden', !showGroup);
                    setCollapseVisible(group.querySelector('.accordion-collapse'), showGroup);
                });

                noResults.classList.toggle('is-visible', matchCount === 0);
                clearButton.classList.remove('d-none');
                countLabel.textContent = matchCount === 0
                    ? 'بدون نتیجه'
                    : `${matchCount.toLocaleString('fa-IR')} نتیجه`;
            };

            input.addEventListener('input', applySearch);

            clearButton.addEventListener('click', () => {
                input.value = '';
                input.focus();
                resetSearch();
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape' && document.activeElement === input) {
                    input.value = '';
                    resetSearch();
                }
            });
        })();
    </script>

    <div class="modal fade" id="appConfirmDialog" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content app-confirm-dialog">
                <div class="modal-header">
                    <h5 class="modal-title">تایید عملیات</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="appConfirmMessage" class="mb-0">آیا مطمئن هستید؟</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">لغو</button>
                    <button type="button" class="btn btn-danger" id="appConfirmOk">تایید</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="appCommandPalette" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content command-palette">
                <div class="command-palette-head">
                    <i class="bi bi-command"></i>
                    <input id="appCommandInput" type="search" autocomplete="off" placeholder="جستجوی فرمان، صفحه یا گزارش..." aria-label="جستجوی فرمان">
                    <kbd>Ctrl K</kbd>
                </div>
                <div id="appCommandList" class="command-palette-list"></div>
                <div class="command-palette-foot">Enter برای اجرا، Esc برای بستن</div>
            </div>
        </div>
    </div>

    <script>
        (() => {
            const frequentNav = document.getElementById('frequentPagesNav');
            const recentNav = document.getElementById('recentPagesNav');
            const trackedLinks = Array.from(document.querySelectorAll('a.sidebar-link[data-nav-id]'));
            if (!frequentNav || !recentNav || trackedLinks.length === 0) {
                return;
            }

            const recentKey = 'rhyno.sidebar.recent';
            const usageKey = 'rhyno.sidebar.usage';
            const maxItems = 6;

            const catalog = new Map(trackedLinks.map((link) => [link.dataset.navId, {
                id: link.dataset.navId,
                href: link.getAttribute('href') || '#',
                iconClass: link.querySelector('i')?.className || 'bi bi-file-earmark',
                text: (link.querySelector('.link-text')?.textContent || link.textContent || '').trim(),
                active: link.classList.contains('sidebar-active')
            }]));

            const readState = (key, fallback) => {
                try {
                    return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback));
                } catch {
                    return fallback;
                }
            };

            const writeList = (container, ids, emptyText) => {
                container.innerHTML = '';
                const items = ids
                    .map((id) => catalog.get(id))
                    .filter((item, index, array) => item && array.findIndex((entry) => entry.id === item.id) === index);

                if (items.length === 0) {
                    const empty = document.createElement('span');
                    empty.className = 'sidebar-empty-state';
                    empty.textContent = emptyText;
                    container.appendChild(empty);
                    return;
                }

                items.forEach((item) => {
                    const anchor = document.createElement('a');
                    anchor.className = `nav-link sidebar-link sidebar-link-compact${item.active ? ' sidebar-active' : ''}`;
                    anchor.href = item.href;
                    anchor.innerHTML = `<i class="${item.iconClass}"></i><span class="link-text">${item.text}</span>`;
                    container.appendChild(anchor);
                });
            };

            const activeId = trackedLinks.find((link) => link.classList.contains('sidebar-active'))?.dataset.navId;
            const recent = readState(recentKey, []);
            const usage = readState(usageKey, {});
            if (activeId) {
                localStorage.setItem(recentKey, JSON.stringify([activeId, ...recent.filter((id) => id !== activeId)].slice(0, maxItems)));
                localStorage.setItem(usageKey, JSON.stringify({ ...usage, [activeId]: Number(usage[activeId] || 0) + 1 }));
            }

            const nextRecent = readState(recentKey, []);
            const nextUsage = readState(usageKey, {});
            const frequent = Object.entries(nextUsage)
                .sort((left, right) => Number(right[1]) - Number(left[1]))
                .map((entry) => entry[0])
                .slice(0, maxItems);

            writeList(frequentNav, frequent, 'هنوز صفحه پرکاربردی ثبت نشده است.');
            writeList(recentNav, nextRecent, 'هنوز صفحه‌ای باز نشده است.');
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/app-ui.js" asp-append-version="true"></script>
</body>
</html>





