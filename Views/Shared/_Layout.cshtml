                    </div>

                    <section class="sidebar-section sidebar-section-scroll">
                        <div class="sidebar-section-head">
                            <span>همه صفحات</span>
                            <small>دسته‌بندی ماژولار</small>
                        </div>
                        <div class="sidebar-pages-scroll">
