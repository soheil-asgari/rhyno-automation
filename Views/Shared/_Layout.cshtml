<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - پنل مدیریت راینو</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true">
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <!-- فقط یک overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <div class="app-shell">

        <aside class="sidebar-right" id="appSidebar">
            <div class="sidebar-header">
                <div class="d-flex align-items-center justify-content-between">
                    <h6 class="fw-bold mb-0">
                        <i class="bi bi-box-seam-fill text-info ms-2"></i> پنل راینو
                    </h6>

                    <button type="button" class="btn btn-sm btn-light border d-lg-none" id="btnCloseSidebar" aria-label="بستن منو">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <div class="sidebar-content">
                <div class="sidebar-section">
                    <div class="sidebar-section-title">صفحات منتخب</div>
                    <nav class="nav flex-column">
                        <a class="nav-link sidebar-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-1x2-fill text-primary"></i>
                            میز کار مرکزی
                        </a>

                        <a class="nav-link sidebar-link sidebar-link--comingsoon" href="javascript:void(0)" data-title="تنظیمات مالی">
                            <i class="bi bi-wallet2 text-success"></i>
                            تنظیمات مالی
                            <span class="badge bg-light text-dark border ms-auto">به‌زودی</span>
                        </a>

                        <a class="nav-link sidebar-link sidebar-link--comingsoon" href="javascript:void(0)" data-title="صدور سند">
                            <i class="bi bi-file-earmark-diff text-warning"></i>
                            صدور سند
                            <span class="badge bg-light text-dark border ms-auto">به‌زودی</span>
                        </a>

                        <a class="nav-link sidebar-link sidebar-link--comingsoon" href="javascript:void(0)" data-title="حکم کارگزینی">
                            <i class="bi bi-person-badge text-info"></i>
                            حکم کارگزینی
                            <span class="badge bg-light text-dark border ms-auto">به‌زودی</span>
                        </a>
                    </nav>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-section-title">مدیریت سیستمی</div>
                    <nav class="nav flex-column">
                        <a class="nav-link sidebar-link" asp-controller="Letters" asp-action="Index">
                            <i class="bi bi-envelope text-danger"></i>
                            مدیریت نامه‌ها
                        </a>

                        <a class="nav-link sidebar-link" asp-controller="Leaves" asp-action="Index">
                            <i class="bi bi-calendar-check text-success"></i>
                            درخواست مرخصی
                        </a>

                        <a class="nav-link sidebar-link"
                           asp-controller="HumanCapital"
                           asp-action="Index"
                           data-title="سرمایه انسانی">
                            <i class="bi bi-people text-info"></i>
                            سرمایه انسانی
                        </a>

                        <a class="nav-link sidebar-link sidebar-link--comingsoon" href="javascript:void(0)" data-title="مدیریت تردد">
                            <i class="bi bi-person-walking text-warning"></i>
                            مدیریت تردد
                            <span class="badge bg-light text-dark border ms-auto">به‌زودی</span>
                        </a>

                         <a class="nav-link py-2 px-4" href="#"><i class="bi bi-chat-square-text-fill text-primary ms-2"></i> سامانه پیامکی</a>
                        <a class="nav-link py-2 px-4" href="#"><i class="bi bi-chat-square-text-fill text-primary ms-2"></i> چت سازمانی</a>

                        <a class="nav-link py-2 px-4" href="#"><i class="bi bi-stars text-purple ms-2"></i> چت با هوش مصنوعی</a>

                        <a class="nav-link py-2 px-4" href="#"><i class="bi bi-truck text-warning ms-2"></i> ثبت بارنامه</a>

                        <a class="nav-link py-2 px-4" href="#"><i class="bi bi-cash-stack text-success ms-2"></i> ارسال کارکرد لیست حقوق</a>

                        <a class="nav-link py-2 px-4" href="#"><i class="bi bi-shield-check text-info ms-2"></i> ارسال کارکرد لیست بیمه</a>
                           

                        <a class="nav-link sidebar-link" asp-controller="Settings" asp-action="Index">
                            <i class="bi bi-gear text-secondary"></i>
                            تنظیمات سیستم
                        </a>
                    </nav>
                </div>
            </div>

            <div class="sidebar-footer">
                @await Html.PartialAsync("_LoginPartial")
            </div>
        </aside>

        <main class="main-content">

            <!-- Topbar -->
            <div class="topbar">
                <button type="button" class="btn btn-sm btn-light border d-lg-none" id="btnOpenSidebar" aria-label="باز کردن منو">
                    <i class="bi bi-list"></i>
                </button>

                <!-- فقط یک ساعت در کل سیستم -->
                <div class="topbar-clock ms-auto">
                    <i class="bi bi-clock ms-1"></i>
                    <span id="current-persian-date"></span>
                    <span class="mx-2">|</span>
                    <span id="current-time-persian"></span>
                </div>
            </div>

            <div class="container-fluid py-3">
                @RenderBody()
            </div>

            @* <footer class="app-footer">
                <small class="footer-text">
                    طراحی شده برای پورتال سازمانی راینو &copy; 2026
                </small>
            </footer> *@
        </main>

    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>

    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js" defer></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js" defer></script>

    <script src="https://lib.arvancloud.ir/html2pdf.js/0.9.3/html2pdf.min.js" defer></script>

    <script src="~/js/layout.js" asp-append-version="true" defer></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>