@model OfficeAutomation.Models.Leave

@{
    ViewData["Title"] = "ویرایش مرخصی";
}

<div class="container-fluid leave-edit-page">

    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h4 class="mb-1">ویرایش مرخصی</h4>
            <div class="text-muted small">اطلاعات مرخصی را ویرایش و ذخیره کنید.</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-right"></i>
            بازگشت
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-3 p-md-4">

            <form asp-action="Edit" method="post" id="leaveEditForm" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small d-none" id="modelSummary"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row g-3">

                    <!-- کاربر -->
                    <div class="col-12 col-md-6">
                        <label asp-for="UserId" class="form-label">کاربر</label>
                        <select asp-for="UserId"
                                class="form-select"
                                asp-items="ViewBag.UserId"
                                id="UserId">
                            <option value="">— انتخاب کنید —</option>
                        </select>
                        <span asp-validation-for="UserId" class="text-danger small"></span>
                    </div>

                    <!-- وضعیت -->
                    <div class="col-12 col-md-6">
                        <label asp-for="Status" class="form-label">وضعیت</label>
                        <select asp-for="Status" class="form-select" id="Status">
                            <option value="">— انتخاب کنید —</option>
                            <option value="Pending">در انتظار</option>
                            <option value="Approved">تایید شده</option>
                            <option value="Rejected">رد شده</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                        <div class="form-text">
                            وضعیت را متناسب با فرآیند تایید انتخاب کنید.
                        </div>
                    </div>

                    <!-- تاریخ شروع -->
                    <div class="col-12 col-md-6">
                        <label class="form-label">تاریخ شروع</label>

                        <input type="text"
                               id="StartDateFa"
                               name="StartDateFa"
                               class="form-control"
                               autocomplete="off"
                               placeholder="مثلاً 1402/12/01" />

                        <input asp-for="StartDate" type="hidden" id="StartDate" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>

                    <!-- تاریخ پایان -->
                    <div class="col-12 col-md-6">
                        <label class="form-label">تاریخ پایان</label>

                        <input type="text"
                               id="EndDateFa"
                               name="EndDateFa"
                               class="form-control"
                               autocomplete="off"
                               placeholder="مثلاً 1402/12/05" />

                        <input asp-for="EndDate" type="hidden" id="EndDate" />
                        <span asp-validation-for="EndDate" class="text-danger small"></span>
                        <div class="form-text" id="daysHint"></div>
                    </div>

                    <!-- دلیل -->
                    <div class="col-12">
                        <label asp-for="Reason" class="form-label">دلیل مرخصی</label>
                        <textarea asp-for="Reason"
                                  class="form-control"
                                  id="Reason"
                                  rows="3"
                                  placeholder="مثلاً: مرخصی استعلاجی / امور شخصی / سفر و ..."></textarea>
                        <span asp-validation-for="Reason" class="text-danger small"></span>
                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-light">انصراف</a>
                    <button type="submit" class="btn btn-primary" id="btnSaveLeave">
                        <span class="btn-text">ذخیره تغییرات</span>
                        <span class="spinner-border spinner-border-sm ms-2 d-none" id="btnSpinner" role="status" aria-hidden="true"></span>
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Styles {
    <!-- فایل CSS اختصاصی این صفحه -->
    <link rel="stylesheet" href="~/lib/persian-datepicker/persian-datepicker.min.css" />
    <link rel="stylesheet" href="~/css/leave-edit.css" />
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <!-- فایل JS اختصاصی این صفحه -->
    <script src="~/lib/persian-date/persian-date.min.js"></script>
    <script src="~/lib/persian-datepicker/persian-datepicker.min.js"></script>
    <script src="~/js/leave-edit.js"></script>
}