@model List<Vendor>
@{
    ViewData["Title"] = "تامین‌کنندگان";
}

<div class="container-fluid py-4">
    @if (TempData["VendorMessage"] is string vendorMessage)
    {
        <div class="alert alert-info py-2 px-3 small mb-3">@vendorMessage</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">تامین‌کنندگان</h6>
        <a asp-action="Create" class="btn btn-sm btn-primary">تامین‌کننده جدید</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 border-bottom">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label small text-muted mb-1">جستجو</label>
                    <input name="searchTerm" value="@ViewBag.SearchTerm" class="form-control form-control-sm" placeholder="نام / کد اقتصادی / شناسه ملی" />
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary">اعمال</button>
                </div>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>نام</th>
                        <th>کد اقتصادی</th>
                        <th>شناسه ملی</th>
                        <th>تلفن</th>
                        <th>وضعیت</th>
                        <th class="text-center">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@(string.IsNullOrWhiteSpace(item.EconomicCode) ? "-" : item.EconomicCode)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.NationalId) ? "-" : item.NationalId)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Phone) ? "-" : item.Phone)</td>
                                <td><span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? "فعال" : "غیرفعال")</span></td>
                                <td class="text-center">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('آیتم حذف/غیرفعال شود؟');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted py-3">رکوردی یافت نشد.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
