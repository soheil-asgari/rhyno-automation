@model Vendor
@{
    ViewData["Title"] = "ویرایش تامین‌کننده";
}

<div class="container-fluid py-4">
    <h6 class="fw-bold mb-3">ویرایش تامین‌کننده</h6>
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                <div class="row g-2">
                    <div class="col-md-4"><label asp-for="Name" class="form-label small"></label><input asp-for="Name" class="form-control form-control-sm" /></div>
                    <div class="col-md-4"><label asp-for="EconomicCode" class="form-label small"></label><input asp-for="EconomicCode" class="form-control form-control-sm" /></div>
                    <div class="col-md-4"><label asp-for="NationalId" class="form-label small"></label><input asp-for="NationalId" class="form-control form-control-sm" /></div>
                    <div class="col-md-4"><label asp-for="Phone" class="form-label small"></label><input asp-for="Phone" class="form-control form-control-sm" /></div>
                    <div class="col-md-8"><label asp-for="Address" class="form-label small"></label><input asp-for="Address" class="form-control form-control-sm" /></div>
                    <div class="col-md-2 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label small"></label>
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-sm btn-success">ذخیره تغییرات</button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">بازگشت</a>
                </div>
            </form>
        </div>
    </div>
</div>
