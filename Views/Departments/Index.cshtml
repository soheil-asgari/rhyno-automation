@model IEnumerable<OfficeAutomation.Models.Department>

<h2>مدیریت بخش‌ها</h2>

<a asp-action="Create" class="btn btn-primary">بخش جدید</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>نام بخش</th>
            <th>مدیر</th>
            <th>عملیات</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var dept in Model)
        {
            <tr>
                <td>@dept.Name</td>

                <td>
                    @(dept.Manager != null
                        ? dept.Manager.FullName
                        : "تعیین نشده")
                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-warning">ویرایش</a>
                </td>
            </tr>
        }
    </tbody>
</table>
