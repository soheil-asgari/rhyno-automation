@model OfficeAutomation.Models.DashboardIndexViewModel
@using System.Globalization

@{
    ViewData["Title"] = "داشبورد اجرایی";
    var fa = CultureInfo.GetCultureInfo("fa-IR");
    string ToFa(int value) => value.ToString("N0", fa);

    var shortcuts = new List<(string Id, string Title, string Description, string Url, string Icon)>
    {
        ("letters", "نامه‌ها", "گزارش‌ها و مکاتبات", "/Letters", "bi-envelope-paper"),
        ("invoices", "فاکتورها", "ایجاد و پیگیری فاکتور", "/Financial/Invoices", "bi-receipt"),
        ("leaves", "مرخصی‌ها", "درخواست‌ها و تاییدها", "/Leaves", "bi-calendar-check"),
        ("warehouse", "انبار", "رسید و خروجی کالا", "/Warehouse", "bi-box-seam"),
        ("inbox", "کارتابل", "اقدام‌ها و تاییدهای مهم", "/WorkInbox", "bi-inboxes"),
        ("calendar", "تقویم", "رویدادهای مهم سازمان", "/OrganizationCalendar", "bi-calendar3"),
        ("search", "جستجو", "جستجوی سریع", "/Search", "bi-search")
    };
}

<div class="executive-dashboard">
    <section class="dashboard-header">
        <div>
            <h1>داشبورد اجرایی</h1>
            <p>نمای زنده از کارهای امروز، تاییدها، فاکتورها، موجودی و هشدارهای سیستم - @Model.TodayText</p>
        </div>
        <div class="header-actions">
            <button id="homeCustomizeToggle" class="btn btn-sm btn-outline-primary" type="button">
                <i class="bi bi-sliders2"></i>
                تنظیمات صفحه
            </button>
            <a class="btn btn-sm btn-outline-primary" href="/admin/audit-dashboard">
                <i class="bi bi-shield-check"></i>
                رخدادها
            </a>
        </div>
    </section>

    <section id="homeCustomizationPanel" class="home-customization-panel">
        <h3>شخصی‌سازی داشبورد</h3>
        <p>می‌تونید ترتیب کارت‌ها رو عوض کنید و شورتکات‌های نمایش داده‌شده را انتخاب کنید.</p>

        <div class="customization-toolbar">
            <button id="toggleEditMode" class="btn btn-sm btn-outline-secondary" type="button">
                <i class="bi bi-arrows-move"></i>
                فعال‌سازی جابه‌جایی
            </button>
            <button id="resetDashboardConfig" class="btn btn-sm btn-outline-danger" type="button">
                <i class="bi bi-arrow-counterclockwise"></i>
                بازنشانی چیدمان
            </button>
        </div>

        <div class="bg-controls">
            <label>پس‌زمینه</label>
            <div class="preset-backgrounds" role="list" aria-label="پیش‌تنظیم پس‌زمینه">
                <button type="button" class="bg-swatch bg-swatch-light" data-bg="linear-gradient(135deg, #f8fafc, #eff6ff)" data-type="gradient" title="پس‌زمینه روشن" aria-label="پس‌زمینه روشن"></button>
                <button type="button" class="bg-swatch bg-swatch-warm" data-bg="#fef3c7" data-type="color" title="سفید مایل" aria-label="پس‌زمینه سفید مایل"></button>
                <button type="button" class="bg-swatch bg-swatch-green" data-bg="#dcfce7" data-type="color" title="سبز روشن" aria-label="پس‌زمینه سبز روشن"></button>
                <button type="button" class="bg-swatch bg-swatch-blue" data-bg="#dbeafe" data-type="color" title="آبی روشن" aria-label="پس‌زمینه آبی روشن"></button>
                <button type="button" class="bg-swatch bg-swatch-violet" data-bg="#ede9fe" data-type="color" title="بنفش روشن" aria-label="پس‌زمینه بنفش روشن"></button>
            </div>
            <div class="bg-actions">
                <label for="customBackgroundColor">رنگ دلخواه</label>
                <input id="customBackgroundColor" type="color" value="#f8fafc" />
                <label for="customBackgroundImage">تصویر دلخواه</label>
                <input id="customBackgroundImage" type="text" placeholder="آدرس تصویر" />
                <button id="applyBgImage" type="button" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-image"></i>
                    اعمال تصویر
                </button>
                <button id="clearBackground" type="button" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x-circle"></i>
                    حذف پس‌زمینه
                </button>
            </div>
        </div>

        <div class="shortcut-visibility">
            <p>نمایش شورتکات‌ها</p>
            <div class="shortcut-toggles" id="shortcutToggles">
                @foreach (var shortcut in shortcuts)
                {
                    <label class="shortcut-toggle-item">
                        <input type="checkbox" value="@shortcut.Id" checked />
                        <i class="bi @shortcut.Icon"></i>
                        <span>@shortcut.Title</span>
                    </label>
                }
            </div>
        </div>
    </section>

    <section class="metric-grid" id="metricGrid" data-drag-container>
        @for (int metricIndex = 0; metricIndex < Model.ExecutiveMetrics.Count; metricIndex++)
        {
            var metric = Model.ExecutiveMetrics[metricIndex];
            var cardId = $"metric-{metricIndex}";
            <a class="metric-card metric-@metric.Tone customizable-card" href="@metric.Url" data-card-id="@cardId" data-card-type="metric" draggable="true">
                <span class="drag-handle d-none"><i class="bi bi-grip-vertical"></i></span>
                <span class="metric-icon"><i class="bi @metric.Icon"></i></span>
                <span class="metric-body">
                    <strong>@metric.Value</strong>
                    <span>@metric.Title</span>
                    <small>@metric.Description</small>
                </span>
            </a>
        }
    </section>

    <section class="dashboard-grid" id="mainPanels" data-drag-container>
        <div class="dashboard-panel customizable-card" id="panel-pending-work" data-card-id="panel-pending-work" data-card-type="panel" draggable="true">
            <div class="panel-head">
                <span class="drag-handle d-none"><i class="bi bi-grip-vertical"></i></span>
                <h2>کارهای در انتظار اقدام</h2>
                <span>@ToFa(Model.PendingWorkItems.Count) مورد</span>
            </div>

            @if (Model.PendingWorkItems.Count == 0)
            {
                <div class="empty-state">موردی برای اقدام فوری وجود ندارد.</div>
            }
            else
            {
                <div class="work-list">
                    @foreach (var item in Model.PendingWorkItems)
                    {
                        <a class="work-item" href="@item.Url">
                            <i class="bi @item.Icon"></i>
                            <span>
                                <strong>@item.Title</strong>
                                <small>@item.Module - @item.DateText</small>
                            </span>
                            <em class="badge @item.StatusCssClass">@WorkflowStatus.Label(item.Status)</em>
                        </a>
                    }
                </div>
            }
        </div>

        <div class="dashboard-panel customizable-card" id="panel-system-alerts" data-card-id="panel-system-alerts" data-card-type="panel" draggable="true">
            <div class="panel-head">
                <span class="drag-handle d-none"><i class="bi bi-grip-vertical"></i></span>
                <h2>هشدارهای سیستم</h2>
                <span>@ToFa(Model.SystemWarnings)</span>
            </div>

            <div class="alert-list">
                @foreach (var alert in Model.SystemAlerts)
                {
                    <a class="alert-item alert-@alert.Severity" href="@alert.Url">
                        <i class="bi @alert.Icon"></i>
                        <span>
                            <strong>@alert.Title</strong>
                            <small>@alert.Description</small>
                        </span>
                    </a>
                }
            </div>
        </div>

        <div class="dashboard-panel customizable-card" id="panel-weekly-activity" data-card-id="panel-weekly-activity" data-card-type="panel" draggable="true">
            <div class="panel-head">
                <span class="drag-handle d-none"><i class="bi bi-grip-vertical"></i></span>
                <h2>روند فعالیت ۷ روز اخیر</h2>
                <span>@ToFa(Model.TotalAuditEvents) رخداد</span>
            </div>
            <div class="activity-bars">
                @foreach (var point in Model.WeeklyActivity)
                {
                    <div class="activity-bar" title="@point.Label - @ToFa(point.Value)">
                        <span data-bar-percent="@point.Percent"></span>
                        <small>@(point.Label.Length >= 2 ? point.Label[^2..] : point.Label)</small>
                    </div>
                }
            </div>
        </div>

        <div class="dashboard-panel customizable-card" id="panel-recent-activities" data-card-id="panel-recent-activities" data-card-type="panel" draggable="true">
            <div class="panel-head">
                <span class="drag-handle d-none"><i class="bi bi-grip-vertical"></i></span>
                <h2>آخرین فعالیت‌ها</h2>
                <span>ممیزی</span>
            </div>
            <div class="recent-list">
                @if (Model.RecentActivities.Count == 0)
                {
                    <div class="empty-state">هنوز رخدادی ثبت نشده است.</div>
                }
                else
                {
                    @foreach (var item in Model.RecentActivities)
                    {
                        <div class="recent-item">
                            <span>
                                <strong>@item.DocumentType</strong>
                                <small>@item.DateText</small>
                            </span>
                            <em class="status-@item.StatusCssClass">@item.StatusText</em>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <section class="dashboard-shortcuts" id="shortcutsPanel" data-card-type="shortcuts" data-card-id="shortcuts-panel">
        <div class="panel-head">
            <span class="drag-handle d-none"><i class="bi bi-grip-vertical"></i></span>
            <h2>شورتکات‌ها</h2>
            <span>فوریت‌ها</span>
        </div>
        <div class="shortcut-grid" id="shortcutGrid" data-drag-container>
            @foreach (var shortcut in shortcuts)
            {
                <a class="dashboard-shortcut customizable-card" href="@shortcut.Url" data-shortcut-id="@shortcut.Id" data-card-id="shortcut-@shortcut.Id" draggable="true">
                    <span class="drag-handle d-none"><i class="bi bi-grip-vertical"></i></span>
                    <i class="bi @shortcut.Icon"></i>
                    <span>
                        <strong>@shortcut.Title</strong>
                        <small>@shortcut.Description</small>
                    </span>
                </a>
            }
        </div>
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/home-dashboard.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (() => {
            document.querySelectorAll('[data-bar-percent]').forEach((bar) => {
                const value = Number(bar.getAttribute('data-bar-percent'));
                if (Number.isFinite(value)) {
                    bar.style.setProperty('--bar-height', `${Math.max(0, Math.min(100, value))}%`);
                }
            });
            const storagePrefix = 'home-dashboard';
            const layoutStorageKey = `${storagePrefix}.layout.order.v1`;
            const shortcutStorageKey = `${storagePrefix}.shortcuts.v1`;
            const bgStorageKey = `${storagePrefix}.bg.v1`;
            const isDarkTheme = () => document.documentElement.classList.contains('theme-dark') || document.documentElement.getAttribute('data-theme') === 'dark';
            const getBaseSurface = () => isDarkTheme() ? '#111827' : '#f8fafc';

            const toggleButton = document.getElementById('homeCustomizeToggle');
            const customizationPanel = document.getElementById('homeCustomizationPanel');
            const editButton = document.getElementById('toggleEditMode');
            const resetButton = document.getElementById('resetDashboardConfig');
            const mainPanels = document.getElementById('mainPanels');
            const metricGrid = document.getElementById('metricGrid');
            const shortcutGrid = document.getElementById('shortcutGrid');
            const shortcutToggles = document.getElementById('shortcutToggles');
            const mainContainer = document.getElementById('main-content-wrapper');

            const presetSwatches = document.querySelectorAll('.bg-swatch');
            const customColorInput = document.getElementById('customBackgroundColor');
            const customImageInput = document.getElementById('customBackgroundImage');
            const applyImageButton = document.getElementById('applyBgImage');
            const clearBackgroundButton = document.getElementById('clearBackground');

            const containerList = [metricGrid, mainPanels, shortcutGrid];
            let draggingElement = null;
            let isDragEnabled = false;

            const getDashboardSettings = () => {
                const defaultOrder = {};
                containerList.forEach((container) => {
                    if (!container) return;
                    defaultOrder[container.id] = Array.from(container.children)
                        .filter((node) => node instanceof HTMLElement)
                        .map((node) => node.getAttribute('data-card-id'));
                });
                const defaultShortcuts = Array.from(shortcutToggles?.querySelectorAll('input[type="checkbox"]') || []).map((input) => input.value);
                return { order: defaultOrder, shortcuts: defaultShortcuts };
            };

            const readSavedSettings = () => {
                const fallback = getDashboardSettings();
                let layout = { ...fallback };
                let shortcuts = [...fallback.shortcuts];
                let background = null;

                try {
                    const rawLayout = localStorage.getItem(layoutStorageKey);
                    if (rawLayout) {
                        const parsed = JSON.parse(rawLayout);
                        if (parsed && typeof parsed === 'object' && parsed.order) {
                            layout = { ...layout, ...parsed };
                        }
                    }

                    const rawShortcuts = localStorage.getItem(shortcutStorageKey);
                    if (rawShortcuts) {
                        const parsedShortcuts = JSON.parse(rawShortcuts);
                        if (Array.isArray(parsedShortcuts)) {
                            shortcuts = parsedShortcuts;
                        }
                    }

                    const rawBg = localStorage.getItem(bgStorageKey);
                    if (rawBg) {
                        background = JSON.parse(rawBg);
                    }
                }
                catch {
                    // ignore and continue with fallback
                }

                return { order: layout.order || fallback.order, shortcuts, background };
            };

            const saveSettings = (settings) => {
                localStorage.setItem(layoutStorageKey, JSON.stringify({ order: settings.order }));
                localStorage.setItem(shortcutStorageKey, JSON.stringify(settings.shortcuts));
            };

            const saveBackground = (value) => {
                localStorage.setItem(bgStorageKey, JSON.stringify(value));
            };

            const applyOrder = (orderMap) => {
                if (!containerList.every((container) => container)) {
                    return;
                }

                containerList.forEach((container) => {
                    const expectedOrder = orderMap[container.id];
                    if (!Array.isArray(expectedOrder)) {
                        return;
                    }

                    const childrenById = new Map();
                    const existingCards = Array.from(container.children);
                    existingCards.forEach((card) => {
                        if (card instanceof HTMLElement && card.getAttribute('data-card-id')) {
                            childrenById.set(card.getAttribute('data-card-id'), card);
                        }
                    });

                    const fallbackCards = [];
                    existingCards.forEach((card) => {
                        if (card instanceof HTMLElement && card.getAttribute('data-card-id') && !childrenById.has(card.getAttribute('data-card-id'))) {
                            fallbackCards.push(card);
                        }
                    });

                    expectedOrder.forEach((cardId) => {
                        const card = childrenById.get(cardId);
                        if (card) {
                            container.appendChild(card);
                            childrenById.delete(cardId);
                        }
                    });

                    fallbackCards.forEach((card) => container.appendChild(card));
                    childrenById.forEach((card) => {
                        container.appendChild(card);
                    });
                });
            };

            const applyShortcutVisibility = (visibleShortcutIds) => {
                const activeIds = new Set(visibleShortcutIds);
                const shortcuts = Array.from(shortcutGrid.querySelectorAll('.dashboard-shortcut'));
                shortcuts.forEach((shortcut) => {
                    const id = shortcut.getAttribute('data-shortcut-id');
                    shortcut.classList.toggle('hidden', id ? !activeIds.has(id) : false);
                });

                const checkboxes = Array.from(shortcutToggles.querySelectorAll('input[type="checkbox"]'));
                checkboxes.forEach((checkbox) => {
                    checkbox.checked = activeIds.has(checkbox.value);
                });
            };

            const applyBackground = (config) => {
                if (!mainContainer) {
                    return;
                }

                if (!config || (config.type !== 'color' && config.type !== 'image' && config.type !== 'gradient')) {
                    mainContainer.style.background = '';
                    mainContainer.style.backgroundImage = '';
                    return;
                }

                if (config.type === 'image') {
                    mainContainer.style.backgroundColor = getBaseSurface();
                    mainContainer.style.backgroundImage = `url('${config.value}')`;
                    mainContainer.style.backgroundSize = 'cover';
                    mainContainer.style.backgroundPosition = 'center';
                    mainContainer.style.backgroundAttachment = 'fixed';
                    return;
                }

                mainContainer.style.backgroundImage = 'none';
                mainContainer.style.backgroundColor = config.value;
                if (config.type === 'gradient') {
                    mainContainer.style.background = config.value;
                }
            };

            const collectLayoutState = () => {
                const order = {};
                containerList.forEach((container) => {
                    if (!container) {
                        return;
                    }

                    order[container.id] = Array.from(container.children)
                        .filter((node) => node instanceof HTMLElement && node.getAttribute('data-card-id'))
                        .map((node) => node.getAttribute('data-card-id'));
                });

                const shortcuts = Array.from(shortcutToggles.querySelectorAll('input[type="checkbox"]'))
                    .filter((checkbox) => checkbox.checked)
                    .map((checkbox) => checkbox.value);

                return { order, shortcuts };
            };

            const hydrate = () => {
                const settings = readSavedSettings();
                applyOrder(settings.order);
                applyShortcutVisibility(settings.shortcuts);
                applyBackground(settings.background);
            };

            const togglePanel = () => {
                customizationPanel.classList.toggle('open');
            };

            const setDragMode = (enabled) => {
                isDragEnabled = enabled;
                document.body.classList.toggle('drag-mode', enabled);
                editButton.textContent = enabled ? 'تایید و خروج از ویرایش' : 'فعال‌سازی جابه‌جایی';
                document.querySelectorAll('.drag-handle').forEach((handle) => {
                    handle.style.display = enabled ? 'inline-flex' : '';
                });
            };

            const setDragStateForCards = (container, enabled) => {
                if (!container) {
                    return;
                }

                container.querySelectorAll('[draggable]').forEach((item) => {
                    item.draggable = enabled;
                });
            };

            const setAllDragState = (enabled) => {
                setDragStateForCards(metricGrid, enabled);
                setDragStateForCards(mainPanels, enabled);
                setDragStateForCards(shortcutGrid, enabled);
            };

            const clearIndicators = () => {
                document.querySelectorAll('.drag-indicator').forEach((node) => {
                    node.classList.remove('drag-indicator');
                });
            };

            const getCardContainer = (element) => {
                if (!element) return null;
                return element.closest('[data-drag-container]');
            };

            const updateOrderStorage = () => {
                const settings = collectLayoutState();
                saveSettings(settings);
            };

            const onDragStart = (event) => {
                if (!isDragEnabled) {
                    event.preventDefault();
                    return;
                }

                draggingElement = event.currentTarget;
                event.dataTransfer.effectAllowed = 'move';
                event.dataTransfer.setData('text/plain', draggingElement.getAttribute('data-card-id') || '');
                draggingElement.classList.add('dragging');
            };

            const onDragOver = (event) => {
                if (!isDragEnabled || !draggingElement) {
                    return;
                }

                event.preventDefault();
                const container = getCardContainer(event.currentTarget);
                if (!container) {
                    return;
                }

                const afterElement = getDragAfterElement(container, event.clientY);
                clearIndicators();
                if (afterElement) {
                    afterElement.classList.add('drag-indicator');
                }
                return;
            };

            const getDragAfterElement = (container, y) => {
                const draggableElements = Array.from(container.querySelectorAll('.customizable-card:not(.dragging):not(.hidden)'));
                return draggableElements.reduce((closest, child) => {
                    const box = child.getBoundingClientRect();
                    const offset = y - (box.top + box.height / 2);
                    if (offset < 0 && offset > closest.offset) {
                        return { offset, element: child };
                    }
                    return closest;
                }, { offset: Number.NEGATIVE_INFINITY, element: null }).element;
            };

            const onDragEnter = (event) => {
                const container = getCardContainer(event.currentTarget);
                if (!container) return;
                container.classList.add('drag-indicator');
            };

            const onDragLeave = (event) => {
                const container = getCardContainer(event.currentTarget);
                if (!container) return;
                container.classList.remove('drag-indicator');
            };

            const onDrop = (event) => {
                event.preventDefault();
                if (!isDragEnabled || !draggingElement) {
                    return;
                }

                const container = getCardContainer(event.currentTarget);
                if (!container || !container.contains(event.currentTarget)) {
                    return;
                }

                const afterElement = getDragAfterElement(container, event.clientY);
                if (!afterElement) {
                    container.appendChild(draggingElement);
                } else {
                    container.insertBefore(draggingElement, afterElement);
                }

                clearIndicators();
                updateOrderStorage();
            };

            const onDragEnd = () => {
                clearIndicators();
                if (draggingElement) {
                    draggingElement.classList.remove('dragging');
                }
                draggingElement = null;
            };

            const bindDragEvents = () => {
                const cards = document.querySelectorAll('[draggable="true"]');
                cards.forEach((card) => {
                    card.addEventListener('dragstart', onDragStart);
                    card.addEventListener('dragend', onDragEnd);
                });

                containerList.forEach((container) => {
                    if (!container) return;
                    container.addEventListener('dragover', onDragOver);
                    container.addEventListener('dragenter', onDragEnter);
                    container.addEventListener('dragleave', onDragLeave);
                    container.addEventListener('drop', onDrop);
                });
            };

            const bindShortcutToggle = () => {
                if (!shortcutToggles) {
                    return;
                }

                shortcutToggles.addEventListener('change', (event) => {
                    const checkbox = event.target;
                    if (!(checkbox instanceof HTMLInputElement) || checkbox.type !== 'checkbox') {
                        return;
                    }

                    const id = checkbox.value;
                    const shortcut = shortcutGrid.querySelector(`[data-shortcut-id="${id}"]`);
                    if (shortcut) {
                        shortcut.classList.toggle('hidden', !checkbox.checked);
                    }
                    updateOrderStorage();
                });
            };

            const bindBackgroundControls = () => {
                presetSwatches.forEach((swatch) => {
                    swatch.addEventListener('click', () => {
                        const bgType = swatch.dataset.type || 'color';
                        const value = swatch.dataset.bg;
                        const config = { type: bgType, value };
                        applyBackground(config);
                        saveBackground(config);
                    });
                });

                customColorInput?.addEventListener('change', () => {
                    const config = { type: 'color', value: customColorInput.value };
                    applyBackground(config);
                    saveBackground(config);
                });

                applyImageButton?.addEventListener('click', () => {
                    const value = customImageInput?.value?.trim();
                    if (!value) {
                        return;
                    }
                    const config = { type: 'image', value };
                    applyBackground(config);
                    saveBackground(config);
                });

                clearBackgroundButton?.addEventListener('click', () => {
                    applyBackground(null);
                    localStorage.removeItem(bgStorageKey);
                });
            };

            const resetDashboard = () => {
                const defaultSettings = getDashboardSettings();
                applyOrder(defaultSettings.order);
                applyShortcutVisibility(defaultSettings.shortcuts);
                localStorage.removeItem(layoutStorageKey);
                localStorage.removeItem(shortcutStorageKey);
                localStorage.removeItem(bgStorageKey);
                applyBackground(null);
                mainContainer.style.background = '';
                mainContainer.style.backgroundImage = '';
                mainContainer.style.backgroundColor = '';
            };

            toggleButton?.addEventListener('click', togglePanel);
            editButton?.addEventListener('click', () => {
                const nextState = !isDragEnabled;
                setDragMode(nextState);
                setAllDragState(nextState);
            });

            resetButton?.addEventListener('click', resetDashboard);

            hydrate();
            bindDragEvents();
            bindShortcutToggle();
            bindBackgroundControls();
            setAllDragState(false);

            document.querySelectorAll('[draggable="true"]').forEach((card) => {
                card.addEventListener('touchstart', () => {
                    if (!isDragEnabled) return;
                    card.setAttribute('data-touch-lock', '1');
                });
            });

            window.addEventListener('storage', (event) => {
                if (event.key === layoutStorageKey || event.key === shortcutStorageKey || event.key === bgStorageKey) {
                    hydrate();
                }
            });

            window.addEventListener('themechange', () => {
                const settings = readSavedSettings();
                applyBackground(settings.background);
            });

            if (mainContainer) {
                if (mainContainer.style.backgroundImage || mainContainer.style.backgroundColor) {
                    return;
                }
            }
        })();
    </script>
}
