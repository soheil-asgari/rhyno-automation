@model OfficeAutomation.Models.DashboardIndexViewModel
@using System.Globalization

@{
    ViewData["Title"] = "داشبورد اجرایی";
    var fa = CultureInfo.GetCultureInfo("fa-IR");
    string ToFa(int value) => value.ToString("N0", fa);
}

<div class="executive-dashboard">
    <section class="dashboard-header">
        <div>
            <h1>داشبورد اجرایی</h1>
            <p>نمای زنده از کارهای امروز، تاییدها، فاکتورها، موجودی و هشدارهای سیستم - @Model.TodayText</p>
        </div>
        <a class="btn btn-sm btn-outline-primary" href="/admin/audit-dashboard">
            <i class="bi bi-shield-check"></i>
            رخدادها
        </a>
    </section>

    <section class="metric-grid">
        @foreach (var metric in Model.ExecutiveMetrics)
        {
            <a class="metric-card metric-@metric.Tone" href="@metric.Url">
                <span class="metric-icon"><i class="bi @metric.Icon"></i></span>
                <span class="metric-body">
                    <strong>@metric.Value</strong>
                    <span>@metric.Title</span>
                    <small>@metric.Description</small>
                </span>
            </a>
        }
    </section>

    <section class="dashboard-grid">
        <div class="dashboard-panel" id="pending-work">
            <div class="panel-head">
                <h2>کارهای در انتظار اقدام</h2>
                <span>@ToFa(Model.PendingWorkItems.Count) مورد</span>
            </div>

            @if (Model.PendingWorkItems.Count == 0)
            {
                <div class="empty-state">موردی برای اقدام فوری وجود ندارد.</div>
            }
            else
            {
                <div class="work-list">
                    @foreach (var item in Model.PendingWorkItems)
                    {
                        <a class="work-item" href="@item.Url">
                            <i class="bi @item.Icon"></i>
                            <span>
                                <strong>@item.Title</strong>
                                <small>@item.Module - @item.DateText</small>
                            </span>
                            <em class="badge @item.StatusCssClass">@WorkflowStatus.Label(item.Status)</em>
                        </a>
                    }
                </div>
            }
        </div>

        <div class="dashboard-panel" id="system-alerts">
            <div class="panel-head">
                <h2>هشدارهای سیستم</h2>
                <span>@ToFa(Model.SystemWarnings)</span>
            </div>

            <div class="alert-list">
                @foreach (var alert in Model.SystemAlerts)
                {
                    <a class="alert-item alert-@alert.Severity" href="@alert.Url">
                        <i class="bi @alert.Icon"></i>
                        <span>
                            <strong>@alert.Title</strong>
                            <small>@alert.Description</small>
                        </span>
                    </a>
                }
            </div>
        </div>

        <div class="dashboard-panel">
            <div class="panel-head">
                <h2>روند فعالیت ۷ روز اخیر</h2>
                <span>@ToFa(Model.TotalAuditEvents) رخداد</span>
            </div>
            <div class="activity-bars">
                @foreach (var point in Model.WeeklyActivity)
                {
                    <div class="activity-bar" title="@point.Label - @ToFa(point.Value)">
                        <span style="height:@point.Percent%"></span>
                        <small>@(point.Label.Length >= 2 ? point.Label[^2..] : point.Label)</small>
                    </div>
                }
            </div>
        </div>

        <div class="dashboard-panel">
            <div class="panel-head">
                <h2>آخرین فعالیت‌ها</h2>
                <span>Audit</span>
            </div>
            <div class="recent-list">
                @if (Model.RecentActivities.Count == 0)
                {
                    <div class="empty-state">هنوز رخدادی ثبت نشده است.</div>
                }
                else
                {
                    @foreach (var item in Model.RecentActivities)
                    {
                        <div class="recent-item">
                            <span>
                                <strong>@item.DocumentType</strong>
                                <small>@item.DateText</small>
                            </span>
                            <em class="status-@item.StatusCssClass">@item.StatusText</em>
                        </div>
                    }
                }
            </div>
        </div>
    </section>
</div>

@section Styles {
    <style>
        .executive-dashboard {
            direction: rtl;
            color: var(--text-dark);
        }

        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 12px;
        }

        .dashboard-header h1 {
            margin: 0 0 4px;
            font-size: 1.2rem !important;
            font-weight: 850;
        }

        .dashboard-header p {
            margin: 0;
            color: #64748b;
            font-size: .76rem;
        }

        .metric-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
            gap: 10px;
            margin-bottom: 12px;
        }

        .metric-card,
        .dashboard-panel {
            background: #fff;
            border: 1px solid #e2e8f0;
            box-shadow: 0 1px 3px rgba(15, 23, 42, .05);
        }

        .metric-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px;
            color: inherit;
            text-decoration: none;
        }

        .metric-card:hover {
            border-color: #94a3b8;
        }

        .metric-icon {
            width: 32px;
            height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #e2e8f0;
            background: #f8fafc;
            color: #4f46e5;
        }

        .metric-body {
            display: grid;
            min-width: 0;
        }

        .metric-body strong {
            font-size: 1.1rem;
            line-height: 1.2;
        }

        .metric-body span {
            font-size: .76rem;
            font-weight: 800;
        }

        .metric-body small {
            color: #64748b;
            font-size: .66rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .metric-danger .metric-icon { color: #dc2626; }
        .metric-warning .metric-icon { color: #d97706; }
        .metric-success .metric-icon { color: #059669; }
        .metric-info .metric-icon { color: #0891b2; }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 360px), 1fr));
            gap: 12px;
        }

        .dashboard-panel {
            padding: 12px;
            min-width: 0;
        }

        .panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 10px;
        }

        .panel-head h2 {
            margin: 0;
            font-size: .9rem !important;
            font-weight: 850;
        }

        .panel-head span {
            color: #64748b;
            font-size: .7rem;
            font-weight: 800;
        }

        .work-list,
        .alert-list,
        .recent-list {
            display: grid;
            gap: 7px;
        }

        .work-item,
        .alert-item,
        .recent-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px;
            border: 1px solid #eef2f7;
            background: #f8fafc;
            color: inherit;
            text-decoration: none;
        }

        .work-item i,
        .alert-item i {
            color: #4f46e5;
        }

        .work-item span,
        .alert-item span,
        .recent-item span {
            display: grid;
            min-width: 0;
            flex: 1;
        }

        .work-item strong,
        .alert-item strong,
        .recent-item strong {
            font-size: .76rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .work-item small,
        .alert-item small,
        .recent-item small {
            font-size: .66rem;
            color: #64748b;
        }

        .work-item em,
        .recent-item em {
            font-style: normal;
            font-size: .66rem;
            white-space: nowrap;
        }

        .alert-danger { border-color: #fecaca; background: #fff7f7; }
        .alert-warning { border-color: #fde68a; background: #fffbeb; }
        .alert-info { border-color: #bae6fd; background: #f0f9ff; }
        .alert-success { border-color: #bbf7d0; background: #f0fdf4; }

        .activity-bars {
            height: 156px;
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            align-items: end;
            gap: 8px;
            padding-top: 8px;
        }

        .activity-bar {
            height: 100%;
            display: grid;
            grid-template-rows: 1fr auto;
            gap: 5px;
            align-items: end;
            text-align: center;
        }

        .activity-bar span {
            display: block;
            min-height: 8px;
            background: #4f46e5;
        }

        .activity-bar small {
            color: #64748b;
            font-size: .62rem;
        }

        .empty-state {
            padding: 18px;
            text-align: center;
            color: #64748b;
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            font-size: .76rem;
        }

        html.theme-dark .metric-card,
        html.theme-dark .dashboard-panel {
            background: #111827 !important;
            border-color: #334155 !important;
        }

        html.theme-dark .work-item,
        html.theme-dark .alert-item,
        html.theme-dark .recent-item,
        html.theme-dark .empty-state,
        html.theme-dark .metric-icon {
            background: #0f172a !important;
            border-color: #334155 !important;
        }

        html.theme-dark .dashboard-header p,
        html.theme-dark .metric-body small,
        html.theme-dark .panel-head span,
        html.theme-dark .work-item small,
        html.theme-dark .alert-item small,
        html.theme-dark .recent-item small,
        html.theme-dark .activity-bar small {
            color: #cbd5e1 !important;
        }

        @@media (max-width: 1200px) {
            .metric-grid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
        }

        @@media (max-width: 900px) {
            .dashboard-grid,
            .metric-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}
