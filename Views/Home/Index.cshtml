@model OfficeAutomation.Models.DashboardIndexViewModel
@using System.Globalization

@{
    ViewData["Title"] = "میز کار";
    var fa = CultureInfo.GetCultureInfo("fa-IR");
    string ToFa(int value) => value.ToString("N0", fa);
}

<script src="~/js/jalali-moment.browser.js"></script>

<div class="rhino-premium-panel">
    <main class="rh-grid-layout">
        <section class="rh-bento hero-sm animate-frip">
            <div class="hero-inner">
                <h2>میز کار <span>مرکزی</span></h2>
                <p>امروز @Model.TodayText؛ داده‌های این صفحه مستقیما از پایگاه داده خوانده شده‌اند.</p>
            </div>
        </section>

        <section class="rh-bento stat-sm blue animate-frip">
            <i class="bi bi-clipboard-data" style="color: #4f46e5;"></i>
            <div class="stat-info">
                <span class="v">@ToFa(Model.TotalAuditEvents)</span>
                <span class="l">کل رخدادها</span>
            </div>
        </section>

        <section class="rh-bento stat-sm green animate-frip">
            <i class="bi bi-file-earmark-plus" style="color: #10b981;"></i>
            <div class="stat-info">
                <span class="v">@ToFa(Model.CreateEvents)</span>
                <span class="l">ثبت جدید</span>
            </div>
        </section>

        <section class="rh-bento table-box animate-frip">
            <div class="box-head">
                <h3><i class="bi bi-clock-history"></i> آخرین فعالیت‌های ثبت شده</h3>
                <a href="/admin/audit-dashboard">مشاهده کامل <i class="bi bi-arrow-left-short"></i></a>
            </div>

            <table class="rh-table-sm">
                <thead>
                    <tr>
                        <th>بخش</th>
                        <th>تاریخ</th>
                        <th>وضعیت</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentActivities.Count == 0)
                    {
                        <tr>
                            <td colspan="3" class="text-muted">هنوز رخدادی برای نمایش ثبت نشده است.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.RecentActivities)
                        {
                            <tr>
                                <td>@item.DocumentType</td>
                                <td>@item.DateText</td>
                                <td><span class="badge-sm @item.StatusCssClass">@item.StatusText</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div class="mini-chart-wrapper">
                <span class="chart-label">روند رخدادهای ۷ روز اخیر</span>
                <div class="css-chart">
                    @foreach (var point in Model.WeeklyActivity)
                    {
                        <div style="height: @point.Percent%;" title="@point.Label - @ToFa(point.Value) رخداد"></div>
                    }
                </div>
            </div>
        </section>

        <section class="rh-bento stat-sm orange animate-frip">
            <i class="bi bi-pencil" style="color: #f59e0b;"></i>
            <div class="stat-info">
                <span class="v">@ToFa(Model.UpdateEvents)</span>
                <span class="l">ویرایش</span>
            </div>
        </section>

        <section class="rh-bento stat-sm cyan animate-frip">
            <i class="bi bi-trash" style="color: #ef4444;"></i>
            <div class="stat-info">
                <span class="v">@ToFa(Model.DeleteEvents)</span>
                <span class="l">حذف</span>
            </div>
        </section>

        <section class="rh-bento stat-sm animate-frip collab-box">
            <i class="bi bi-envelope-open" style="color: #4f46e5;"></i>
            <div class="stat-info">
                <span class="v">@ToFa(Model.NewLetters)</span>
                <span class="l">نامه خوانده نشده</span>
            </div>
        </section>

        <section class="rh-bento stat-sm animate-frip event-box">
            <i class="bi bi-calendar-event" style="color: #db2777;"></i>
            <div class="stat-info">
                <span class="v">@ToFa(Model.PendingLeaves)</span>
                <span class="l">مرخصی در انتظار</span>
            </div>
        </section>

        <section class="rh-bento chart-wide animate-frip">
            <div class="donut-chart-wrapper">
                <svg viewBox="0 0 36 36">
                    <circle cx="18" cy="18" r="16" fill="none" stroke="#e2e8f0" stroke-width="3"></circle>
                    <circle cx="18" cy="18" r="16" fill="none" stroke="var(--primary)" stroke-width="3" stroke-dasharray="@Model.WorkloadPercent, 100"></circle>
                </svg>
                <div class="donut-chart-value">@ToFa(Model.WorkloadPercent)٪</div>
            </div>
            <div class="chart-info">
                <h4>توزیع بار کاری</h4>
                <p>بر اساس نامه‌های خوانده نشده و مرخصی‌های در انتظار نسبت به کل نامه‌های ثبت شده.</p>
            </div>
        </section>

        <section class="rh-bento task-box animate-frip">
            <div class="task-header">
                <span><i class="bi bi-people-fill"></i> کاربران سامانه</span>
                <i class="bi bi-gear"></i>
            </div>
            <div class="task-body">
                <strong>@ToFa(Model.TotalUsers)</strong>
                <span>کاربر ثبت شده در سامانه</span>
            </div>
        </section>

        <section class="rh-bento calendar-box animate-frip">
            <div class="cal-header">
                <div class="cal-nav">
                    <i class="bi bi-chevron-right" id="prevMonth"></i>
                    <span id="monthDisplay">---</span>
                    <i class="bi bi-chevron-left" id="nextMonth"></i>
                </div>
                <button class="btn-today btn-action-sm" type="button">امروز</button>
            </div>

            <div class="cal-body">
                <div class="weekday-row">
                    <span>شنبه</span><span>یکشنبه</span><span>دوشنبه</span><span>سه‌شنبه</span><span>چهارشنبه</span><span>پنجشنبه</span><span>جمعه</span>
                </div>
                <div id="daysContainer" class="days-grid"></div>
            </div>

            <div class="cal-footer">
                <div id="eventBox">
                    <div id="eventLoader"></div>
                    <div id="eventContent">
                        <i class="bi bi-calendar2-event"></i>
                        <span id="eventDisplay">در حال دریافت مناسبت...</span>
                    </div>
                </div>
            </div>
        </section>
    </main>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <style>
        html.theme-dark .rhino-premium-panel {
            background: #0f172a !important;
            background-image: none !important;
        }

        .rhino-premium-panel {
            --rh-home-radius: 6px;
        }

        .rhino-premium-panel .rh-bento,
        .rhino-premium-panel .card,
        .rhino-premium-panel .table-box,
        .rhino-premium-panel .calendar-box,
        .rhino-premium-panel .task-box,
        .rhino-premium-panel .chart-wide,
        .rhino-premium-panel .hero-sm,
        .rhino-premium-panel .badge-sm,
        .rhino-premium-panel .btn-action-sm,
        .rhino-premium-panel .btn-today,
        .rhino-premium-panel input,
        .rhino-premium-panel select,
        .rhino-premium-panel textarea,
        .rhino-premium-panel button {
            border-radius: var(--rh-home-radius) !important;
        }

        .rhino-premium-panel .rh-bento {
            border-color: rgba(203, 213, 225, 0.9) !important;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.05) !important;
        }

        .rhino-premium-panel .rh-bento:hover {
            border-color: rgba(79, 70, 229, 0.35) !important;
            box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08) !important;
        }

        .rhino-premium-panel .stat-sm > i,
        .rhino-premium-panel .box-head h3 > i,
        .rhino-premium-panel .task-header i,
        .rhino-premium-panel #eventContent i {
            width: 34px !important;
            height: 34px !important;
            min-width: 34px !important;
            border-radius: var(--rh-home-radius) !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            background: #f1f5f9 !important;
            border: 1px solid #e2e8f0 !important;
            box-shadow: none !important;
            font-size: 1rem !important;
        }

        .rhino-premium-panel .box-head h3 > i,
        .rhino-premium-panel .task-header i,
        .rhino-premium-panel #eventContent i {
            color: #4f46e5 !important;
        }

        .rhino-premium-panel .css-chart div,
        .rhino-premium-panel .days-grid span,
        .rhino-premium-panel .days-grid span.today,
        .rhino-premium-panel .spinner-border-sm {
            border-radius: var(--rh-home-radius) !important;
        }

        .rhino-premium-panel .box-head a {
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        html.theme-dark .rhino-premium-panel .rh-bento {
            background: #111827 !important;
            border-color: #334155 !important;
            box-shadow: none !important;
        }

        html.theme-dark .rhino-premium-panel .stat-sm > i,
        html.theme-dark .rhino-premium-panel .box-head h3 > i,
        html.theme-dark .rhino-premium-panel .task-header i,
        html.theme-dark .rhino-premium-panel #eventContent i {
            background: #1f2937 !important;
            border-color: #334155 !important;
        }
    </style>
}

@section Scripts {
    <script src="~/js/dashboard.js"></script>
}
