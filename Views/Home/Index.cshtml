@{
    ViewData["Title"] = "میز کار";
}

<div class="container-fluid mt-4 dashboard" style="direction: rtl; text-align: right;">

    <!-- Top Bar -->
    <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
        <div class="dash-search">
            <i class="bi bi-search"></i>
            <input id="dashSearch" type="text" class="form-control" placeholder="جستجو در بخش‌ها..." autocomplete="off">
            <button type="button" class="btn btn-sm btn-light border dash-search-clear d-none" id="dashSearchClear" aria-label="پاک کردن">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

      @*   <div class="dash-clock">
            <i class="bi bi-clock ms-1"></i>
            <span id="current-persian-date"></span>
            <span class="mx-2">|</span>
            <span id="current-time-persian"></span>
        </div> *@
    </div>

    <!-- Hero -->
    <div class="dash-hero mb-4">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <h3 class="mb-1 fw-black text-dark">
                    میز کار <span class="text-primary">مرکزی</span>
                </h3>
                <div class="text-muted">
                    گزارش لحظه‌ای فعالیت‌های شما در پورتال راینو
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <a href="/Letters" class="btn btn-outline-primary">
                    <i class="bi bi-envelope ms-1"></i> کارتابل نامه‌ها
                </a>
                <a href="/Leaves" class="btn btn-primary">
                    <i class="bi bi-plus-lg ms-1"></i> درخواست جدید
                </a>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4" id="statsArea">
        <div class="col-12 col-md-6 col-xl-3">
            <a href="/Letters" class="stat-card2 stat-primary" data-keywords="نامه کارتابل جدید inbox">
                <div class="stat2-icon"><i class="bi bi-envelope-paper"></i></div>
                <div class="stat2-info">
                    <div class="stat2-label">نامه‌های جدید</div>
                    <div class="stat2-value">۵</div>
                </div>
                <div class="stat2-meta text-success">+۲ امروز</div>
            </a>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <a href="/Leaves" class="stat-card2 stat-success" data-keywords="مرخصی باقی مانده leave">
                <div class="stat2-icon"><i class="bi bi-calendar2-check"></i></div>
                <div class="stat2-info">
                    <div class="stat2-label">مرخصی مانده</div>
                    <div class="stat2-value">۱۲</div>
                </div>
                <div class="stat2-meta text-muted">روز</div>
            </a>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <a href="/Notifications" class="stat-card2 stat-warning" data-keywords="پیام سیستم اعلان notification">
                <div class="stat2-icon"><i class="bi bi-bell"></i></div>
                <div class="stat2-info">
                    <div class="stat2-label">پیام سیستم</div>
                    <div class="stat2-value">۲</div>
                </div>
                <div class="stat2-meta text-muted">باز نشده</div>
            </a>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <a href="/Letters/Sent" class="stat-card2 stat-info" data-keywords="ارسالی ماه sent نامه">
                <div class="stat2-icon"><i class="bi bi-send"></i></div>
                <div class="stat2-info">
                    <div class="stat2-label">ارسالی ماه</div>
                    <div class="stat2-value">۲۴</div>
                </div>
                <div class="stat2-meta text-muted">نامه</div>
            </a>
        </div>
    </div>

    <!-- Banner -->
    <div class="dash-banner mb-4" data-keywords="اطلاعیه ها اخبار announcements">
        <div class="banner-text">
            <div class="banner-title">پورتال هوشمند <span class="text-primary">راینو</span></div>
            <div class="banner-sub">خوش آمدید! امروز همه چیز برای مدیریت بهتر آماده است.</div>
        </div>
        <a href="/Announcements" class="btn btn-light border">
            <i class="bi bi-megaphone ms-1"></i> مشاهده اطلاعیه‌ها
        </a>
    </div>

    <!-- Content Grid -->
    <div class="row g-3" id="dashContent">

        <div class="col-12 col-lg-4">
            <div class="card dash-card h-100" data-keywords="سرمایه انسانی حضور غیاب hr">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="fw-bold">سرمایه انسانی</div>
                    <span class="badge bg-light text-success border">فعال</span>
                </div>
                <div class="dash-mini-chart">
                    <canvas id="chartDemo"></canvas>
                </div>
                <div class="text-muted small mt-2">
                    گزارش وضعیت حضور و غیاب پرسنل در ماه جاری
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <div class="card dash-card h-100" data-keywords="اسناد آخرین ثبت شده documents">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="fw-bold">آخرین اسناد ثبت شده</div>
                    <a href="/Documents" class="btn btn-sm btn-outline-secondary">مشاهده همه</a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>نوع سند</th>
                                <th style="width:140px;">تاریخ</th>
                                <th style="width:160px;">وضعیت</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="fw-semibold">فاکتور خرید</td>
                                <td>۱۴۰۲/۱۱/۲۸</td>
                                <td><span class="badge bg-info">درحال بررسی</span></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">حکم کارگزینی</td>
                                <td>۱۴۰۲/۱۱/۲۵</td>
                                <td><span class="badge bg-success">تایید نهایی</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>

</div>

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" />
}

@section Scripts {
    <script src="~/js/dashboard.js"></script>
}