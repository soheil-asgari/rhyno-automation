@model List<InventoryCounting>
@{
    ViewData["Title"] = "انبارگردانی";
    var warehouseOptions = ViewBag.WarehouseOptions as List<SelectListItem> ?? new();
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">جلسات انبارگردانی</h5>
            <div class="text-muted small">وضعیت، تاریخ و اختلاف‌ها را با فیلترهای سریع بررسی کن.</div>
        </div>
        <a asp-action="CreateCounting" class="btn btn-primary btn-sm">ثبت انبارگردانی جدید</a>
    </div>

    @if (TempData["WarehouseMessage"] is string message)
    {
        <div class="alert alert-info border-0 shadow-sm small">@message</div>
    }

    @{ ViewData["SavedFiltersTitle"] = "فیلترهای ذخیره‌شده"; ViewData["SavedFiltersSubtitle"] = "فیلترهای انبارگردانی را ذخیره کن."; ViewData["SavedFiltersSaveButtonId"] = "countingSaveFilter"; ViewData["SavedFiltersClearButtonId"] = "countingClearFilter"; ViewData["SavedFiltersContainerId"] = "countingSavedFilters"; }
    <partial name="_SavedFiltersPanel" />

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
            <form method="get" class="row g-3 align-items-end" data-warehouse-filter-form data-filters-key="warehouse-countings" data-save-button-id="countingSaveFilter" data-clear-button-id="countingClearFilter" data-presets-container-id="countingSavedFilters">
                <div class="col-12 col-md-4">
                    <label class="form-label small mb-1">جستجو</label>
                    <input name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" data-filter-key="searchTerm" placeholder="شماره سند یا وضعیت" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label small mb-1">وضعیت</label>
                    <select name="status" class="form-select" data-filter-key="status">
                        <option value="">همه وضعیت‌ها</option>
                        <option value="Draft" selected="@(ViewBag.Status as string == "Draft" ? "selected" : null)">پیش‌نویس</option>
                        <option value="Approved" selected="@(ViewBag.Status as string == "Approved" ? "selected" : null)">تایید شده</option>
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label small mb-1">انبار</label>
                    <select name="warehouseId" class="form-select" data-filter-key="warehouseId">
                        <option value="">همه انبارها</option>
                        @foreach (var option in warehouseOptions)
                        {
                            <option value="@option.Value" selected="@(option.Selected ? "selected" : null)">@option.Text</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-1">
                    <label class="form-label small mb-1">از</label>
                    <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="form-control" data-filter-key="dateFrom" />
                </div>
                <div class="col-6 col-md-1">
                    <label class="form-label small mb-1">تا</label>
                    <input type="date" name="dateTo" value="@ViewBag.DateTo" class="form-control" data-filter-key="dateTo" />
                </div>
                <div class="col-12 col-md-1">
                    <button type="submit" class="btn btn-primary w-100">اعمال</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>شماره سند</th>
                        <th>تاریخ</th>
                        <th>انبار</th>
                        <th>وضعیت</th>
                        <th>ردیف‌ها</th>
                        <th class="text-center">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.DocumentNumber</td>
                                <td>@item.DateShamsi</td>
                                <td>@item.Warehouse.Name</td>
                                <td><span class="badge @(item.Status == "Approved" ? "text-bg-success" : "text-bg-secondary")">@item.Status</span></td>
                                <td>@item.Items.Count</td>
                                <td class="text-center">
                                    <a asp-action="CountingDetails" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">جزئیات</a>
                                    @if (item.Status != "Approved")
                                    {
                                        <form asp-action="ApproveCounting" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-success">تایید</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">انبارگردانی‌ای با این فیلترها پیدا نشد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/warehouse-filters.js" asp-append-version="true"></script>
}
