@model List<InventoryCounting>
@{
    ViewData["Title"] = "انبارگردانی";
    var warehouseOptions = ViewBag.WarehouseOptions as List<SelectListItem> ?? new();
    var selectedWarehouseId = ViewBag.WarehouseId as int?;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">جلسات انبارگردانی</h6>
        <a asp-action="CreateCounting" class="btn btn-sm btn-primary">ثبت انبارگردانی</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 border-bottom">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-12 col-md-4"><label class="form-label small text-muted mb-1">جستجو</label><input name="searchTerm" value="@ViewBag.SearchTerm" class="form-control form-control-sm" placeholder="شماره سند/وضعیت" /></div>
                <div class="col-12 col-md-3">
                    <label class="form-label small text-muted mb-1">انبار</label>
                    <select name="warehouseId" class="form-select form-select-sm">
                        <option value="">همه انبارها</option>
                        @foreach (var option in warehouseOptions)
                        {
                            <option value="@option.Value" selected="@(selectedWarehouseId.HasValue && selectedWarehouseId.Value.ToString() == option.Value)">@option.Text</option>
                        }
                    </select>
                </div>
                <div class="col-auto"><button class="btn btn-sm btn-primary">اعمال</button></div>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead><tr><th>شماره سند</th><th>تاریخ</th><th>انبار</th><th>وضعیت</th><th>اقلام</th><th class="text-center">عملیات</th></tr></thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DocumentNumber</td>
                            <td>@item.DateShamsi</td>
                            <td>@item.Warehouse.Name</td>
                            <td><span class="badge @(item.Status == "Approved" ? "text-bg-success" : "text-bg-secondary")">@item.Status</span></td>
                            <td>@item.Items.Count</td>
                            <td class="text-center">
                                @if (item.Status != "Approved")
                                {
                                    <form asp-action="ApproveCounting" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-success">تایید و اعمال به موجودی</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">انبارگردانی ثبت نشده است.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
