@model WarehouseIssuanceUpsertVM
@{
    ViewData["Title"] = "ثبت خروج انبار";
    var stockSnapshotJson = ViewBag.StockSnapshotJson as string ?? "[]";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">ثبت خروج انبار</h5>
            <p class="text-muted small mb-0">پیش‌نمایش زنده، هشدار موجودی و ارسال برای بررسی</p>
        </div>
        <a asp-action="Issuances" class="btn btn-sm btn-outline-secondary">بازگشت</a>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
            <form asp-action="CreateIssuance" method="post" id="issuanceForm">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                <div class="row g-2 mb-3">
                    <div class="col-md-3"><label asp-for="IssuanceNumber" class="form-label small"></label><input asp-for="IssuanceNumber" class="form-control form-control-sm" /></div>
                    <div class="col-md-2"><label asp-for="DateShamsi" class="form-label small"></label><input asp-for="DateShamsi" class="form-control form-control-sm" /></div>
                    <div class="col-md-3"><label asp-for="WarehouseId" class="form-label small"></label><select asp-for="WarehouseId" asp-items="Model.WarehouseOptions" class="form-select form-select-sm"></select></div>
                    <div class="col-md-2">
                        <label asp-for="EmployerId" class="form-label small"></label>
                        <select asp-for="EmployerId" asp-items="Model.EmployerOptions" class="form-select form-select-sm">
                            <option value="">انتخاب کارفرما</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small">عملیات</label>
                        <button type="button" id="addIssuanceRow" class="btn btn-sm btn-outline-secondary d-block w-100">+ ردیف</button>
                    </div>
                    <div class="col-md-4 d-none"><label asp-for="DestinationOrDepartment" class="form-label small"></label><input asp-for="DestinationOrDepartment" class="form-control form-control-sm" /></div>
                    <div class="col-12"><label asp-for="Notes" class="form-label small"></label><textarea asp-for="Notes" rows="2" class="form-control form-control-sm"></textarea></div>
                </div>

                <div class="summary-bar mb-3" id="issuanceSummaryBar">
                    <div><span class="text-muted small">تعداد ردیف</span><div class="fw-bold" id="issuanceRowCount">0</div></div>
                    <div><span class="text-muted small">جمع تعداد</span><div class="fw-bold" id="issuanceTotalQty">0.000</div></div>
                    <div><span class="text-muted small">هشدار کمبود</span><div class="fw-bold" id="issuanceWarnings">0</div></div>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-xl-8">
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle" id="issuanceItemsTable">
                                <thead><tr><th>کالا</th><th>تعداد</th><th>وضعیت موجودی</th><th></th></tr></thead>
                                <tbody id="issuanceItemsBody"></tbody>
                            </table>
                        </div>
                    </div>
                    <div class="col-12 col-xl-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="fw-bold mb-3">پیش‌نمایش نهایی</h6>
                                <div class="preview-line"><span>شماره خروج</span><strong id="previewIssuanceNumber">-</strong></div>
                                <div class="preview-line"><span>تاریخ</span><strong id="previewDateShamsi">-</strong></div>
                                <div class="preview-line"><span>انبار</span><strong id="previewWarehouse">-</strong></div>
                                <div class="preview-line"><span>کارفرما</span><strong id="previewEmployer">-</strong></div>
                                <div class="preview-line"><span>ردیف‌ها</span><strong id="previewLines">0</strong></div>
                                <div class="preview-line"><span>هشدارهای کمبود</span><strong id="previewWarnings">0</strong></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <button type="submit" name="SaveAsDraft" value="true" class="btn btn-sm btn-outline-secondary">ذخیره پیش نویس</button>
                    <button type="submit" name="SaveAsDraft" value="false" class="btn btn-sm btn-success">ارسال برای بررسی</button>
                    <a asp-action="Issuances" class="btn btn-sm btn-outline-secondary">بازگشت</a>
                </div>
            </form>
        </div>
    </div>
</div>

<template id="issuanceRowTemplate">
    <tr>
        <td>
            <select data-field="ProductId" class="form-select form-select-sm product-select">
                <option value="">انتخاب کالا</option>
                @foreach (var product in Model.ProductOptions)
                {
                    <option value="@product.Value">@product.Text</option>
                }
            </select>
        </td>
        <td><input type="number" data-field="Quantity" class="form-control form-control-sm quantity-input" min="0.001" step="0.001" /></td>
        <td><div class="small text-muted row-feedback">در انتظار انتخاب کالا</div></td>
        <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger removeRow">حذف</button></td>
    </tr>
</template>

<style>
    .summary-bar {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        padding: 14px 16px;
        border: 1px solid var(--ds-border);
        border-radius: 16px;
        background: rgba(255,255,255,.65);
    }
    .preview-line {
        display:flex;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid var(--ds-border);
    }
    .preview-line:last-of-type { border-bottom: 0; }
    html[data-theme="dark"] .summary-bar,
    body[data-theme="dark"] .summary-bar { background: rgba(15,23,42,.55); }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const body = document.getElementById('issuanceItemsBody');
            const tpl = document.getElementById('issuanceRowTemplate');
            const stockSnapshot = @Html.Raw(stockSnapshotJson);
            const stockMap = new Map(stockSnapshot.map(item => [Number(item.productId), item]));
            const warehouseSelect = document.getElementById('WarehouseId');
            const employerSelect = document.getElementById('EmployerId');

            function qty(v) { return Number(v || 0).toFixed(3); }

            function updateNames() {
                [...body.querySelectorAll('tr')].forEach((row, index) => {
                    row.querySelectorAll('[data-field]').forEach(field => {
                        field.name = `Items[${index}].${field.getAttribute('data-field')}`;
                    });
                });
            }

            function updatePreview() {
                const rows = [...body.querySelectorAll('tr')];
                let totalQty = 0;
                let warningCount = 0;
                rows.forEach(row => {
                    const productId = Number(row.querySelector('[data-field="ProductId"]').value || 0);
                    const q = Number(row.querySelector('[data-field="Quantity"]').value || 0);
                    totalQty += q;
                    const feedback = row.querySelector('.row-feedback');
                    const stock = stockMap.get(productId);
                    if (!productId) {
                        feedback.textContent = 'در انتظار انتخاب کالا';
                        feedback.className = 'small text-muted row-feedback';
                        return;
                    }
                    if (!stock) {
                        feedback.textContent = 'موجودی این کالا ثبت نشده است';
                        feedback.className = 'small text-warning row-feedback';
                        warningCount++;
                        return;
                    }
                    const remaining = stock.currentQuantity - q;
                    if (remaining < 0) {
                        feedback.textContent = `کمبود موجودی: ${remaining.toFixed(3)}`;
                        feedback.className = 'small text-danger row-feedback';
                        warningCount++;
                    } else if (remaining <= stock.minimumStock) {
                        feedback.textContent = `بعد از خروج به حداقل نزدیک می‌شود: ${remaining.toFixed(3)}`;
                        feedback.className = 'small text-warning row-feedback';
                        warningCount++;
                    } else {
                        feedback.textContent = `موجودی فعلی: ${Number(stock.currentQuantity).toFixed(3)}`;
                        feedback.className = 'small text-success row-feedback';
                    }
                });

                document.getElementById('issuanceRowCount').textContent = rows.length;
                document.getElementById('issuanceTotalQty').textContent = qty(totalQty);
                document.getElementById('issuanceWarnings').textContent = warningCount;
                document.getElementById('previewIssuanceNumber').textContent = document.getElementById('IssuanceNumber').value || '-';
                document.getElementById('previewDateShamsi').textContent = document.getElementById('DateShamsi').value || '-';
                document.getElementById('previewWarehouse').textContent = warehouseSelect.selectedOptions[0]?.text || '-';
                document.getElementById('previewEmployer').textContent = employerSelect.selectedOptions[0]?.text || 'انتخاب نشده';
                document.getElementById('previewLines').textContent = rows.length;
                document.getElementById('previewWarnings').textContent = warningCount;
            }

            function addRow(item) {
                const clone = tpl.content.cloneNode(true);
                const row = clone.querySelector('tr');
                body.appendChild(clone);
                if (item) {
                    row.querySelector('[data-field="ProductId"]').value = item.productId || '';
                    row.querySelector('[data-field="Quantity"]').value = item.quantity || '';
                }
                row.querySelectorAll('input, select').forEach(el => el.addEventListener('input', () => {
                    updateNames();
                    updatePreview();
                }));
                row.querySelector('[data-field="ProductId"]').addEventListener('change', updatePreview);
                updateNames();
                updatePreview();
            }

            document.getElementById('addIssuanceRow').addEventListener('click', () => addRow());
            body.addEventListener('click', e => {
                if (!e.target.closest('.removeRow')) return;
                e.target.closest('tr')?.remove();
                if (!body.querySelector('tr')) addRow();
                updateNames();
                updatePreview();
            });

            [warehouseSelect, employerSelect, document.getElementById('IssuanceNumber'), document.getElementById('DateShamsi')].forEach(el => {
                el?.addEventListener('input', updatePreview);
                el?.addEventListener('change', updatePreview);
            });

            const initialItems = @Html.Raw(Json.Serialize(Model.Items ?? new List<WarehouseIssuanceItemVM>()));
            if (initialItems.length) initialItems.forEach(addRow); else addRow();
        })();
    </script>
}
