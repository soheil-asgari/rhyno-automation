@model List<WarehouseIssuance>
@{
    ViewData["Title"] = "خروجی‌های انبار";
    var warehouseOptions = ViewBag.WarehouseOptions as List<SelectListItem> ?? new();
    var employerOptions = ViewBag.EmployerOptions as List<SelectListItem> ?? new();
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">اسناد خروج از انبار</h5>
            <div class="text-muted small">با فیلترهای وضعیت، تاریخ، انبار و کارفرما سریع‌تر بررسی کن.</div>
        </div>
        <a asp-action="CreateIssuance" class="btn btn-primary btn-sm">ثبت خروج جدید</a>
    </div>

    @if (TempData["WarehouseMessage"] is string message)
    {
        <div class="alert alert-info border-0 shadow-sm small">@message</div>
    }

    @{ ViewData["SavedFiltersTitle"] = "فیلترهای ذخیره‌شده"; ViewData["SavedFiltersSubtitle"] = "فیلترهای خروج را ذخیره کن."; ViewData["SavedFiltersSaveButtonId"] = "issuanceSaveFilter"; ViewData["SavedFiltersClearButtonId"] = "issuanceClearFilter"; ViewData["SavedFiltersContainerId"] = "issuanceSavedFilters"; }
    <partial name="_SavedFiltersPanel" />

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
            <form method="get" class="row g-3 align-items-end" data-warehouse-filter-form data-filters-key="warehouse-issuances" data-save-button-id="issuanceSaveFilter" data-clear-button-id="issuanceClearFilter" data-presets-container-id="issuanceSavedFilters">
                <div class="col-12 col-md-3">
                    <label class="form-label small mb-1">جستجو</label>
                    <input name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" data-filter-key="searchTerm" placeholder="شماره خروج یا مقصد" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label small mb-1">وضعیت</label>
                    <select name="status" class="form-select" data-filter-key="status">
                        <option value="">همه وضعیت‌ها</option>
                        <option value="@WorkflowStatus.Draft" selected="@(ViewBag.Status as string == WorkflowStatus.Draft ? "selected" : null)">پیش‌نویس</option>
                        <option value="@WorkflowStatus.PendingApproval" selected="@(ViewBag.Status as string == WorkflowStatus.PendingApproval ? "selected" : null)">در انتظار تایید</option>
                        <option value="@WorkflowStatus.Approved" selected="@(ViewBag.Status as string == WorkflowStatus.Approved ? "selected" : null)">تایید شده</option>
                        <option value="@WorkflowStatus.Rejected" selected="@(ViewBag.Status as string == WorkflowStatus.Rejected ? "selected" : null)">رد شده</option>
                        <option value="@WorkflowStatus.Canceled" selected="@(ViewBag.Status as string == WorkflowStatus.Canceled ? "selected" : null)">ابطال شده</option>
                        <option value="@WorkflowStatus.Completed" selected="@(ViewBag.Status as string == WorkflowStatus.Completed ? "selected" : null)">انجام شده</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label small mb-1">انبار</label>
                    <select name="warehouseId" class="form-select" data-filter-key="warehouseId">
                        <option value="">همه انبارها</option>
                        @foreach (var option in warehouseOptions)
                        {
                            <option value="@option.Value" selected="@(option.Selected ? "selected" : null)">@option.Text</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label small mb-1">کارفرما</label>
                    <select name="employerId" class="form-select" data-filter-key="employerId">
                        <option value="">همه کارفرماها</option>
                        @foreach (var option in employerOptions)
                        {
                            <option value="@option.Value" selected="@(option.Selected ? "selected" : null)">@option.Text</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-1">
                    <label class="form-label small mb-1">از</label>
                    <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="form-control" data-filter-key="dateFrom" />
                </div>
                <div class="col-6 col-md-1">
                    <label class="form-label small mb-1">تا</label>
                    <input type="date" name="dateTo" value="@ViewBag.DateTo" class="form-control" data-filter-key="dateTo" />
                </div>
                <div class="col-12 col-md-1">
                    <button type="submit" class="btn btn-primary w-100">اعمال</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>شماره</th>
                        <th>تاریخ</th>
                        <th>انبار</th>
                        <th>کارفرما / مقصد</th>
                        <th>مقدار</th>
                        <th>وضعیت</th>
                        <th class="text-center">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.IssuanceNumber</td>
                                <td>@item.DateShamsi</td>
                                <td>@item.Warehouse.Name</td>
                                <td>@(item.Employer?.Name ?? item.DestinationOrDepartment)</td>
                                <td>@item.Items.Sum(row => row.Quantity).ToString("N3")</td>
                                <td><span class="badge @WorkflowStatus.BadgeCss(item.WorkflowStatus)">@WorkflowStatus.Label(item.WorkflowStatus)</span></td>
                                <td class="text-center">
                                    <a asp-action="IssuanceDetails" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">جزئیات</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">خروجی‌ای با این فیلترها پیدا نشد.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/warehouse-filters.js" asp-append-version="true"></script>
}
