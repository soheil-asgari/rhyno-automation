@model WarehouseClosingRequestVM
@{
    ViewData["Title"] = "بستن انبار پایان سال";
    var warehouseOptions = ViewBag.WarehouseOptions as List<SelectListItem> ?? new();
}

<div class="container-fluid py-4">
    <h6 class="fw-bold mb-3">بستن انبار پایان سال</h6>
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <form asp-action="Closing" method="post" class="row g-2">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="col-md-4"><label asp-for="WarehouseId" class="form-label small"></label><select asp-for="WarehouseId" asp-items="warehouseOptions" class="form-select form-select-sm"></select><span asp-validation-for="WarehouseId" class="text-danger small"></span></div>
                <div class="col-md-4"><label asp-for="ClosingDateShamsi" class="form-label small"></label><input asp-for="ClosingDateShamsi" class="form-control form-control-sm" /><span asp-validation-for="ClosingDateShamsi" class="text-danger small"></span></div>
                <div class="col-md-4"><label asp-for="ClosingYear" class="form-label small"></label><input asp-for="ClosingYear" class="form-control form-control-sm" type="number" min="1300" max="1700" /><span asp-validation-for="ClosingYear" class="text-danger small"></span></div>
                <div class="col-12 d-flex gap-2"><button class="btn btn-sm btn-danger" onclick="return confirm('آیا از بستن انبار مطمئن هستید؟');">بستن انبار و تولید افتتاحیه</button><a asp-action="Warehouses" class="btn btn-sm btn-outline-secondary">بازگشت</a></div>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
