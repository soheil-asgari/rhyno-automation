@model WarehouseClosingRequestVM
@{
    ViewData["Title"] = "بستن انبار پایان سال";
    var warehouseOptions = ViewBag.WarehouseOptions as List<SelectListItem> ?? new();
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">بستن انبار پایان سال</h5>
            <p class="text-muted small mb-0">قبل از بستن سال، همه موارد باز و مغایرت‌ها را بررسی کنید.</p>
        </div>
        <a asp-action="Warehouses" class="btn btn-outline-secondary btn-sm">بازگشت</a>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
            <form asp-action="Closing" method="post" class="row g-3">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="col-md-4">
                    <label asp-for="WarehouseId" class="form-label small"></label>
                    <select asp-for="WarehouseId" asp-items="warehouseOptions" class="form-select form-select-sm"></select>
                    <span asp-validation-for="WarehouseId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ClosingDateShamsi" class="form-label small"></label>
                    <input asp-for="ClosingDateShamsi" class="form-control form-control-sm" />
                    <span asp-validation-for="ClosingDateShamsi" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ClosingYear" class="form-label small"></label>
                    <input asp-for="ClosingYear" class="form-control form-control-sm" type="number" min="1300" max="1700" />
                    <span asp-validation-for="ClosingYear" class="text-danger small"></span>
                </div>
                <div class="col-12 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-sm btn-danger" disabled="@(!Model.CanClose)" onclick="return confirm('آیا از بستن انبار مطمئن هستید؟');">بستن انبار و تولید افتتاحیه</button>
                    <a asp-action="Warehouses" class="btn btn-sm btn-outline-secondary">بازگشت</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">چک لیست قبل از بستن سال</h6>
                <span class="badge @(Model.CanClose ? "text-bg-success" : "text-bg-warning")">@(Model.CanClose ? "مجاز" : "نیازمند اصلاح")</span>
            </div>
            <div class="row g-2">
                @foreach (var item in Model.PreflightItems)
                {
                    <div class="col-12">
                        <div class="border rounded-3 p-3 @(item.IsBlocking ? "border-danger bg-danger-subtle" : "border-success bg-success-subtle")">
                            <div class="d-flex justify-content-between gap-2">
                                <strong>@item.Title</strong>
                                <span class="badge @(item.IsBlocking ? "text-bg-danger" : "text-bg-success")">@(item.IsBlocking ? "مانع" : "مجاز")</span>
                            </div>
                            <div class="small mt-1">@item.Detail</div>
                        </div>
                    </div>
                }
                @if (!Model.PreflightItems.Any())
                {
                    <div class="col-12 text-muted small">فعلاً چک‌لیستی محاسبه نشده است.</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
