@model InventoryTransferRequestCreateVM
@{
    ViewData["Title"] = "ثبت درخواست انتقال بین انبارها";
}

@section Styles {
    <style>
        .wf-card { background: var(--glass-bg); border: 1px solid rgba(148, 163, 184, .35); }
        .transfer-create .table th,
        .transfer-create .table td {
            color: var(--text-dark) !important;
        }
        html.theme-dark .transfer-create .table th,
        html.theme-dark .transfer-create .table td,
        html.theme-dark .transfer-create .table th *,
        html.theme-dark .transfer-create .table td * {
            color: var(--text-dark) !important;
        }
        .transfer-create .dropdown-menu { z-index: 10001 !important; }
    </style>
}

<div class="container-fluid py-4 transfer-create">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">ثبت درخواست انتقال بین پروژه‌ها/انبارها</h6>
        <a asp-action="TransferRequests" class="btn btn-sm btn-outline-secondary">بازگشت</a>
    </div>

    <div class="card shadow-sm border-0 wf-card">
        <div class="card-body">
            <form asp-action="CreateTransferRequest" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="col-md-4">
                    <label asp-for="SourceWarehouseId" class="form-label small"></label>
                    <select asp-for="SourceWarehouseId" asp-items="Model.WarehouseOptions" class="form-select form-select-sm"></select>
                    <span asp-validation-for="SourceWarehouseId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DestinationWarehouseId" class="form-label small"></label>
                    <select asp-for="DestinationWarehouseId" asp-items="Model.WarehouseOptions" class="form-select form-select-sm"></select>
                    <span asp-validation-for="DestinationWarehouseId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="ProductId" class="form-label small"></label>
                    <select asp-for="ProductId" asp-items="Model.ProductOptions" class="form-select form-select-sm"></select>
                    <span asp-validation-for="ProductId" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Quantity" class="form-label small"></label>
                    <input asp-for="Quantity" class="form-control form-control-sm" />
                    <span asp-validation-for="Quantity" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-sm btn-primary">ثبت درخواست</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
