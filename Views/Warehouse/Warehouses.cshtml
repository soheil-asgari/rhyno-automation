@model List<Warehouse>
@{
    ViewData["Title"] = "انبارها";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">فهرست انبارها</h6>
        <div class="d-flex gap-2">
            <a asp-action="Closing" class="btn btn-sm btn-outline-danger">بستن انبار پایان سال</a>
            <a asp-action="CreateWarehouse" class="btn btn-sm btn-primary">انبار جدید</a>
        </div>
    </div>

    @if (TempData["WarehouseMessage"] is string message)
    {
        <div class="alert alert-info py-2 small">@message</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 border-bottom">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label small text-muted mb-1">جستجو</label>
                    <input name="searchTerm" value="@ViewBag.SearchTerm" class="form-control form-control-sm" placeholder="نام/کد/موقعیت" />
                </div>
                <div class="col-auto"><button class="btn btn-sm btn-primary">اعمال</button></div>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead><tr><th>کد</th><th>نام</th><th>موقعیت</th><th>وضعیت</th><th class="text-center">عملیات</th></tr></thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Code</td>
                            <td>@item.Name</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Location) ? "-" : item.Location)</td>
                            <td>
                                <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? "فعال" : "غیرفعال")</span>
                                <span class="badge @(item.IsClosed ? "text-bg-danger" : "text-bg-primary")">@(item.IsClosed ? "بسته" : "باز")</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="EditWarehouse" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">ویرایش</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" class="text-center text-muted py-3">انباری یافت نشد.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
