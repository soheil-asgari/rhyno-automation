@model InventoryStockIndexVM
@{
    ViewData["Title"] = "موجودی انبار";
    var warehouseOptions = ViewBag.WarehouseOptions as List<SelectListItem> ?? new();
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">موجودی جاری انبار</h6>
        <div class="d-flex gap-2">
            <a asp-controller="Financial" asp-action="ExportStockExcel" asp-route-warehouseId="@Model.WarehouseId" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 border-bottom">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label asp-for="SearchTerm" class="form-label small text-muted mb-1">جستجو</label>
                    <input asp-for="SearchTerm" class="form-control form-control-sm" placeholder="نام یا کد کالا" />
                </div>
                <div class="col-6 col-md-3">
                    <label asp-for="WarehouseId" class="form-label small text-muted mb-1">انبار</label>
                    <select asp-for="WarehouseId" asp-items="warehouseOptions" class="form-select form-select-sm">
                        <option value="">همه انبارها</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary">اعمال</button>
                </div>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead><tr><th>کد</th><th>کالا</th><th>واحد</th><th>انبار</th><th>حداقل</th><th>ورودی</th><th>خروجی</th><th>موجودی فعلی</th><th>آخرین بروزرسانی</th></tr></thead>
                <tbody>
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        var isLowStock = item.CurrentQuantity <= item.MinimumStock;
                        <tr>
                            <td>@item.ProductCode</td>
                            <td>@item.ProductName</td>
                            <td>@item.Unit</td>
                            <td>@item.WarehouseName</td>
                            <td>@item.MinimumStock</td>
                            <td class="text-success">@item.TotalInput.ToString("N3")</td>
                            <td class="text-danger">@item.TotalOutput.ToString("N3")</td>
                            <td class="fw-semibold @(isLowStock ? "text-danger" : "")">@item.CurrentQuantity.ToString("N3")</td>
                            <td>@item.UpdatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="9" class="text-center text-muted py-3">موجودی یافت نشد.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
