@model InventoryCountingUpsertVM
@{
    ViewData["Title"] = "ثبت انبارگردانی";
    var stockSnapshotJson = ViewBag.StockSnapshotJson as string ?? "[]";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">ثبت انبارگردانی</h5>
            <p class="text-muted small mb-0">مغایرت، جمع‌ها و پیش‌نمایش نهایی قبل از ثبت</p>
        </div>
        <a asp-action="Countings" class="btn btn-sm btn-outline-secondary">بازگشت</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <form asp-action="CreateCounting" method="post" id="countingForm">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                <div class="row g-2 mb-3">
                    <div class="col-md-3"><label asp-for="DocumentNumber" class="form-label small"></label><input asp-for="DocumentNumber" class="form-control form-control-sm" /></div>
                    <div class="col-md-2"><label asp-for="DateShamsi" class="form-label small"></label><input asp-for="DateShamsi" class="form-control form-control-sm" /></div>
                    <div class="col-md-2"><label asp-for="WarehouseId" class="form-label small"></label><select asp-for="WarehouseId" asp-items="Model.WarehouseOptions" class="form-select form-select-sm"></select></div>
                    <div class="col-md-2"><label asp-for="Status" class="form-label small"></label><select asp-for="Status" class="form-select form-select-sm"><option value="Draft">پیش نویس</option><option value="Approved">تایید شده</option></select></div>
                    <div class="col-md-3"><label class="form-label small">عملیات</label><button type="button" id="addCountingRow" class="btn btn-sm btn-outline-secondary d-block w-100">+ ردیف</button></div>
                    <div class="col-12"><label asp-for="Notes" class="form-label small"></label><textarea asp-for="Notes" rows="2" class="form-control form-control-sm"></textarea></div>
                </div>

                <div class="summary-bar mb-3">
                    <div><span class="text-muted small">تعداد ردیف</span><div class="fw-bold" id="countingRowCount">0</div></div>
                    <div><span class="text-muted small">جمع مغایرت</span><div class="fw-bold" id="countingDiscrepancy">0.000</div></div>
                    <div><span class="text-muted small">هشدار</span><div class="fw-bold" id="countingWarnings">0</div></div>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-xl-8">
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle" id="countingItemsTable">
                                <thead><tr><th>کالا</th><th>موجودی سیستمی</th><th>موجودی شمارش</th><th>اختلاف</th><th>وضعیت</th><th></th></tr></thead>
                                <tbody id="countingItemsBody"></tbody>
                            </table>
                        </div>
                    </div>
                    <div class="col-12 col-xl-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="fw-bold mb-3">پیش‌نمایش نهایی</h6>
                                <div class="preview-line"><span>شماره سند</span><strong id="previewDocumentNumber">-</strong></div>
                                <div class="preview-line"><span>تاریخ</span><strong id="previewDateShamsi">-</strong></div>
                                <div class="preview-line"><span>انبار</span><strong id="previewWarehouse">-</strong></div>
                                <div class="preview-line"><span>ردیف‌ها</span><strong id="previewLines">0</strong></div>
                                <div class="preview-line"><span>مغایرت کل</span><strong id="previewDiscrepancy">0.000</strong></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <button type="submit" class="btn btn-sm btn-success">ثبت</button>
                    <a asp-action="Countings" class="btn btn-sm btn-outline-secondary">بازگشت</a>
                </div>
            </form>
        </div>
    </div>
</div>

<template id="countingRowTemplate">
    <tr>
        <td>
            <select data-field="ProductId" class="form-select form-select-sm product-select">
                <option value="">انتخاب کالا</option>
                @foreach (var product in Model.ProductOptions)
                {
                    <option value="@product.Value">@product.Text</option>
                }
            </select>
        </td>
        <td><input type="number" data-field="SystemQuantity" class="form-control form-control-sm system-qty" min="0" step="0.001" readonly /></td>
        <td><input type="number" data-field="PhysicalQuantity" class="form-control form-control-sm physical-qty" min="0" step="0.001" /></td>
        <td><input type="number" data-field="DiscrepancyQuantity" class="form-control form-control-sm discrepancy-qty" readonly /></td>
        <td><div class="small text-muted row-feedback">در انتظار انتخاب کالا</div></td>
        <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger removeRow">حذف</button></td>
    </tr>
</template>

<style>
    .summary-bar {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        padding: 14px 16px;
        border: 1px solid var(--ds-border);
        border-radius: 16px;
        background: rgba(255,255,255,.65);
    }
    .preview-line {
        display:flex;
        justify-content: space-between;
        gap: 12px;
        padding: 10px 0;
        border-bottom: 1px solid var(--ds-border);
    }
    .preview-line:last-of-type { border-bottom: 0; }
    html[data-theme="dark"] .summary-bar,
    body[data-theme="dark"] .summary-bar { background: rgba(15,23,42,.55); }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const body = document.getElementById('countingItemsBody');
            const tpl = document.getElementById('countingRowTemplate');
            const stockSnapshot = @Html.Raw(stockSnapshotJson);
            const stockMap = new Map(stockSnapshot.map(item => [Number(item.productId), item]));
            const warehouseSelect = document.getElementById('WarehouseId');

            function qty(v) { return Number(v || 0).toFixed(3); }

            function updateNames() {
                [...body.querySelectorAll('tr')].forEach((row, index) => {
                    row.querySelectorAll('[data-field]').forEach(field => {
                        field.name = `Items[${index}].${field.getAttribute('data-field')}`;
                    });
                });
            }

            function updatePreview() {
                const rows = [...body.querySelectorAll('tr')];
                let totalDiscrepancy = 0;
                let warningCount = 0;
                rows.forEach(row => {
                    const productId = Number(row.querySelector('[data-field="ProductId"]').value || 0);
                    const physical = Number(row.querySelector('[data-field="PhysicalQuantity"]').value || 0);
                    const feedback = row.querySelector('.row-feedback');
                    const stock = stockMap.get(productId);
                    if (!productId) {
                        feedback.textContent = 'در انتظار انتخاب کالا';
                        feedback.className = 'small text-muted row-feedback';
                        row.querySelector('[data-field="SystemQuantity"]').value = '';
                        row.querySelector('[data-field="DiscrepancyQuantity"]').value = '';
                        return;
                    }

                    if (!stock) {
                        feedback.textContent = 'موجودی سیستمی پیدا نشد';
                        feedback.className = 'small text-warning row-feedback';
                        warningCount++;
                        row.querySelector('[data-field="SystemQuantity"]').value = 0;
                    } else {
                        row.querySelector('[data-field="SystemQuantity"]').value = stock.currentQuantity;
                        feedback.textContent = `حداقل: ${stock.minimumStock} | موجودی: ${Number(stock.currentQuantity).toFixed(3)}`;
                        feedback.className = 'small text-success row-feedback';
                    }

                    const system = Number(row.querySelector('[data-field="SystemQuantity"]').value || 0);
                    const discrepancy = physical - system;
                    row.querySelector('[data-field="DiscrepancyQuantity"]').value = discrepancy.toFixed(3);
                    totalDiscrepancy += discrepancy;
                    if (Math.abs(discrepancy) > 0) warningCount++;
                });

                document.getElementById('countingRowCount').textContent = rows.length;
                document.getElementById('countingDiscrepancy').textContent = qty(totalDiscrepancy);
                document.getElementById('countingWarnings').textContent = warningCount;
                document.getElementById('previewDocumentNumber').textContent = document.getElementById('DocumentNumber').value || '-';
                document.getElementById('previewDateShamsi').textContent = document.getElementById('DateShamsi').value || '-';
                document.getElementById('previewWarehouse').textContent = warehouseSelect.selectedOptions[0]?.text || '-';
                document.getElementById('previewLines').textContent = rows.length;
                document.getElementById('previewDiscrepancy').textContent = qty(totalDiscrepancy);
            }

            function addRow(item) {
                const clone = tpl.content.cloneNode(true);
                const row = clone.querySelector('tr');
                body.appendChild(clone);
                if (item) {
                    row.querySelector('[data-field="ProductId"]').value = item.productId || '';
                    row.querySelector('[data-field="SystemQuantity"]').value = item.systemQuantity || 0;
                    row.querySelector('[data-field="PhysicalQuantity"]').value = item.physicalQuantity || 0;
                    row.querySelector('[data-field="DiscrepancyQuantity"]').value = item.discrepancyQuantity || 0;
                }
                row.querySelectorAll('input, select').forEach(el => el.addEventListener('input', () => {
                    updateNames();
                    updatePreview();
                }));
                row.querySelector('[data-field="ProductId"]').addEventListener('change', updatePreview);
                updateNames();
                updatePreview();
            }

            document.getElementById('addCountingRow').addEventListener('click', () => addRow());
            body.addEventListener('click', e => {
                if (!e.target.closest('.removeRow')) return;
                e.target.closest('tr')?.remove();
                if (!body.querySelector('tr')) addRow();
                updateNames();
                updatePreview();
            });

            [warehouseSelect, document.getElementById('DocumentNumber'), document.getElementById('DateShamsi')].forEach(el => {
                el?.addEventListener('input', updatePreview);
                el?.addEventListener('change', updatePreview);
            });

            const initialItems = @Html.Raw(Json.Serialize(Model.Items ?? new List<InventoryCountingItemVM>()));
            if (initialItems.length) initialItems.forEach(addRow); else addRow();
        })();
    </script>
}
