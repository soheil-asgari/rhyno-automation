@model ProductUpsertVM
@{
    ViewData["Title"] = "ثبت کالا";
}

<div class="container-fluid py-4">
    <h6 class="fw-bold mb-3">ثبت کالای جدید</h6>
    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <form asp-action="CreateProduct" method="post" class="row g-2">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="col-md-4"><label asp-for="Code" class="form-label small"></label><input asp-for="Code" class="form-control form-control-sm" /><span asp-validation-for="Code" class="text-danger small"></span></div>
                <div class="col-md-4"><label asp-for="Name" class="form-label small"></label><input asp-for="Name" class="form-control form-control-sm" /><span asp-validation-for="Name" class="text-danger small"></span></div>
                <div class="col-md-2"><label asp-for="Unit" class="form-label small"></label><input asp-for="Unit" class="form-control form-control-sm" /><span asp-validation-for="Unit" class="text-danger small"></span></div>
                <div class="col-md-2 d-flex align-items-end"><div class="form-check"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label small"></label></div></div>
                <div class="col-12"><label asp-for="Description" class="form-label small"></label><textarea asp-for="Description" rows="2" class="form-control form-control-sm"></textarea></div>
                <div class="col-12 d-flex gap-2"><button class="btn btn-sm btn-success">ذخیره</button><a asp-action="Products" class="btn btn-sm btn-outline-secondary">بازگشت</a></div>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
