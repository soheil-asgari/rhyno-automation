@model List<Product>
@{
    ViewData["Title"] = "کالاها";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">فهرست کالاها</h6>
        <div class="d-flex gap-2">
            <a asp-action="Warehouses" class="btn btn-sm btn-outline-secondary">انبارها</a>
            <a asp-action="CreateProduct" class="btn btn-sm btn-primary">کالای جدید</a>
        </div>
    </div>

    @if (TempData["WarehouseMessage"] is string message)
    {
        <div class="alert alert-info py-2 small">@message</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 border-bottom">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label small text-muted mb-1">جستجو</label>
                    <input name="searchTerm" value="@ViewBag.SearchTerm" class="form-control form-control-sm" placeholder="نام یا کد کالا" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-sm btn-primary">اعمال</button>
                </div>
            </form>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead><tr><th>کد</th><th>نام</th><th>واحد</th><th>حداقل موجودی</th><th>وضعیت</th><th class="text-center">عملیات</th></tr></thead>
                <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Code</td>
                            <td>@item.Name</td>
                            <td>@item.Unit</td>
                            <td>@item.MinimumStock</td>
                            <td>
                                <span class="badge @(item.IsActive ? "text-bg-success" : "text-bg-secondary")">@(item.IsActive ? "فعال" : "غیرفعال")</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="EditProduct" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">ویرایش</a>
                                <form asp-action="ToggleProductStatus" asp-route-id="@item.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-warning">تغییر وضعیت</button>
                                </form>
                                <form asp-action="DeleteProduct" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('حذف/غیرفعال‌سازی کالا انجام شود؟');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger">حذف</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">موردی یافت نشد.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
