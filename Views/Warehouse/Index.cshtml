@model WarehouseDashboardVM
@{
    ViewData["Title"] = "انبارداری";
}

@section Styles {
    <style>
        .wh-page { direction: rtl; text-align: right; }
        .wh-card { border-radius: 12px; }
        .wh-stat { font-size: .78rem; color: #64748b; }
        .wh-value { font-size: 1.15rem; font-weight: 700; color: #0f172a; }
    </style>
}

<div class="container-fluid py-4 wh-page">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">مدیریت انبارداری</h5>
            <p class="text-muted small mb-0">رسید، خروج، موجودی و انبارگردانی یکپارچه</p>
        </div>
    </div>

    <div class="row g-2 g-md-3 mb-3">
        <div class="col-6 col-md-2"><div class="card border-0 shadow-sm wh-card"><div class="card-body py-2"><div class="wh-stat">کالا</div><div class="wh-value">@Model.ProductCount</div></div></div></div>
        <div class="col-6 col-md-2"><div class="card border-0 shadow-sm wh-card"><div class="card-body py-2"><div class="wh-stat">انبار</div><div class="wh-value">@Model.WarehouseCount</div></div></div></div>
        <div class="col-6 col-md-2"><div class="card border-0 shadow-sm wh-card"><div class="card-body py-2"><div class="wh-stat">رسید</div><div class="wh-value">@Model.ReceiptCount</div></div></div></div>
        <div class="col-6 col-md-2"><div class="card border-0 shadow-sm wh-card"><div class="card-body py-2"><div class="wh-stat">خروج</div><div class="wh-value">@Model.IssuanceCount</div></div></div></div>
        <div class="col-6 col-md-2"><div class="card border-0 shadow-sm wh-card"><div class="card-body py-2"><div class="wh-stat">انبارگردانی Draft</div><div class="wh-value">@Model.CountingDraftCount</div></div></div></div>
        <div class="col-6 col-md-2"><div class="card border-0 shadow-sm wh-card"><div class="card-body py-2"><div class="wh-stat">کسری/صفر</div><div class="wh-value text-danger">@Model.LowStockCount</div></div></div></div>
    </div>

    <div class="card border-0 shadow-sm wh-card">
        <div class="card-body p-3">
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-sm btn-outline-primary" asp-action="Products">کالاها</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Warehouses">انبارها</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Receipts">رسید انبار</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Issuances">خروج انبار</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Stock">موجودی</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Countings">انبارگردانی</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Closing">بستن پایان سال</a>
            </div>
        </div>
    </div>
</div>
