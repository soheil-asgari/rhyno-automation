@model PayrollHistoryIndexViewModel
@{
    ViewData["Title"] = "سوابق لیست حقوق";
    var quickActions = new List<OfficeAutomation.Models.FinancialQuickActionVM>
    {
        new() { Title = "ایجاد لیست", Description = "ساخت لیست حقوق جدید", Url = Url.Action("Create", "Payroll") ?? "#", Icon = "bi-plus-circle", Tone = "primary" },
        new() { Title = "هاب مالی", Description = "بازگشت به هاب مالی", Url = Url.Action("Dashboard", "Financial") ?? "#", Icon = "bi-speedometer2", Tone = "success" },
        new() { Title = "گزارش‌ها", Description = "ورود به گزارش‌ساز", Url = Url.Action("Index", "Reports") ?? "#", Icon = "bi-file-earmark-bar-graph", Tone = "warning" }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/Bimeh.css" asp-append-version="true" />
}

<div class="container-fluid py-4 bimeh-page">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h5 class="fw-bold mb-1">سوابق لیست حقوق و دستمزد</h5>
            <p class="text-muted small mb-0">مرور لیست‌های ذخیره‌شده و وضعیت نهایی‌سازی</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-sm px-3">ایجاد لیست حقوق جدید</a>
    </div>

    <div class="mb-3">
        <partial name="_QuickActionsGrid" model="quickActions" />
    </div>

    <div class="mb-3 px-1">
        <div class="d-flex flex-wrap gap-2 align-items-center small text-muted">
            <span>وضعیت‌های لیست:</span>
            <span>پیش‌نویس</span>
            <span>/</span>
            <span>محاسبه‌شده</span>
            <span>/</span>
            <span>بررسی‌شده</span>
            <span>/</span>
            <span>نهایی‌شده</span>
            <span>/</span>
            <span>پرداخت‌شده</span>
            <span>/</span>
            <span>بازگشایی‌شده</span>
        </div>
        <div class="small text-muted mt-1">برای مقایسه ماه جاری، وارد ایجاد یا جزئیات شوید.</div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 bimeh-table">
                <thead>
                    <tr>
                        <th>سال</th>
                        <th>ماه</th>
                        <th>جمع حقوق پایه</th>
                        <th>جمع بیمه</th>
                        <th>جمع خالص پرداختی</th>
                        <th>وضعیت</th>
                        <th class="text-center">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.Year</td>
                                <td>@item.Month</td>
                                <td>@item.TotalBaseSalary.ToString("N0")</td>
                                <td>@item.TotalInsurance.ToString("N0")</td>
                                <td>@item.TotalNetPayable.ToString("N0")</td>
                                <td>
                                    <span class="badge @(item.IsFinalized ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning")">
                                        @(item.IsFinalized ? "نهایی‌شده" : "پیش‌نویس")
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (item.IsFinalized)
                                    {
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">مشاهده</a>
                                    }
                                    else
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">ویرایش</a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <partial name="_EmptyState" model='new { Icon = "bi-receipt", Title = "هنوز لیست حقوقی ثبت نشده است.", Description = "اولین لیست را از بخش ایجاد بسازید." }' />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
