@model PayrollListPageViewModel
@{
    ViewData["Title"] = "ایجاد لیست حقوق";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Bimeh.css" asp-append-version="true" />
    <style>
        .payroll-header {
            display: flex;
            justify-content: space-between;
            align-items: start;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1.25rem;
        }
        .payroll-status {
            border-radius: 999px;
            padding: .4rem .75rem;
            font-size: .82rem;
            font-weight: 700;
            background: #eef2ff;
            color: #3730a3;
            border: 1px solid #c7d2fe;
        }
        .payroll-shell {
            border-radius: 1rem;
            border: 1px solid #e2e8f0;
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        }
        .payroll-summary-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: .75rem;
            margin-bottom: 1rem;
        }
        .payroll-summary-item {
            border: 1px solid #e2e8f0;
            border-radius: .85rem;
            padding: .85rem;
            background: #fff;
        }
        .payroll-summary-item .label {
            font-size: .8rem;
            color: #64748b;
            margin-bottom: .2rem;
        }
        .payroll-summary-item .value {
            font-size: 1.1rem;
            font-weight: 700;
            color: #0f172a;
        }
        .employee-autocomplete { position: relative; }
        .employee-suggestions {
            position: absolute;
            top: calc(100% + 4px);
            right: 0;
            left: 0;
            z-index: 9999 !important;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 12px 28px rgba(15, 23, 42, .12);
            max-height: 260px;
            overflow-y: auto;
            display: none;
        }
        .employee-suggestion-item {
            width: 100%;
            border: 0;
            background: transparent;
            text-align: right;
            padding: .6rem .8rem;
        }
        .employee-suggestion-item:hover { background: #f8fafc; }
        .payroll-shell,
        .payroll-shell .table-responsive,
        .payroll-shell table,
        .payroll-shell tbody,
        .payroll-shell tr,
        .payroll-shell td {
            overflow: visible !important;
        }
        .payroll-shell td { position: relative; }
        .calculated-field {
            background: #f8fafc;
            color: #0f172a;
            font-weight: 600;
        }
        @@media (max-width: 992px) {
            .payroll-summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }
        @@media (max-width: 576px) {
            .payroll-summary-grid { grid-template-columns: 1fr; }
        }
    </style>
}

<div class="container-fluid py-4 bimeh-page">
    <div class="payroll-header">
        <div>
            <h5 class="fw-bold mb-1">ایجاد لیست حقوق</h5>
            <p class="text-muted small mb-0">دریافت اطلاعات از سرمایه انسانی و محاسبه ماهانه حقوق</p>
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <a asp-controller="Financial" asp-action="Dashboard" class="btn btn-sm btn-outline-secondary">هاب مالی</a>
            <span class="payroll-status">وضعیت: @(Model.IsFinalized ? "نهایی‌شده" : "پیش‌نویس")</span>
        </div>
    </div>

    <div class="payroll-shell p-3 p-md-4 shadow-sm">
        <div class="payroll-summary-grid mb-3" id="payrollSummary">
            <div class="payroll-summary-item">
                <div class="label">جمع حقوق پایه</div>
                <div class="value" id="totalBaseSalary">0 ریال</div>
            </div>
            <div class="payroll-summary-item">
                <div class="label">جمع حق بیمه</div>
                <div class="value" id="totalInsurance">0 ریال</div>
            </div>
            <div class="payroll-summary-item">
                <div class="label">جمع مالیات</div>
                <div class="value" id="totalTax">0 ریال</div>
            </div>
            <div class="payroll-summary-item">
                <div class="label">جمع خالص پرداختی</div>
                <div class="value" id="totalNetPayable">0 ریال</div>
            </div>
        </div>

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 py-2 px-1 mb-3 border-top border-bottom">
            <div>
                <div class="small text-muted">مقایسه با ماه قبل</div>
                <div class="fw-bold @(Model.NetPayableDelta >= 0 ? "text-warning" : "text-success")">@Model.NetPayableDelta.ToString("N0") ریال</div>
            </div>
            <div>
                <div class="small text-muted">ردیف‌های بدون قفل سرمایه انسانی</div>
                <div class="fw-bold @(Model.MissingHrLockCount > 0 ? "text-danger" : "text-success")">@Model.MissingHrLockCount</div>
            </div>
            <div>
                <div class="small text-muted">وضعیت کیفیت داده</div>
                <div class="fw-bold @(Model.DataQualityWarnings > 0 ? "text-warning" : "text-success")">@(Model.DataQualityWarnings > 0 ? "نیاز به بررسی" : "تایید شده")</div>
            </div>
        </div>

        @if (Model.Warnings.Any())
        {
            <div class="mb-3">
                @foreach (var warning in Model.Warnings)
                {
                    <div class="alert alert-@warning.Tone small mb-2">
                        <strong>@warning.Title:</strong> @warning.Description
                    </div>
                }
            </div>
        }

        <form id="payrollForm">
            @Html.AntiForgeryToken()

            <div class="row g-3 align-items-end mb-3">
                <div class="col-6 col-md-2">
                    <label class="form-label">ماه</label>
                    <select id="payrollMonth" class="form-select">
                        @for (var m = 1; m <= 12; m++)
                        {
                            <option value="@m" selected="@(m == Model.Month ? "selected" : null)">@m</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label">سال</label>
                    <input id="payrollYear" type="number" min="1300" max="1600" class="form-control" value="@Model.Year" />
                </div>
                <div class="col-12 col-md-8 text-md-end">
                    <button type="submit" class="btn btn-primary">ذخیره لیست</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle bimeh-table" id="payrollTable">
                    <thead>
                        <tr>
                            <th>کارمند</th>
                            <th>حقوق پایه</th>
                            <th>بیمه</th>
                            <th>مالیات</th>
                            <th>خالص پرداختی</th>
                        </tr>
                    </thead>
                    <tbody id="payrollRows"></tbody>
                </table>
            </div>
        </form>
    </div>
</div>

<template id="payrollRowTemplate">
    <tr>
        <td>
            <input data-field="FullName" class="form-control" placeholder="جستجو نام/کد پرسنلی" autocomplete="off" />
            <input type="hidden" data-field="HumanCapitalEmployeeId" />
            <div class="employee-suggestions"></div>
        </td>
        <td><input data-field="BaseSalary" class="form-control calculated-field" /></td>
        <td><input data-field="Insurance" class="form-control calculated-field" /></td>
        <td><input data-field="Tax" class="form-control calculated-field" /></td>
        <td><input data-field="NetPayable" class="form-control calculated-field" /></td>
    </tr>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const rowsContainer = document.getElementById('payrollRows');
            const rowTemplate = document.getElementById('payrollRowTemplate');
            const monthField = document.getElementById('payrollMonth');
            const yearField = document.getElementById('payrollYear');

            if (rowsContainer && rowTemplate) {
                rowsContainer.appendChild(rowTemplate.content.cloneNode(true));
            }
        })();
    </script>
}
