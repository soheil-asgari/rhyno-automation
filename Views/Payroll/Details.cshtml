@model PayrollDetailsViewModel
@{
    ViewData["Title"] = "جزئیات لیست حقوق";
}

<div class="container-fluid py-4 bimeh-page">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">جزئیات لیست حقوق</h5>
            <p class="text-muted small mb-0">مشاهده خواندنی لیست ذخیره‌شده بدون امکان ویرایش</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">بازگشت</a>
            <a asp-controller="Financial" asp-action="ExportPayrollExcel" asp-route-year="@Model.Year" asp-route-month="@Model.Month" class="btn btn-outline-success btn-sm">خروجی اکسل</a>
            @if (Model.Items.Any())
            {
                <a asp-controller="Financial" asp-action="PrintPayslipPdf" asp-route-payrollListId="@Model.Id" asp-route-payrollItemId="@Model.Items.First().Id" class="btn btn-outline-dark btn-sm">چاپ PDF</a>
            }
            else
            {
                <button type="button" class="btn btn-outline-dark btn-sm" disabled>چاپ PDF</button>
            }
        </div>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100"><div class="card-body p-3"><small class="text-muted d-block">سال/ماه</small><strong>@Model.Year / @Model.Month</strong></div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100"><div class="card-body p-3"><small class="text-muted d-block">جمع حقوق پایه</small><strong>@Model.TotalBaseSalary.ToString("N0")</strong></div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100"><div class="card-body p-3"><small class="text-muted d-block">جمع بیمه</small><strong>@Model.TotalInsurance.ToString("N0")</strong></div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100"><div class="card-body p-3"><small class="text-muted d-block">جمع خالص پرداختی</small><strong>@Model.TotalNetPayable.ToString("N0")</strong></div></div>
        </div>
    </div>

    <div class="row g-2 mb-3">
        @foreach (var summary in Model.ChangeSummary)
        {
            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3">
                        <small class="text-muted d-block">@summary.Label</small>
                        <strong class="d-block text-@summary.Tone">@summary.Value</strong>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="small text-muted">وضعیت لیست</span>
                <span class="badge @(Model.IsFinalized ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning")">@(Model.IsFinalized ? "Finalized" : "Draft")</span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0 bimeh-table">
                    <thead>
                        <tr>
                            <th>کارمند</th>
                            <th>حقوق پایه</th>
                            <th>مزایا</th>
                            <th>اضافه‌کار</th>
                            <th>بیمه</th>
                            <th>مالیات</th>
                            <th>خالص دریافتی</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.EmployeeName</td>
                                    <td>@item.BaseSalary.ToString("N0")</td>
                                    <td>@item.Allowance.ToString("N0")</td>
                                    <td>@item.Overtime.ToString("N0")</td>
                                    <td>@item.InsuranceDeduction.ToString("N0")</td>
                                    <td>@item.Tax.ToString("N0")</td>
                                    <td>@item.NetPayable.ToString("N0")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="7" class="text-center text-muted py-3">ردیفی ثبت نشده است.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
