@model ReportsIndexViewModel
@{
    ViewData["Title"] = "گزارش‌ها و خروجی‌ها";
}

<div class="page-shell reports-page" dir="rtl">
    <section class="reports-hero">
        <div class="reports-hero-copy">
            <span class="reports-eyebrow">مرکز گزارش‌ها</span>
            <h1 class="section-title">گزارش‌ها و خروجی‌ها</h1>
            <p class="section-subtitle">
                گزارش‌های عملیاتی، مدیریتی و انطباق را از یک صفحه واحد باز کنید؛
                خروجی‌های اکسل سریع بگیرید و بین ماژول‌های تحلیلی جابه‌جا شوید.
            </p>
        </div>
        <div class="reports-hero-actions">
            <a href="#report-sections" class="btn btn-primary">
                <i class="bi bi-grid-1x2"></i>
                مرور گزارش‌ها
            </a>
            <button type="button" class="btn btn-outline-secondary" onclick="window.print()">
                <i class="bi bi-printer"></i>
                چاپ صفحه
            </button>
        </div>
    </section>

    <section class="reports-summary-grid">
        @foreach (var card in Model.SummaryCards)
        {
            <article class="report-summary-card report-tone-@card.Tone">
                <div class="report-summary-top">
                    <span class="summary-label">@card.Title</span>
                    <span class="report-tone-pill">@card.Tone</span>
                </div>
                <div class="summary-value">@card.Value</div>
                <p class="summary-desc">@card.Description</p>
            </article>
        }
    </section>

    <section class="report-filter-bar">
        <div>
            <div class="filter-title">فیلترهای سریع</div>
            <p class="filter-subtitle">برای دسترسی سریع به بازه‌های پرکاربرد و نماهای مقایسه‌ای.</p>
        </div>
        <div class="filter-actions">
            @foreach (var preset in Model.FilterPresets)
            {
                <a href="@preset.Url" class="report-chip">
                    <i class="bi bi-funnel"></i>
                    @preset.Label
                </a>
            }
        </div>
    </section>

    <div id="report-sections" class="reports-section-stack">
        @foreach (var reportSection in Model.Sections)
        {
            <section class="report-section report-tone-@reportSection.Tone">
                <div class="report-section-head">
                    <div>
                        <div class="report-section-kicker">دسته‌بندی</div>
                        <h2 class="report-section-title">@reportSection.Title</h2>
                        <p class="report-section-desc">@reportSection.Description</p>
                    </div>
                    <span class="report-section-badge">@reportSection.Modules.Count ماژول</span>
                </div>

                <div class="reports-grid">
                    @foreach (var module in reportSection.Modules)
                    {
                        <article class="report-module-card">
                            <div class="report-module-head">
                                <div class="report-icon report-tone-@module.Tone">
                                    <i class="bi @module.Icon"></i>
                                </div>
                                <div>
                                    <h3 class="report-title">@module.Title</h3>
                                    <p class="report-description">@module.Description</p>
                                </div>
                            </div>

                            <div class="report-actions">
                                @foreach (var action in module.Actions)
                                {
                                    var icon = action.Kind == "Excel" ? "bi-file-earmark-excel" : action.Kind == "Search" ? "bi-search" : "bi-bar-chart";
                                    var cssClass = action.Kind == "Excel" ? "report-action report-action-excel" : "report-action";
                                    <a href="@action.Url" class="@cssClass">
                                        <i class="bi @icon"></i>
                                        @action.Label
                                    </a>
                                }
                            </div>
                        </article>
                    }
                </div>
            </section>
        }

        <section class="report-section report-section-legacy">
            <div class="report-section-head">
                <div>
                    <div class="report-section-kicker">دسترسی قدیمی</div>
                    <h2 class="report-section-title">خروجی‌های قدیمی</h2>
                    <p class="report-section-desc">
                        این میانبرها برای سازگاری با مسیرهای قبلی نگه داشته شده‌اند تا در زمان دمو یا مهاجرت،
                        دسترسی مستقیم به اکسل‌ها و جست‌وجوهای قدیمی از بین نرود.
                    </p>
                </div>
                <span class="report-section-badge report-section-badge-muted">سازگاری</span>
            </div>

            <div class="reports-grid">
                @foreach (var module in Model.Modules)
                {
                    <article class="report-module-card report-module-card-legacy">
                        <div class="report-module-head">
                            <div class="report-icon report-tone-@module.Tone">
                                <i class="bi @module.Icon"></i>
                            </div>
                            <div>
                                <h3 class="report-title">@module.Title</h3>
                                <p class="report-description">@module.Description</p>
                            </div>
                        </div>

                        <div class="report-actions">
                            @foreach (var action in module.Actions)
                            {
                                var icon = action.Kind == "Excel" ? "bi-file-earmark-excel" : action.Kind == "Search" ? "bi-search" : "bi-bar-chart";
                                var cssClass = action.Kind == "Excel" ? "report-action report-action-excel" : "report-action";
                                <a href="@action.Url" class="@cssClass">
                                    <i class="bi @icon"></i>
                                    @action.Label
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
        </section>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/reports.css" asp-append-version="true" />
}
