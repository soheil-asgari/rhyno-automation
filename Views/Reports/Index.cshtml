@model ReportsIndexViewModel
@{
    ViewData["Title"] = "گزارش‌ساز و خروجی‌ها";
}

<div class="container-fluid py-3" dir="rtl">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">گزارش‌ساز و خروجی‌ها</h5>
            <p class="text-muted small mb-0">مرکز واحد خروجی Excel، چاپ و گزارش‌های استاندارد بخش‌های اصلی</p>
        </div>
        <button type="button" class="btn btn-sm btn-outline-dark" onclick="window.print()">
            <i class="bi bi-printer"></i> چاپ صفحه
        </button>
    </div>

    <div class="row g-3">
        @foreach (var module in Model.Modules)
        {
            <div class="col-12 col-lg-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-start gap-2 mb-3">
                            <div class="rounded-2 bg-@module.Tone bg-opacity-10 text-@module.Tone d-flex align-items-center justify-content-center" style="width:34px;height:34px;">
                                <i class="bi @module.Icon"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">@module.Title</h6>
                                <p class="text-muted small mb-0">@module.Description</p>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var action in module.Actions)
                            {
                                var icon = action.Kind == "Excel" ? "bi-file-earmark-excel" : action.Kind == "Search" ? "bi-search" : "bi-bar-chart";
                                <a href="@action.Url" class="btn btn-sm @(action.Kind == "Excel" ? "btn-outline-success" : "btn-outline-primary")">
                                    <i class="bi @icon"></i> @action.Label
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
