@model WarehouseReceipt
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Warehouse Receipt Print</title>
    <style>
        body { font-family: Tahoma, sans-serif; margin: 24px; color: #111827; }
        table { width: 100%; border-collapse: collapse; margin-top: 14px; font-size: 12px; }
        th, td { border: 1px solid #e5e7eb; padding: 6px 8px; text-align: right; }
        th { background: #f9fafb; }
        .meta { font-size: 12px; color: #4b5563; margin-bottom: 4px; }
    </style>
</head>
<body onload="window.print()">
    <h3 style="margin-bottom:8px;">رسید انبار</h3>
    <div class="meta">شماره: @Model.ReceiptNumber | تاریخ: @Model.DateShamsi</div>
    <div class="meta">انبار: @Model.Warehouse.Name | منبع: @Model.SupplierOrSource</div>

    <table>
        <thead>
            <tr><th>کالا</th><th>تعداد</th><th>فی واحد</th><th>جمع</th></tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Product.Name</td>
                <td>@item.Quantity.ToString("N3")</td>
                <td>@item.UnitPrice.ToString("N0")</td>
                <td>@(item.Quantity * item.UnitPrice).ToString("N0")</td>
            </tr>
        }
        </tbody>
    </table>
</body>
</html>
