@{
    ViewData["Title"] = "گزارشات و داشبورد مدیریتی";
    var year = ViewBag.Year as int? ?? DateTime.Now.Year;
    var monthLabels = ViewBag.MonthLabels ?? new List<string>();
    var revenueSeries = ViewBag.RevenueSeries ?? new List<decimal>();
    var costSeries = ViewBag.CostSeries ?? new List<decimal>();
    var payrollSeries = ViewBag.PayrollSeries ?? new List<decimal>();
    var stockMovementSeries = ViewBag.StockMovementSeries ?? new List<decimal>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/financial-pages.css" asp-append-version="true" />
}

<div class="container-fluid py-4 hub-page">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h5 class="fw-bold mb-1">مرکز گزارشات و داشبورد مدیریتی</h5>
            <p class="text-muted small mb-0">تحلیل نموداری پیشرفته و مرکز یکپارچه خروجی‌ها</p>
        </div>
        <form method="get" class="d-flex gap-2 align-items-center">
            <label class="small text-muted mb-0">سال:</label>
            <input name="year" value="@year" type="number" min="1300" max="1700" class="form-control form-control-sm compact-year-input" />
            <button class="btn btn-sm btn-outline-primary">اعمال</button>
        </form>
    </div>

    <div class="card border-0 shadow-sm hub-card">
        <div class="card-body p-3">
            <ul class="nav nav-tabs hub-tabs mb-3" id="reportingHubTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="analytics-tab" data-bs-toggle="tab" data-bs-target="#analytics-panel" type="button" role="tab">داشبورد تحلیلی پیشرفته</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="exports-tab" data-bs-toggle="tab" data-bs-target="#exports-panel" type="button" role="tab">مرکز یکپارچه خروجی‌ها</button>
                </li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="analytics-panel" role="tabpanel" aria-labelledby="analytics-tab">
                    <div class="d-flex gap-2 mb-2 flex-wrap">
                        <button type="button" class="btn btn-sm btn-outline-primary chart-type-btn" data-chart-type="bar">Bar</button>
                        <button type="button" class="btn btn-sm btn-outline-primary chart-type-btn" data-chart-type="line">Line</button>
                        <button type="button" class="btn btn-sm btn-outline-primary chart-type-btn" data-chart-type="area">Area</button>
                    </div>
                    <div class="hub-chart-wrap"><canvas id="reportingHubChart"></canvas></div>
                </div>

                <div class="tab-pane fade" id="exports-panel" role="tabpanel" aria-labelledby="exports-tab">
                    <div class="hub-grid">
                        <div class="hub-action-card">
                            <h6>حقوق (Payroll)</h6>
                            <p>خروجی اکسل و چاپ فیش/گزارش حقوق</p>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-controller="Financial" asp-action="ExportPayrollExcel" asp-route-year="@year" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
                                <a asp-controller="Payroll" asp-action="Index" class="btn btn-sm btn-outline-dark">چاپ PDF</a>
                            </div>
                        </div>
                        <div class="hub-action-card">
                            <h6>بیمه (Bimeh)</h6>
                            <p>دسترسی سریع به چاپ و پیگیری لیست بیمه</p>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-controller="Bimeh" asp-action="Index" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
                                <a asp-controller="Bimeh" asp-action="Index" class="btn btn-sm btn-outline-dark">چاپ PDF</a>
                            </div>
                        </div>
                        <div class="hub-action-card">
                            <h6>موجودی انبار</h6>
                            <p>خروجی اکسل از موجودی جاری و گردش کالا</p>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-controller="Financial" asp-action="ExportStockExcel" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
                                <a asp-controller="Warehouse" asp-action="Stock" class="btn btn-sm btn-outline-dark">چاپ گزارش</a>
                            </div>
                        </div>
                        <div class="hub-action-card">
                            <h6>فروش</h6>
                            <p>خروجی اکسل و چاپ فاکتورهای فروش</p>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-controller="Financial" asp-action="ExportInvoicesExcel" asp-route-invoiceType="Sale" asp-route-year="@year" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
                                <a asp-controller="Financial" asp-action="Sales" class="btn btn-sm btn-outline-dark">چاپ PDF</a>
                            </div>
                        </div>
                        <div class="hub-action-card">
                            <h6>خرید</h6>
                            <p>خروجی اکسل و چاپ فاکتورهای خرید</p>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-controller="Financial" asp-action="ExportInvoicesExcel" asp-route-invoiceType="Purchase" asp-route-year="@year" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
                                <a asp-controller="Financial" asp-action="Purchases" class="btn btn-sm btn-outline-dark">چاپ PDF</a>
                            </div>
                        </div>
                        <div class="hub-action-card">
                            <h6>ماده ۱۶۹</h6>
                            <p>گزارش معاملات فصلی و خروجی حسابرسی</p>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-controller="Financial" asp-action="ExportInvoicesExcel" asp-route-year="@year" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
                                <a asp-controller="Financial" asp-action="SeasonalTax" asp-route-year="@year" class="btn btn-sm btn-outline-dark">چاپ گزارش</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (() => {
            const labels = @Html.Raw(Json.Serialize(monthLabels));
            const revenueSeries = @Html.Raw(Json.Serialize(revenueSeries));
            const costSeries = @Html.Raw(Json.Serialize(costSeries));
            const payrollSeries = @Html.Raw(Json.Serialize(payrollSeries));
            const stockMovementSeries = @Html.Raw(Json.Serialize(stockMovementSeries));

            const context = document.getElementById('reportingHubChart');
            let chart;

            function datasets(areaMode) {
                return [
                    {
                        label: 'سود و زیان (درآمد)',
                        data: revenueSeries,
                        borderColor: '#10b981',
                        backgroundColor: areaMode ? 'rgba(16,185,129,0.2)' : '#10b981',
                        fill: areaMode,
                        tension: .3
                    },
                    {
                        label: 'سود و زیان (هزینه)',
                        data: costSeries,
                        borderColor: '#ef4444',
                        backgroundColor: areaMode ? 'rgba(239,68,68,0.2)' : '#ef4444',
                        fill: areaMode,
                        tension: .3
                    },
                    {
                        label: 'هزینه‌های حقوق',
                        data: payrollSeries,
                        borderColor: '#f59e0b',
                        backgroundColor: areaMode ? 'rgba(245,158,11,0.2)' : '#f59e0b',
                        fill: areaMode,
                        tension: .3
                    },
                    {
                        label: 'حجم گردش انبار',
                        data: stockMovementSeries,
                        borderColor: '#3b82f6',
                        backgroundColor: areaMode ? 'rgba(59,130,246,0.2)' : '#3b82f6',
                        fill: areaMode,
                        tension: .3,
                        yAxisID: 'yStock'
                    }
                ];
            }

            function draw(type) {
                const isArea = type === 'area';
                const baseType = isArea ? 'line' : type;
                if (chart) chart.destroy();

                chart = new Chart(context, {
                    type: baseType,
                    data: { labels, datasets: datasets(isArea) },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom' } },
                        scales: {
                            y: {
                                position: 'left',
                                ticks: { callback: (val) => Number(val).toLocaleString('fa-IR') }
                            },
                            yStock: {
                                position: 'right',
                                grid: { drawOnChartArea: false },
                                ticks: { callback: (val) => Number(val).toLocaleString('fa-IR') }
                            }
                        }
                    }
                });
            }

            document.querySelectorAll('.chart-type-btn').forEach(button => {
                button.addEventListener('click', () => draw(button.getAttribute('data-chart-type') || 'bar'));
            });

            draw('bar');
        })();
    </script>
}
