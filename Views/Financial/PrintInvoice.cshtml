@model Invoice
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <title>Invoice Print</title>
</head>
<body onload="window.print()">
    <div class="head">
        <div class="title">فاکتور @(Model.InvoiceType == "Sale" ? "فروش" : "خرید")</div>
        <div class="meta">شماره: @Model.InvoiceNumber | تاریخ: @Model.DateShamsi</div>
        <div class="meta">طرف معامله: @Model.PartyName | شناسه: @(Model.NationalCodeOrEconomicId ?? "-")</div>
    </div>

    <table>
        <thead>
            <tr><th>شرح</th><th>تعداد</th><th>فی</th><th>جمع جزء</th><th>VAT</th><th>جمع کل</th></tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ItemName</td>
                <td>@item.Quantity.ToString("N3")</td>
                <td>@item.UnitPrice.ToString("N0")</td>
                <td>@item.LineSubTotal.ToString("N0")</td>
                <td>@item.LineVatAmount.ToString("N0")</td>
                <td>@item.LineGrandTotal.ToString("N0")</td>
            </tr>
        }
        </tbody>
    </table>

    <div class="totals">
        <div>جمع جزء: <strong>@Model.SubTotal.ToString("N0")</strong></div>
        <div>مالیات 10٪: <strong>@Model.VatAmount.ToString("N0")</strong></div>
        <div>جمع کل: <strong>@Model.GrandTotal.ToString("N0")</strong></div>
    </div>
</body>
</html>

@section Styles {
    <link rel="stylesheet" href="~/css/financial-print.css" asp-append-version="true" />
}
