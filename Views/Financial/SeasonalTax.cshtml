@model SeasonalTaxReportVM
@{
    ViewData["Title"] = "گزارش معاملات فصلی";
    var selectableYears = Enumerable.Range(Model.Year - 3, 7).Where(item => item >= 1300).OrderByDescending(item => item).ToList();
    var totalRows = Model.Rows.Count;
    var missingNationalIdCount = Model.Rows.Count(item => string.IsNullOrWhiteSpace(item.NationalId));
}

<div class="container-fluid py-4 seasonal-page" dir="rtl">
    <div class="section-header mb-3">
        <div>
            <h1 class="section-title">گزارش معاملات فصلی</h1>
            <p class="section-subtitle">کنترل مجموع، داده‌های ناقص و خروجی آماده برای ارسال</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
            <form method="get" asp-action="SeasonalTax" class="row g-2 align-items-end">
                <div class="col-6 col-md-2">
                    <label class="form-label small mb-1">سال</label>
                    <select name="year" class="form-select form-select-sm">
                        @foreach (var item in selectableYears)
                        {
                            <option value="@item" selected="@(item == Model.Year)">@item</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <label class="form-label small mb-1">فصل</label>
                    <select name="quarter" class="form-select form-select-sm">
                        <option value="1" selected="@(Model.Quarter == 1)">بهار</option>
                        <option value="2" selected="@(Model.Quarter == 2)">تابستان</option>
                        <option value="3" selected="@(Model.Quarter == 3)">پاییز</option>
                        <option value="4" selected="@(Model.Quarter == 4)">زمستان</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <button class="btn btn-sm btn-primary w-100">اعمال</button>
                </div>
                <div class="col-6 col-md-2">
                    <a asp-action="ExportInvoicesExcel" asp-route-year="@Model.Year" asp-route-quarter="@Model.Quarter" class="btn btn-sm btn-outline-success w-100">خروجی اکسل</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">جمع مبلغ</div>
                    <div class="fs-5 fw-bold">@Model.TotalAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">جمع VAT</div>
                    <div class="fs-5 fw-bold">@Model.TotalVat.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">ردیفهای ناقص</div>
                    <div class="fs-5 fw-bold @(missingNationalIdCount > 0 ? "text-warning" : "text-success")">@missingNationalIdCount</div>
                </div>
            </div>
        </div>
    </div>

    @if (missingNationalIdCount > 0)
    {
        <div class="alert alert-warning small mb-3">
            تعدادی از ردیف‌ها شناسه ملی / اقتصادی ندارند. برای ارسال قابل‌دفاع، این داده‌ها باید تکمیل شوند.
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0" style="font-size:.82rem;">
                <thead>
                    <tr>
                        <th>نوع معامله</th>
                        <th>نام طرف معامله</th>
                        <th>کد ملی / شناسه اقتصادی</th>
                        <th>جمع جزء</th>
                        <th>VAT</th>
                        <th>جمع کل</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Rows.Any())
                {
                    @foreach (var row in Model.Rows)
                    {
                        var grandTotal = row.Amount + row.Vat;
                        <tr class="@(string.IsNullOrWhiteSpace(row.NationalId) ? "table-warning" : "")">
                            <td><span class="badge @(row.TransactionType == "فروش" ? "text-bg-success" : "text-bg-primary")">@row.TransactionType</span></td>
                            <td>@row.PartyName</td>
                            <td>@(row.NationalId ?? "-")</td>
                            <td>@row.Amount.ToString("N0")</td>
                            <td>@row.Vat.ToString("N0")</td>
                            <td>@grandTotal.ToString("N0")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">برای فصل انتخاب‌شده داده‌ای یافت نشد.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
