@model FinancialInvoiceIndexVM
@{
    var pageTitle = ViewBag.PageTitle as string ?? "مدیریت فاکتورها";
    var pageDescription = ViewBag.PageDescription as string ?? "مدیریت فرآیندهای مالی";
    var createInvoiceType = ViewBag.CreateInvoiceType as string ?? Model.InvoiceType ?? "Sale";
    var exportInvoiceType = ViewBag.ExportInvoiceType as string ?? Model.InvoiceType;
    var returnTo = exportInvoiceType == "Purchase" ? "Purchase" : "Sale";
}

@section Styles {
    <link rel="stylesheet" href="~/css/financial-pages.css" asp-append-version="true" />
}

<div class="container-fluid py-4 fin-page">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success alert-dismissible fade show py-2 px-3 small mb-3" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger alert-dismissible fade show py-2 px-3 small mb-3" role="alert">
            @errorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h5 class="fw-bold mb-1">@pageTitle</h5>
            <p class="text-muted small mb-0">@pageDescription</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="CreateInvoice" asp-route-invoiceType="@createInvoiceType" class="btn btn-sm btn-primary">ثبت فاکتور</a>
            <a asp-action="ExportInvoicesExcel" asp-route-invoiceType="@exportInvoiceType" asp-route-year="@Model.Year" asp-route-quarter="@Model.Quarter" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
            <a asp-action="PrintInvoicePdf" asp-route-id="@(Model.Items.FirstOrDefault()?.Id ?? 0)" class="btn btn-sm btn-outline-dark @(Model.Items.Any() ? "" : "disabled")">چاپ PDF</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm fin-card mb-3">
        <div class="card-body p-3">
            <form method="get" class="row g-2 align-items-end fin-compact">
                <div class="col-12 col-md-3"><label asp-for="SearchTerm" class="form-label small mb-1">جستجو</label><input asp-for="SearchTerm" class="form-control form-control-sm" placeholder="شماره/نام/شناسه" /></div>
                <div class="col-6 col-md-2"><label asp-for="Year" class="form-label small mb-1">سال</label><input asp-for="Year" class="form-control form-control-sm" type="number" min="1300" max="1700" /></div>
                <div class="col-6 col-md-2"><label asp-for="Quarter" class="form-label small mb-1">فصل</label><select asp-for="Quarter" class="form-select form-select-sm"><option value="">همه</option><option value="1">بهار</option><option value="2">تابستان</option><option value="3">پاییز</option><option value="4">زمستان</option></select></div>
                <div class="col-6 col-md-2"><button class="btn btn-sm btn-primary w-100">اعمال</button></div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm fin-card">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0 fin-compact" data-pro-table="financial-invoices-@exportInvoiceType">
                <thead class="bg-slate-100 dark:bg-slate-850 text-slate-700 dark:text-slate-200">
                    <tr>
                        <th>شماره</th>
                        <th>نوع</th>
                        <th>تاریخ</th>
                        <th>طرف معامله</th>
                        <th>شناسه</th>
                        <th>جمع جزء</th>
                        <th>VAT 10%</th>
                        <th>وضعیت</th>
                        <th>جمع کل</th>
                        <th class="text-center">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Items.Any())
                {
                    <tr class="loading-state">
                        <td colspan="10">
                            <div class="placeholder-glow">
                                <span class="placeholder col-4"></span>
                                <span class="placeholder col-6"></span>
                                <span class="placeholder col-3"></span>
                            </div>
                        </td>
                    </tr>
                }
                @if (Model.Items.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.InvoiceNumber</td>
                            <td><span class="badge @(item.InvoiceType == "Sale" ? "text-bg-success" : "text-bg-primary")">@(item.InvoiceType == "Sale" ? "فروش" : "خرید")</span></td>
                            <td>@item.DateShamsi</td>
                            <td>@item.PartyName</td>
                            <td>@(item.NationalCodeOrEconomicId ?? "-")</td>
                            <td>@item.SubTotal.ToString("N0")</td>
                            <td>@item.VatAmount.ToString("N0")</td>
                            <td><span class="badge @WorkflowStatus.BadgeCss(item.WorkflowStatus)">@WorkflowStatus.Label(item.WorkflowStatus)</span></td>
                            <td class="fw-bold">@item.GrandTotal.ToString("N0")</td>
                            <td class="text-center">
                                <div class="d-inline-flex gap-1">
                                    <a asp-action="EditInvoice" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                    @if (!WorkflowStatus.IsApproved(item.WorkflowStatus))
                                    {
                                        <form asp-action="ApproveInvoice" asp-route-id="@item.Id" asp-route-returnTo="@returnTo" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-success">تایید</button>
                                        </form>
                                    }
                                    @if (!WorkflowStatus.IsRejected(item.WorkflowStatus))
                                    {
                                        <form asp-action="RejectInvoice" asp-route-id="@item.Id" asp-route-returnTo="@returnTo" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-warning">رد</button>
                                        </form>
                                    }
                                    <form asp-action="DeleteInvoice" asp-route-id="@item.Id" asp-route-returnTo="@returnTo" method="post" class="d-inline" onsubmit="return confirm('فاکتور حذف شود؟');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                    </form>
                                    <a asp-action="PrintInvoicePdf" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">Print PDF</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9">
                            <partial name="_EmptyState" model='new { Icon = "bi-receipt", Title = "فاکتوری ثبت نشده است.", Description = "از دکمه ثبت فاکتور برای ایجاد اولین سند استفاده کنید." }' />
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

