@model FinancialDashboardVM
@{
    ViewData["Title"] = "داشبورد مالی";
    var year = ViewBag.Year as int? ?? DateTime.Now.Year;
}

<div class="container-fluid py-4 fin-hub">
    <div class="fin-topline mb-4">
        <div>
            <h5 class="fw-bold mb-1">داشبورد مالی</h5>
            <p class="text-muted small mb-0">نمای عملیاتی فروش، خرید، مالیات، معاملات فصلی، حقوق و بیمه</p>
        </div>
        <form method="get" class="d-flex gap-2 align-items-center flex-wrap">
            <label class="small text-muted mb-0">سال</label>
            <input name="year" value="@year" type="number" min="1300" max="1700" class="form-control form-control-sm compact-year-input" />
            <button class="btn btn-sm btn-outline-primary">اعمال</button>
        </form>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="hub-kpi hub-tone-success">
                <div class="hub-kpi-label">فروش ماه</div>
                <div class="hub-kpi-value">@Model.MonthlySalesTotal.ToString("N0")</div>
                <div class="hub-kpi-desc">جمع فروش ثبت‌شده</div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="hub-kpi hub-tone-danger">
                <div class="hub-kpi-label">خرید ماه</div>
                <div class="hub-kpi-value">@Model.MonthlyPurchaseTotal.ToString("N0")</div>
                <div class="hub-kpi-desc">جمع خرید ثبت‌شده</div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="hub-kpi hub-tone-warning">
                <div class="hub-kpi-label">مالیات پرداختنی</div>
                <div class="hub-kpi-value">@Model.MonthlyTaxPayable.ToString("N0")</div>
                <div class="hub-kpi-desc">خروجی نهایی کنترل مالیات</div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="hub-kpi hub-tone-info">
                <div class="hub-kpi-label">فاکتور معوق</div>
                <div class="hub-kpi-value">@Model.OverdueInvoices.ToString("N0")</div>
                <div class="hub-kpi-desc">نیازمند پیگیری فوری</div>
            </div>
        </div>
        @foreach (var kpi in Model.HubKpis)
        {
            <div class="col-12 col-md-6 col-xl-3">
                <div class="hub-kpi hub-tone-@kpi.Tone">
                    <div class="hub-kpi-label">@kpi.Title</div>
                    <div class="hub-kpi-value">@kpi.Value</div>
                    <div class="hub-kpi-desc">@kpi.Description</div>
                </div>
            </div>
        }
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-xl-8">
            <section class="card border-0 shadow-sm fin-card">
                <div class="card-body p-3 p-md-4">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <div>
                            <h6 class="fw-bold mb-1">روند مالی</h6>
                            <div class="text-muted small">درآمد، هزینه و سود یا زیان در دوازده ماه</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <a asp-action="Sales" class="btn btn-sm btn-outline-success">فروش</a>
                            <a asp-action="Purchases" class="btn btn-sm btn-outline-primary">خرید</a>
                            <a asp-action="VatDashboard" class="btn btn-sm btn-outline-warning">ارزش افزوده</a>
                            <a asp-action="SeasonalTax" class="btn btn-sm btn-outline-info">معاملات فصلی</a>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mb-3 flex-wrap">
                        <button type="button" class="btn btn-sm btn-outline-primary chart-mode is-active" data-mode="bar">نمودار ستونی</button>
                        <button type="button" class="btn btn-sm btn-outline-primary chart-mode" data-mode="line">نمودار خطی</button>
                        <button type="button" class="btn btn-sm btn-outline-primary chart-mode" data-mode="area">نمودار ناحیه‌ای</button>
                    </div>

                    @if (Model.ValidationWarnings > 0 || Model.OverdueInvoices > 0)
                    {
                        <div class="alert alert-warning small mb-3">
                            @if (Model.ValidationWarnings > 0)
                            {
                                <div>@Model.ValidationWarnings مورد نیازمند بررسی ثبت شده است.</div>
                            }
                            @if (Model.OverdueInvoices > 0)
                            {
                                <div>@Model.OverdueInvoices فاکتور معوق شناسایی شد.</div>
                            }
                        </div>
                    }

                    <div class="chart-shell">
                        <canvas id="finHubChart"></canvas>
                    </div>
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-4">
            <section class="card border-0 shadow-sm fin-card h-100">
                <div class="card-body p-3 p-md-4">
                    <h6 class="fw-bold mb-3">دسترسی سریع</h6>
                    <partial name="_QuickActionsGrid" model="Model.QuickActions" />
                </div>
            </section>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-xl-7">
            <section class="card border-0 shadow-sm fin-card h-100">
                <div class="card-body p-3 p-md-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold mb-0">آخرین عملیات</h6>
                        <a asp-action="Invoices" class="btn btn-sm btn-outline-secondary">مشاهده همه</a>
                    </div>
                    <div class="activity-list">
                        @if (Model.RecentActivities.Any())
                        {
                            @foreach (var item in Model.RecentActivities)
                            {
                                <a href="@item.Url" class="activity-item">
                                    <div>
                                        <strong>@item.Title</strong>
                                        <span>@item.Subtitle</span>
                                    </div>
                                    <span class="badge text-bg-@item.BadgeTone">@item.Badge</span>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="text-muted small">عملیات اخیر وجود ندارد.</div>
                        }
                    </div>
                </div>
            </section>
        </div>

        <div class="col-12 col-xl-5">
            <section class="card border-0 shadow-sm fin-card h-100">
                <div class="card-body p-3 p-md-4">
                    <h6 class="fw-bold mb-3">هشدارهای عملیاتی</h6>
                    <div class="hub-alert-list">
                        <div class="hub-alert tone-warning">
                            <strong>فاکتورهای در انتظار</strong>
                            <span>@Model.PendingSalesInvoices فاکتور فروش و @Model.PendingPurchaseInvoices فاکتور خرید نیاز به پیگیری دارند.</span>
                        </div>
                        <div class="hub-alert tone-danger">
                            <strong>هشدار اعتبارسنجی</strong>
                            <span>@Model.ValidationWarnings رکورد ناقص یا مشکوک شناسایی شده است.</span>
                        </div>
                        <div class="hub-alert tone-info">
                            <strong>سررسید نزدیک</strong>
                            <span>@Model.DuePurchaseDeadlines فاکتور خرید دارای موعد نزدیک است.</span>
                        </div>
                    </div>
                    <div class="mt-3">
                        <a asp-action="ReportingHub" class="btn btn-sm btn-outline-primary w-100">رفتن به گزارش‌های پیشرفته</a>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/financial-dashboard.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (() => {
            const context = document.getElementById('finHubChart');
            if (!context || typeof Chart === 'undefined') return;

            const labels = @Html.Raw(Json.Serialize(Model.MonthLabels));
            const revenue = @Html.Raw(Json.Serialize(Model.RevenueSeries));
            const costs = @Html.Raw(Json.Serialize(Model.CostSeries));
            const profit = @Html.Raw(Json.Serialize(Model.ProfitSeries));
            let chart;

            function buildDatasets(areaMode) {
                return [
                    { label: 'درآمد', data: revenue, borderColor: '#10b981', backgroundColor: areaMode ? 'rgba(16,185,129,0.18)' : '#10b981', fill: areaMode, tension: 0.28 },
                    { label: 'هزینه', data: costs, borderColor: '#ef4444', backgroundColor: areaMode ? 'rgba(239,68,68,0.18)' : '#ef4444', fill: areaMode, tension: 0.28 },
                    { label: 'سود یا زیان', data: profit, borderColor: '#3b82f6', backgroundColor: areaMode ? 'rgba(59,130,246,0.18)' : '#3b82f6', fill: areaMode, tension: 0.28 }
                ];
            }

            function setActiveButton(mode) {
                document.querySelectorAll('.chart-mode').forEach(button => {
                    button.classList.toggle('is-active', button.getAttribute('data-mode') === mode);
                });
            }

            function renderChart(mode) {
                const areaMode = mode === 'area';
                const chartType = areaMode ? 'line' : mode;
                if (chart) chart.destroy();

                chart = new Chart(context, {
                    type: chartType,
                    data: {
                        labels,
                        datasets: buildDatasets(areaMode)
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        resizeDelay: 120,
                        plugins: {
                            legend: {
                                position: 'bottom'
                            }
                        },
                        scales: {
                            y: {
                                ticks: {
                                    callback: (value) => Number(value).toLocaleString('fa-IR')
                                }
                            }
                        }
                    }
                });

                setActiveButton(mode);
            }

            document.querySelectorAll('.chart-mode').forEach(button => {
                button.addEventListener('click', () => renderChart(button.getAttribute('data-mode') || 'bar'));
            });

            renderChart('bar');
        })();
    </script>
}
