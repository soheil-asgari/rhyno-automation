@model SeasonalTaxReportVM
@{
    ViewData["Title"] = "گزارش معاملات فصلی - ماده ۱۶۹";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h5 class="fw-bold mb-1">گزارش معاملات فصلی - ماده ۱۶۹</h5>
            <p class="text-muted small mb-0">فصل: @Model.QuarterTitle | سال: @Model.Year</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="SeasonalTaxReport" asp-route-year="@Model.Year" asp-route-quarter="1" class="btn btn-sm btn-outline-secondary">بهار</a>
            <a asp-action="SeasonalTaxReport" asp-route-year="@Model.Year" asp-route-quarter="2" class="btn btn-sm btn-outline-secondary">تابستان</a>
            <a asp-action="SeasonalTaxReport" asp-route-year="@Model.Year" asp-route-quarter="3" class="btn btn-sm btn-outline-secondary">پاییز</a>
            <a asp-action="SeasonalTaxReport" asp-route-year="@Model.Year" asp-route-quarter="4" class="btn btn-sm btn-outline-secondary">زمستان</a>
            <a asp-action="ExportInvoicesExcel" asp-route-year="@Model.Year" asp-route-quarter="@Model.Quarter" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-3 border-bottom">
            <div class="small text-muted">جمع مبلغ: <strong>@Model.TotalAmount.ToString("N0")</strong> | جمع مالیات: <strong>@Model.TotalVat.ToString("N0")</strong></div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0" style="font-size:.82rem;">
                <thead>
                    <tr>
                        <th>نام خریدار/فروشنده</th>
                        <th>شناسه ملی/اقتصادی</th>
                        <th>نوع معامله</th>
                        <th>مبلغ</th>
                        <th>VAT</th>
                        <th>تاریخ</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Rows.Any())
                {
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>@row.PartyName</td>
                            <td>@(row.NationalId ?? "-")</td>
                            <td><span class="badge @(row.TransactionType == "فروش" ? "text-bg-success" : "text-bg-primary")">@row.TransactionType</span></td>
                            <td>@row.Amount.ToString("N0")</td>
                            <td>@row.Vat.ToString("N0")</td>
                            <td>@row.DateShamsi</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">داده‌ای برای فصل انتخاب‌شده وجود ندارد.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
