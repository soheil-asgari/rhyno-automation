@model SeasonalTaxReportVM
@{
    ViewData["Title"] = "گزارش معاملات فصلی";
    var missingNationalIdCount = Model.Rows.Count(item => string.IsNullOrWhiteSpace(item.NationalId));
}

<div class="container-fluid py-4" dir="rtl">
    <div class="section-header mb-3">
        <div>
            <h1 class="section-title">گزارش معاملات فصلی</h1>
            <p class="section-subtitle">نمای حسابرسی و آماده برای تصمیم‌گیری</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="SeasonalTaxReport" asp-route-year="@Model.Year" asp-route-quarter="1" class="btn btn-sm btn-outline-secondary">بهار</a>
            <a asp-action="SeasonalTaxReport" asp-route-year="@Model.Year" asp-route-quarter="2" class="btn btn-sm btn-outline-secondary">تابستان</a>
            <a asp-action="SeasonalTaxReport" asp-route-year="@Model.Year" asp-route-quarter="3" class="btn btn-sm btn-outline-secondary">پاییز</a>
            <a asp-action="SeasonalTaxReport" asp-route-year="@Model.Year" asp-route-quarter="4" class="btn btn-sm btn-outline-secondary">زمستان</a>
            <a asp-action="ExportInvoicesExcel" asp-route-year="@Model.Year" asp-route-quarter="@Model.Quarter" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
        </div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">جمع مبلغ</div>
                    <div class="fs-5 fw-bold">@Model.TotalAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">جمع مالیات</div>
                    <div class="fs-5 fw-bold">@Model.TotalVat.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">ردیفهای ناقص</div>
                    <div class="fs-5 fw-bold @(missingNationalIdCount > 0 ? "text-warning" : "text-success")">@missingNationalIdCount</div>
                </div>
            </div>
        </div>
    </div>

    @if (missingNationalIdCount > 0)
    {
        <div class="alert alert-warning small mb-3">
            این گزارش برای ارسال نهایی هنوز کامل نیست. ردیف‌های بدون شناسه ملی / اقتصادی باید تکمیل شوند.
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0 table-sm-readable">
                <thead>
                    <tr>
                        <th>نام خریدار/فروشنده</th>
                        <th>شناسه</th>
                        <th>نوع معامله</th>
                        <th>مبلغ</th>
                        <th>VAT</th>
                        <th>تاریخ</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Rows.Any())
                {
                    @foreach (var row in Model.Rows)
                    {
                        <tr class="@(string.IsNullOrWhiteSpace(row.NationalId) ? "table-warning" : "")">
                            <td>@row.PartyName</td>
                            <td>@(row.NationalId ?? "-")</td>
                            <td><span class="badge @(row.TransactionType == "فروش" ? "text-bg-success" : "text-bg-primary")">@row.TransactionType</span></td>
                            <td>@row.Amount.ToString("N0")</td>
                            <td>@row.Vat.ToString("N0")</td>
                            <td>@row.DateShamsi</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">برای فصل انتخاب‌شده ردیفی وجود ندارد.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

