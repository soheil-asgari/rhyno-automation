@model FinancialDashboardVM
@{
    ViewData["Title"] = "مالیات بر ارزش افزوده (VAT)";
    var year = ViewBag.Year as int? ?? DateTime.Now.Year;
}

@section Styles {
    <style>
        .vat-page { direction: rtl; text-align: right; }
        .vat-card { border-radius: 12px; }
        .vat-label { font-size: .76rem; color: #64748b; }
        .vat-value { font-size: 1.02rem; font-weight: 700; }
        .vat-table { font-size: .8rem; }
    </style>
}

<div class="container-fluid py-4 vat-page">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div>
            <h5 class="fw-bold mb-1">داشبورد مالیات بر ارزش افزوده</h5>
            <p class="text-muted small mb-0">خلاصه VAT دریافت‌شده، پرداخت‌شده و مانده پرداخت/استرداد</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="ExportInvoicesExcel" asp-route-year="@year" class="btn btn-sm btn-outline-success">خروجی اکسل</a>
            <a asp-action="PrintInvoicePdf" asp-route-id="@(Model.VatRows.FirstOrDefault()?.Id ?? 0)" class="btn btn-sm btn-outline-dark @(Model.VatRows.Any() ? "" : "disabled")">چاپ PDF</a>
        </div>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm vat-card">
                <div class="card-body py-2 px-3">
                    <div class="vat-label">کل VAT وصولی (فروش)</div>
                    <div class="vat-value text-success">@Model.TotalVatCollected.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm vat-card">
                <div class="card-body py-2 px-3">
                    <div class="vat-label">کل VAT پرداختی (خرید)</div>
                    <div class="vat-value text-primary">@Model.TotalVatPaid.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card border-0 shadow-sm vat-card">
                <div class="card-body py-2 px-3">
                    <div class="vat-label">خالص VAT پرداختنی / استردادی</div>
                    <div class="vat-value @(Model.NetVatPayableOrRefundable >= 0 ? "text-danger" : "text-info")">@Model.NetVatPayableOrRefundable.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm vat-card">
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0 vat-table">
                <thead>
                    <tr>
                        <th>شماره فاکتور</th>
                        <th>نوع</th>
                        <th>تاریخ</th>
                        <th>طرف معامله</th>
                        <th>جمع جزء</th>
                        <th>VAT 10%</th>
                        <th>جمع کل</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.VatRows.Any())
                {
                    @foreach (var item in Model.VatRows)
                    {
                        <tr>
                            <td>@item.InvoiceNumber</td>
                            <td><span class="badge @(item.InvoiceType == "Sale" ? "text-bg-success" : "text-bg-primary")">@(item.InvoiceType == "Sale" ? "فروش" : "خرید")</span></td>
                            <td>@item.DateShamsi</td>
                            <td>@item.PartyName</td>
                            <td>@item.SubTotal.ToString("N0")</td>
                            <td class="fw-semibold">@item.VatAmount.ToString("N0")</td>
                            <td>@item.GrandTotal.ToString("N0")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">برای سال انتخاب‌شده داده VAT ثبت نشده است.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
