@model WaybillDetailsVM
@{
    ViewData["Title"] = "حذف بارنامه";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Waybill.css" asp-append-version="true" />
}

<div class="container-fluid py-4 waybill-page">
    <div class="card border-0 shadow-sm waybill-card">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-4">
                <div class="waybill-danger-icon mx-auto mb-3">
                    <i class="bi bi-trash3"></i>
                </div>
                <h5 class="fw-bold text-danger mb-2">حذف بارنامه</h5>
                <p class="text-muted small mb-0">آیا از حذف این بارنامه مطمئن هستید؟</p>
            </div>

            <div class="waybill-delete-summary mb-4">
                <div class="row g-3">
                    <div class="col-md-6"><strong>شماره بارنامه:</strong> @Model.WaybillNumber</div>
                    <div class="col-md-6"><strong>تاریخ صدور:</strong> @Model.IssueDate.ToString("yyyy/MM/dd")</div>
                    <div class="col-md-6"><strong>راننده:</strong> @Model.DriverName</div>
                    <div class="col-md-6"><strong>مسیر:</strong> @Model.OriginCity → @Model.DestinationCity</div>
                </div>
            </div>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex justify-content-center gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">انصراف</a>
                <button type="submit" class="btn btn-danger px-4">تایید حذف</button>
            </form>
        </div>
    </div>
</div>
