{
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "StartupMigrationTimeout": "00:00:30"
  },
  "Bootstrap": {
    "RunOnStartup": false
  },
  "Tenancy": {
    "DefaultTenantId": "default",
    "Tenants": [
      {
        "TenantId": "default",
        "Name": "Default Tenant",
        "IsolationMode": "DatabasePerTenant",
        "ConnectionString": "Server=(localdb)\\mssqllocaldb;Database=OfficeAutoDbDev;Trusted_Connection=True;MultipleActiveResultSets=true",
        "DatabaseSchema": "dbo",
        "QueueNamespace": "default-dev",
        "CachePrefix": "default-dev",
        "StorageRoot": "tenants/default-dev",
        "LogPrefix": "default-dev",
        "LogRoot": "logs/default-dev",
        "SettingsNamespace": "default-dev:settings",
        "JobNamespace": "default-dev:jobs",
        "RedisDatabase": 0,
        "EnableOutboxPublisher": true,
        "EnableWorkflowJobs": true
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Workflow": {
    "SeedSampleData": false
  },
  "Outbox": {
    "BatchSize": 20,
    "PollIntervalSeconds": 5,
    "LockTimeoutSeconds": 30,
    "MaxRetryCount": 10
  },
  "BackgroundWorkers": {
    "RunInWebHost": false
  },
  "AuditRetention": {
    "Enabled": false,
    "RetainDays": 30,
    "BatchSize": 200,
    "ArchivePath": "logs/audit-archive-dev"
  }
}
